<?xml version="1.0" encoding="utf-8"?>
<odoo>
   <!-- Event Screen membership_authorization -->
    <record id="view_ike_event_screen_membership_authorization_form" model="ir.ui.view">
        <field name="name">view.ike.event.screen.form</field>
        <field name="model">ike.event</field>
        <field name="inherit_id" ref="ike_event.view_ike_event_screen_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group[@name='user_data']" position="attributes">
                <attribute name="invisible">membership_authorization_status in ('pending_cabine','rejected','pending_commercial', False) or not sections.get('user_data', False)</attribute>
            </xpath>
            <xpath expr="//sheet/group[@name='titular_user']" position="attributes">
                <attribute name="invisible">membership_authorization_status in ('authorized', False) or not sections.get('user_data', False)</attribute>
            </xpath>
            <xpath expr="//sheet/widget[@name='ike_event_screen_header_info']" position="attributes">
                <attribute name="invisible">membership_authorization_status in ('rejected', False) or not user_id </attribute>
            </xpath>
            <xpath expr="//sheet/group[@name='titular_user']" position="after">
                <group col="2">
                    <div class="d-flex justify-content-end ">
                        <button name="action_open_register_user_wizard" 
                        type="object"
                        class="btn-link" 
                        invisible="membership_authorization_status in ('pending_cabine','pending_commercial','rejected','authorized') 
                        or stage_ref in ('cancel')">Register user key</button>
                        <!-- <field name="membership_authorization_status" widget="badge" readonly="1" invisible="not membership_authorization_status"/> -->
                        <button 
                            string="Authorization"
                            name="action_view_authorization"
                            type="object" 
                            invisible="membership_authorization_status in ['pending_cabine','pending_commercial','authorized', False] or stage_ref == 'cancel'" 
                            groups="base.group_system,custom_master_catalog.custom_group_event_cabin_supervisor">
                        </button>
                        <button 
                            string="Authorization"
                            name="action_view_authorization"
                            type="object" 
                            invisible="membership_authorization_status not in ['pending_cabine','pending_commercial'] or stage_ref == 'cancel' or not sections.get('user_data', False)" 
                            groups="base.group_system,custom_master_catalog.custom_group_event_cabin_supervisor">
                        </button>
                    </div>
                </group>
            </xpath>
            <!-- Button before alters service coverage -->
            <xpath expr="//group[@name='sub_service']//separator[@class='col-12 my-1']" position="before">

                <button 
                    string="Authorization"
                    name="action_view_authorization"
                    type="object" 
                    groups="base.group_system,custom_master_catalog.custom_group_event_coordinator"
                    context="{'from_event_button_service': True}"
                    invisible="services_available != 0 or membership_authorization_status in ['rejected','pending_cabine','pending_commercial'] or ( required_commercial_authorizer and event_coverage_authorizer) or ( required_commercial_authorizer and not event_coverage_authorizer) or  (not required_commercial_authorizer and event_coverage_authorizer)">
                </button>
                <button 
                    string="Authorization"
                    name="action_view_authorization"
                    type="object"
                    invisible="membership_authorization_status in ['authorized']" 
                    groups="custom_master_catalog.custom_group_event_cabin_supervisor,custom_master_catalog.custom_group_commercial_supervisor">
                </button>
                <div invisible="not event_coverage_authorizer or membership_authorization_id.state == 'rejected'" class="d-flex justify-content-center">
                    <p>Approved by the responsible authorizer</p>
                </div>
            </xpath>

            <!-- Hide button if not services coverage -->
            <xpath expr="//group[@name='sub_service']//button[@name='action_forward']" position="attributes">
                <attribute name="invisible">
                    not sub_service_id or (services_available == 0 and not event_coverage_authorizer)  or (required_commercial_authorizer and not event_coverage_authorizer)
                </attribute>
            </xpath>
        </field>
    </record>
</odoo>
