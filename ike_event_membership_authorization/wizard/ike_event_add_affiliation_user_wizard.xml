<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ike_event_add_nu_user_view_form" model="ir.ui.view">
    <field name="name">ike.add.user.wizard.form</field>
    <field name="model">ike.add.affiliation.nu</field>
    <field name="arch" type="xml">
            <form>
                <!-- Key Identification -->
                <group string="Key identification" class="o_group_border">
                    <label for="account_id"/>
                    <field name="account_id" required="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}" readonly="0"/>
                    <field name="account_name" readonly="1" invisible="1"/>
                    <field name="is_policy_account" invisible="1"/>
                    <field name="x_validation_pattern" invisible="1"/>
                    <field name="x_validation_pattern_second" invisible="1"/>
                    <field name="x_display_mask" invisible="1"/>
                    <field name="x_display_mask_second" invisible="1"/>
                    <!-- Membership -->
                    <!-- <label for="key_primary" class="o_form_label_required"/> -->
                    <group>
                        <field name="label_identification_primary" nolabel="1"/>
                        <field name="key_primary" password="1" nolabel="1" invisible="not account_id" widget="regex_validator_field"/>
                        <field name="label_identification_second" invisible="not check_second_key" nolabel="1"/>
                        <field name="key_second" password="1" invisible="not check_second_key" nolabel="1"
                        widget="regex_validator_field"
                        mask_field="x_display_mask_second"
                        pattern_field="x_validation_pattern_second"/>
                    </group>

                    <group>
                        <field name="clause_primary" invisible="not check_clause"  />
                        <field name="clause_second" invisible="not check_clause_second" required="check_clause_second"/>
                    </group>
                </group>

                <!-- User -->
                <group>
                    <group string="User" class="o_group_border">
                        <field name="name" required="1" force_save="1" readonly="fields_readonly"/>
                        <field name="phone" required="1" force_save="1" readonly="fields_readonly"/>
                        <field name="phone_alternative" widget="phone" options="{'enable_sms': False, 'enable_call': False}"/>
                    </group>
                    <group string="Affiliation" invisible="not fields_readonly">
                        <field name="vehicle_weight_category_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}"/>
                        <field name="check_is_fleet" readonly="1" force_save="1" />
                        <field name="check_is_special" readonly="1" force_save="1"/>
                    </group>
                </group>

                <!-- Preference -->
                <group string="Contact preference">
                    <field name="contact_preference" widget="preference_contact_widget"  widget_props="{'hide_email': true}"/>
                </group>

                <!-- Authorization -->
                <group string="Authorizing responsible" invisible="not authorization">
                    <field name="authorization" invisible="1"/>
                    <field name="x_domain_authorization_affiliation" invisible="1"/>
                    <field name="user_authorization_affiliation_id"
                        domain="x_domain_authorization_affiliation"
                        required="authorization"
                        options="{'no_open': True, 'no_create': True, 'no_edit': True}"/>
                </group>

                <footer>
                    <button string="Continue"
                            type="object"
                            name="action_save"
                            class="btn-primary"
                            context="{'from_event_button': False}"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ike_register_user_wizard" model="ir.actions.act_window">
        <field name="name">User register</field>
        <field name="res_model">ike.add.affiliation.nu</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="ike_event_add_nu_user_view_form"/>
        <field name="target">new</field>
        <field name="context"
            eval="{
                'default_custom_type_police_id': ref('custom_master_catalog.account_identification_policy'),
            }"/>
    </record>

</odoo>
