<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View ike.event.stage View List -->
    <record id="view_ike_event_stage_list" model="ir.ui.view">
        <field name="name">view.ike.event.stage.list</field>
        <field name="model">ike.event.stage</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" duplicate="0" editable="bottom">
                <field name="sequence" readonly="1"/>
                <field name="name" readonly="1"/>
                <field name="apply_max_wait_time"/>
                <field name="max_wait_time_minutes"/>
                <field name="apply_tracking_time"/>
                <field name="tracking_time_minutes"/>
            </list>
        </field>
    </record>

    <!-- View ike.event.stage search -->
    <record id="view_ike_event_stage_search" model="ir.ui.view">
        <field name="name">view.ike.event.stage.search</field>
        <field name="model">ike.event.stage</field>
        <field name="arch" type="xml">
            <search>
                <group expand="1" string="Group By">
                    <filter string="Name" name="name" domain="[]" context="{'group_by':'name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action ike.event.stage -->
    <record id="action_ike_event_stage" model="ir.actions.act_window">
        <field name="name">Event Stage</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">ike.event.stage</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

</odoo>
