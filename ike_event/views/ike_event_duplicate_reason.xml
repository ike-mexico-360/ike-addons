<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ike_event_duplicate_reason_view_form" model="ir.ui.view">
        <field name="name">ike.event.duplicate.reason.view.form</field>
        <field name="model">ike.event.duplicate.reason</field>
        <field name="arch" type="xml">
            <form duplicate="false" delete="false">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active" />
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active" />
                    <group>
                        <h1>
                            <label for="name" class="o_form_label_required"/>
                            <field name="name" required="1" placeholder="Reason"/>
                        </h1>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="ike_event_duplicate_reason_view_list" model="ir.ui.view">
        <field name="name">ike_event_duplicate_reason.view_list</field>
        <field name="model">ike.event.duplicate.reason</field>
        <field name="arch" type="xml">
            <list edit="false" duplicate="false" delete="false">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="ike_event_duplicate_reason_view_search" model="ir.ui.view">
        <field name="name">ike.event.duplicate.reason.view.search</field>
        <field name="model">ike.event.duplicate.reason</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="disabled"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]"
                    invisible="context.get('hide_disabled_enabled_filters', 0) == 1" />
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]"
                    invisible="context.get('hide_disabled_enabled_filters', 0) == 1" />
            </search>
        </field>
    </record>

    <record id="ike_event_duplicate_reason_action" model="ir.actions.act_window">
        <field name="name">Duplicate reason</field>
        <field name="res_model">ike.event.duplicate.reason</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_filter_enabled':1}</field>
    </record>

</odoo>
