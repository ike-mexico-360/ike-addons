<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View ike.service.input.vial search -->
    <record id="view_ike_service_input_vial_search" model="ir.ui.view">
        <field name="name">view.ike.service.input.vial.search</field>
        <field name="model">ike.service.input.vial</field>
        <field name="arch" type="xml">
            <search>
                <field name="event_id"/>
            </search>
        </field>
    </record>

    <!-- View ike.service.input.vial View List -->
    <record id="view_ike_service_input_vial_list" model="ir.ui.view">
        <field name="name">view.ike.service.input.vial.list</field>
        <field name="model">ike.service.input.vial</field>
        <field name="arch" type="xml">
            <list edit="0">
                <field name="name"/>
                <field name="event_id"/>
            </list>
        </field>
    </record>

    <record id="view_ike_service_input_vial_form" model="ir.ui.view">
        <field name="name">view.ike.service.input.vial.form</field>
        <field name="model">ike.service.input.vial</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Service Input Vial">
                <header>
                </header>
                <sheet class="ike_sheet">
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Name..."/>
                        </h1>
                    </div>
                    <group invisible="0">
                        <field name="name"/>
                        <field name="step_number"/>
                    </group>
                    <group name="step_2">
                        <group string="Vehicle ID" name="vehicle_image" class="ike-group">
                            <field name="identification_type" widget="radio" options="{'horizontal': 1}"/>
                            <field name="vehicle_plate_image" widget="image" nolabel="1" colspan="2"/>
                            <button name="action_identification_whatsapp" string="Send Link by Whatsapp"
                                    type="object" class="btn-whatsapp" icon="fa-whatsapp"
                                    invisible="identification_type != 'link'"/>
                        </group>
                        <group string="Vehicle Data" name="vehicle_data">
                            <field name="vehicle_brand"/>
                            <field name="vehicle_model"/>
                            <field name="vehicle_year"/>
                            <field name="vehicle_category_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="vehicle_plate"/>
                            <field name="vehicle_color"/>
                        </group>
                    </group>
                    <group string="Service Location" name="data_location">
                        <group>
                            <widget name="google_map_widget"
                                    latitude="location_latitude"
                                    longitude="location_longitude"
                                    location_label="location_label"
                                    country="country_id"
                                    state="state_id"
                                    municipality="municipality"
                                    street="street"
                                    street_number="street_number"
                                    city="city"
                                    colony="colony"
                                    zip_code="location_zip_code"/>
                        </group>
                        <group>
                            <div class="row">
                                <div class="col-auto d-flex">
                                    <field name="location_latitude" nolabel="1"/>
                                </div>
                                <div class="col-auto d-flex">
                                    <field name="location_longitude" nolabel="1"/>
                                </div>
                            </div>
                            <field name="location_label" />
                            <field name="street" />
                            <field name="street_number" />
                            <field name="colony" />
                            <field name="city" />
                            <field name="municipality_id" />
                            <field name="state_id" options="{'no_open': True, 'no_create': True}" />
                            <field name="country_id" options="{'no_open': True, 'no_create': True}" />
                            <field name="location_zip_code" />
                            <field name="street2" />
                            <field name="requires_federal_plates"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Service Input Screen -->
    <record id="view_ike_service_input_vial_screen_form" model="ir.ui.view">
        <field name="name">view.ike.service.input.vial.screen.form</field>
        <field name="model">ike.service.input.vial</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form string="Service Input Vial" js_class="ike_service_input_screen_form">
                <sheet class="ike-sheet">
                    <group invisible="1">
                        <field name="name"/>
                        <field name="stage_ref"/>
                        <field name="step_number"/>
                        <field name="sections"/>
                    </group>
                    <group name="user_service_data" invisible="not sections.get('user_service_data', False)">
                        <group string="Vehicle ID" name="vehicle_image" class="ike-group">
                            <field name="identification_type" widget="radio" options="{'horizontal': 1}" invisible="1"/>
                            <div class="o_row" colspan="2" invisible="identification_type in ['manual', 'manual_manual']">
                                <button name="action_identification_link" string="Identification Link"
                                        type="object" class="btn-primary" icon="fa-picture-o"/>
                                <button name="action_identification_manual" string="Identification Manual"
                                        type="object" class="btn-outline-primary" icon="fa-pencil"/>
                            </div>
                            <div class="o_row" colspan="2" invisible="identification_type == 'link'">
                                <button name="action_identification_link" string="Identification Link"
                                        type="object" class="btn-outline-primary" icon="fa-picture-o"/>
                                <button name="action_identification_manual" string="Identification Manual"
                                        type="object" class="btn-primary" icon="fa-pencil"/>
                            </div>
                            <field name="vehicle_plate_image" widget="image" nolabel="1" colspan="2"/>
                            <button name="action_identification_whatsapp" string="Send Link by Whatsapp"
                                    type="object" class="btn-whatsapp" icon="fa-whatsapp"
                                    invisible="identification_type != 'link'"/>
                        </group>
                        <group string="Vehicle Data" name="vehicle_data" class="ike-group" col="12">
                            <!-- <field name="service_date"/> -->
                            <group colspan="6">
                                <field name="vehicle_brand"
                                   widget="ike_char" required="identification_type in ['manual', 'manual_manual']" nolabel="1" colspan="2" readonly="identification_type == 'link'"/>
                                <field name="vehicle_year"
                                   widget="ike_char" required="identification_type in ['manual', 'manual_manual']" nolabel="1" colspan="2" readonly="identification_type == 'link'" options="{'regex': '^[0-9]{1,4}$'}"/>
                                <field name="vehicle_color"
                                   widget="ike_char" required="identification_type in ['manual', 'manual_manual']" nolabel="1" colspan="2" readonly="identification_type == 'link'"/>
                            </group>
                            <group colspan="6">
                                <field name="vehicle_model"
                                   widget="ike_char" required="identification_type in ['manual', 'manual_manual']" nolabel="1" colspan="2" readonly="identification_type == 'link'"/>
                                <field name="vehicle_category_id"
                                    widget="ike_many2one" required="identification_type in ['manual', 'manual_manual']" nolabel="1" colspan="2" readonly="identification_type == 'link'"
                                    options="{'no_open': True, 'no_create': True}"
                                    context="{'list_view_ref': 'custom_master_catalog.custom_fleet_vehicle_model_category_view_list'}"/>
                                <field name="vehicle_plate"
                                   widget="ike_char" required="identification_type in ['manual', 'manual_manual']" nolabel="1" colspan="2" readonly="identification_type == 'link'"/>
                            </group>
							<separator/>
                            <group colspan="12">
                                <div class="d-flex justify-content-end gap-1" invisible="step_number != 2">
                                    <button string="Return" class="btn-secondary o_discard"
                                            special="cancel" data-hotkey="x" />
                                    <button string="Continue" class="btn-primary o_save"
                                            special="save" data-hotkey="s" />
                                </div>
                            </group>
                        </group>
                    </group>
                    <group string="Service Location" name="location_data" class="ike-group" invisible="not sections.get('location_data', False)">
                        <group>
                            <widget name="google_map_widget"
                                    latitude="location_latitude"
                                    longitude="location_longitude"
                                    location_label="location_label"
                                    country="country_id"
                                    state="state_id"
                                    municipality="municipality_id"
                                    street="street"
                                    street_number="street_number"
                                    city="city"
                                    colony="colony"
                                    zip_code="location_zip_code"
                                    options="{'show_on_load': False}"/>
                        </group>
                        <group>
                            <div class="o_row" colspan="2">
                                <field name="location_latitude" invisible="0" required="sections.get('location_data', False)"/>
                                <field name="location_longitude" invisible="0" required="sections.get('location_data', False)"/>
                            </div>
                            <field name="location_label" invisible="1"/>
                            <div class="o_address_format" colspan="2">
                                <div class="d-flex gap-2">
                                    <field name="street" widget="ike_char" required="sections.get('location_data', False)"/>
                                    <field name="street_number" widget="ike_char"/>
                                </div>
                                <div class="d-flex gap-2">
                                    <field name="city" widget="ike_char"/>
                                    <field name="colony" widget="ike_char" required="sections.get('location_data', False)"/>
                                </div>
                                <div class="d-flex gap-2">
                                    <field name="municipality_id" widget="ike_many2one" required="sections.get('location_data', False)"
                                        options="{'no_open': True, 'no_create': True, 'no_edit': True}"/>
                                    <field name="state_id" widget="ike_many2one"  context="{'edit': False}"
                                        options="{'no_open': True, 'no_create': True, 'no_edit': True}" required="sections.get('location_data', False)"/>
                                </div>
                                <div class="d-flex gap-2">
                                    <field name="country_id" widget="ike_many2one"  context="{'edit': False}"
                                           options="{'no_open': True, 'no_create': True}" required="sections.get('location_data', False)"/>
                                    <field name="location_zip_code" widget="ike_char" required="sections.get('location_data', False)"/>
                                </div>
                                <field name="street2" widget="ike_char" nolabel="1" />
                                <field name="street_ref" widget="ike_char" nolabel="1"/>
                                <div class="d-flex flex-column" style="gap: 8px; width: fit-content;">
                                    <div>
                                        <field name="event_type_id"
                                            widget="ike_radio"
                                            options="{'horizontal': 1}"
                                            nolabel="1"/>
                                    </div>
                                    <div>
                                        <field name="requires_federal_plates"
                                            widget="ike_checkbox_radio"
                                            nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-end gap-1">
                                <button string="Return" class="btn-secondary o_discard"
                                        special="cancel" data-hotkey="x" />
                                <button string="Continue" class="btn-primary o_save"
                                        special="save" data-hotkey="s" />
                            </div>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action ike.service.input.vial -->
    <record id="action_ike_service_input_vial" model="ir.actions.act_window">
        <field name="name">Service Input Vial</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">ike.service.input.vial</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
                    (0, 0, {'view_mode': 'list', 'view_id': ref('view_ike_service_input_vial_list')}),
                    (0, 0, {'view_mode': 'form', 'view_id': ref('view_ike_service_input_vial_form')})]" />
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

</odoo>
