<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ike_survey_user_input_view_list" model="ir.ui.view">
        <field name="name">ike.survey.user_input.view.list</field>
        <field name="model">survey.user_input</field>
        <field name="arch" type="xml">
            <list create="0" delete="0">
                <field name="event_id"/>
                <field name="survey_id"/>
            </list>
        </field>
    </record>

    <record id="ike_survey_user_input_view_form" model="ir.ui.view">
        <field name="name">ike.survey.user_input.view.form</field>
        <field name="model">survey.user_input</field>
        <field name="inherit_id" ref="survey.survey_user_input_view_form"/>
        <field name="mode">primary</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <field name="survey_id" position="before">
                <field name="event_id"/>
            </field>
            <field name="user_input_line_ids" position="attributes">
                <attribute name="readonly">0</attribute>
            </field>
        </field>
    </record>

    <record id="ike_survey_user_input_view_screen_form" model="ir.ui.view">
        <field name="name">ike.survey.user_input.view.screen.form</field>
        <field name="model">survey.user_input</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form string="Survey Input" create="false" js_class="ike_survey_input_screen_form">
                <sheet class="ike-sheet">
                    <group invisible="1">
                        <group>
                            <field name="survey_id"/>
                            <field name="event_id"/>
                        </group>
                        <group>
                        </group>
                    </group>
                    <notebook invisible="context.get('ike_event_screen', False)">
                        <page string="Answers" name="page_answers">
                            <field name="user_input_line_ids" mode="list" no_label="1">
                                <list decoration-muted="skipped == True">
                                    <field name="user_input_id" column_invisible="1"/>
                                    <field name="question_sequence" column_invisible="1"/>
                                    <field name="create_date" optional="hidden"/>
                                    <field name="page_id" optional="hidden"/>
                                    <field name="question_id" options="{'no_create': 1}"/>
                                    <field name="answer_type"/>
                                    <field name="skipped" optional="show"/>
                                    <field name="display_name" string="Answer"/>
                                    <field name="suggested_answer_id" optional="hidden"/>
                                    <field name="value_char_box" optional="hidden"/>
                                    <field name="value_numerical_box" optional="hidden"/>
                                    <field name="value_date" optional="hidden"/>
                                    <field name="value_datetime" optional="hidden"/>
                                    <field name="value_text_box" optional="hidden"/>
                                </list>
                                <form create="false">
                                    <sheet>
                                        <group col="4">
                                            <field name="question_id" options="{'no_create': 1}"/>
                                            <field name="create_date"/>
                                            <field name="answer_type"/>
                                            <field name="skipped" />
                                            <field name="answer_score" groups="base.group_no_one"/>
                                        </group>
                                        <group>
                                            <field name="value_char_box" colspan='2' invisible="answer_type != 'char_box'"/>
                                            <field name="value_numerical_box" colspan='2' invisible="answer_type != 'numerical_box'"/>
                                            <field name="value_date" colspan='2' invisible="answer_type != 'date'"/>
                                            <field name="value_datetime" colspan='2' invisible="answer_type != 'datetime'"/>
                                            <field name="value_text_box" colspan='2' invisible="answer_type != 'text_box'"/>
                                            <field name="matrix_row_id" colspan='2' invisible="1"/>
                                            <field name="suggested_answer_id" colspan='2' invisible="answer_type != 'suggestion'"
                                                   domain="[('question_id', '=', question_id)]"
                                                   options="{'no_create': 1}"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ike_survey_user_input" model="ir.actions.act_window">
        <field name="name">Survey Input</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">survey.user_input</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
                    (0, 0, {'view_mode': 'list', 'view_id': ref('ike_event.ike_survey_user_input_view_list')}),
                    (0, 0, {'view_mode': 'form', 'view_id': ref('ike_event.ike_survey_user_input_view_form')})]" />
        <field name="domain">[('event_id', '!=', False)]</field>
        <field name="context">{}</field>
    </record>

    <record id="action_ike_survey_user_input_screen" model="ir.actions.act_window">
        <field name="name">Survey Input Screen</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">survey.user_input</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
                    (0, 0, {'view_mode': 'list', 'view_id': ref('ike_event.ike_survey_user_input_view_list')}),
                    (0, 0, {'view_mode': 'form', 'view_id': ref('ike_event.ike_survey_user_input_view_screen_form')})]" />
        <field name="domain">[('event_id', '!=', False)]</field>
        <field name="context">{}</field>
    </record>
</odoo>