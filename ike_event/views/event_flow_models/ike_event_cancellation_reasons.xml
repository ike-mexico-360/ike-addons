<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ike_event_cancellation_reason_view_list" model="ir.ui.view">
        <field name="name">ike.event.cancellation.reasons.view.list</field>
        <field name="model">ike.event.cancellation.reason</field>
        <field name="arch" type="xml">
            <list delete="0" edit="0" duplicate="0">
                <field name="sequence" widget="handle"/>
                <field name="name" />
                <field name="show_supplier" />
            </list>
        </field>
    </record>

    <record id="ike_event_cancellation_reason_view_form" model="ir.ui.view">
        <field name="name">ike.event.cancellation.view.form</field>
        <field name="model">ike.event.cancellation.reason</field>
        <field name="arch" type="xml">
            <form delete="0" duplicate="0">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active" />
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary"
                        invisible="not disabled or not active" />
                    <group>
                        <header>
                            <h1>
                                <label for="name" class="o_form_label_required"/>
                                <field name="name" readonly="disabled" required="1"/>
                            </h1>
                        </header>
                        
                        <field name="show_supplier" readonly="disabled"/>
                    </group>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="ike_event_cancellation_reason_view_search" model="ir.ui.view">
        <field name="name">ike.event.cancellation.reasons.view.search</field>
        <field name="model">ike.event.cancellation.reason</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="disabled" />
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]"
                    invisible="context.get('hide_disabled_enabled_filters', 0) == 1" />
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]"
                    invisible="context.get('hide_disabled_enabled_filters', 0) == 1" />
            </search>
        </field>
    </record>

    <record id="ike_event_cancellation_reason_action" model="ir.actions.act_window">
        <field name="name">Cancellation reasons</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">ike.event.cancellation.reason</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_enabled':1}</field>
    </record>

</odoo>
