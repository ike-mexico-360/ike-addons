<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View ike.event.flow View List -->
    <record id="view_ike_event_flow_list" model="ir.ui.view">
        <field name="name">view.ike.event.flow.list</field>
        <field name="model">ike.event.flow</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="stage_id"/>
                <field name="step_number"/>
            </list>
        </field>
    </record>

    <!-- View ike.event.flow form -->
    <record id="view_ike_event_flow_form" model="ir.ui.view">
        <field name="name">view.ike.event.flow.form</field>
        <field name="model">ike.event.flow</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="stage_id" options="{'no_create': 1}"/>
                            <field name="step_number"/>
                        </group>
                        <group>
                            <field name="condition_domain" widget="domain" options="{'model': 'ike.event', 'in_dialog': True}"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="configuration_data" string="Configuration">
                            <field name="detail_ids" widget="one2many">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="detail_type"/>
                                    <field name="service_specific"/>
                                </list>
                            </field>
                        </page>
                        <pane name="note" string="Note">
                            <field name="note"/>
                        </pane>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View ike.event.flow search -->
    <record id="view_ike_event_flow_search" model="ir.ui.view">
        <field name="name">view.ike.event.flow.search</field>
        <field name="model">ike.event.flow</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="stage_id"/>
                <field name="step_number"/>
                <group expand="1" string="Group By">
                    <filter string="Stage" name='user' context="{'group_by': 'stage_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action ike.event.flow -->
    <record id="action_ike_event_flow" model="ir.actions.act_window">
        <field name="name">Event Flow</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">ike.event.flow</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

</odoo>
