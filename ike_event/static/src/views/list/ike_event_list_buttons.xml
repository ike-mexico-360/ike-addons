<?xml version="1.0" encoding="UTF-8"?>
<templates>

    <t t-name="ike_event.IkeEventListButtons">
        <div class="o_purchase_dashboard container-fluid py-4 border-bottom bg-view" t-if="state.showIkeListButtons">
            <div class="overflow-auto">
                <div class="grid text-nowrap gap-1" style="min-width: 1200px;">
                    <div class="g-col-1">
                        <div class="text-capitalize text-break fw-normal">
                            All Events
                        </div>
                        <div class="mt-5 text-capitalize text-break fw-normal">
                            My Events
                        </div>
                    </div>
                    <div class="g-col-1">
                        <div class="p-0" t-on-click="setSearchContext" title="All Active Events" filter_name="all_active">
                            <a href="#" class="btn btn-primary w-100 h-100 border-0 rounded-0 text-capitalize text-break fw-normal">
                                <div class="fs-2" t-out="eventData['all_active_events']"/>Active
                            </a>
                        </div>
                        <div class="p-0 mt-2" t-on-click="setSearchContext" title="My Active Events"  filter_name="all_active,my_events">
                            <a href="#" class="btn btn-light w-100 border-0 fw-normal">
                                <div t-out="eventData['my_active_events']"/>
                            </a>
                        </div>
                    </div>
                    <div class="g-col-1">
                        <div class="p-0" t-on-click="setSearchContext" title="All Draft Events" filter_name="all_draft">
                            <a href="#" class="btn btn-primary w-100 h-100 border-0 rounded-0 text-capitalize text-break fw-normal">
                                <div class="fs-2" t-out="eventData['all_draft_events']"/>Draft
                            </a>
                        </div>
                        <div class="p-0 mt-2" t-on-click="setSearchContext" title="My Draft Events" filter_name="all_draft,my_events">
                            <a href="#" class="btn btn-light w-100 border-0 fw-normal">
                                <div t-out="eventData['my_draft_events']"/>
                            </a>
                        </div>
                    </div>
                    <div class="g-col-1">
