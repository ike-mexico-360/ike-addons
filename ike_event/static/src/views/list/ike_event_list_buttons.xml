                            <a href="#" class="btn btn-primary w-100 h-100 border-0 rounded-0 text-capitalize text-break fw-normal">
                                <div class="fs-2" t-out="eventData['all_capturing_events']"/>Capturing
                            </a>
                        </div>
                        <div class="p-0 mt-2" t-on-click="setSearchContext" title="My Capturing Events" filter_name="all_capturing,my_events">
                            <a href="#" class="btn btn-light w-100 border-0 fw-normal">
                                <div t-out="eventData['my_capturing_events']"/>
