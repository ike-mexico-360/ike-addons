                            </div>
                            <div class="o_inner_group grid col-lg-6">
                                <div class="o_wrap_field d-flex d-sm-contents flex-column mb-3 mb-sm-0">
                                    <div class="o_cell">
                                        <div class="d-flex justify-content-end gap-1">
                                            <button type="button" class="btn btn-secondary" t-on-click="() => this.actionBackward(true)">
                                                Return
                                            </button>
                                            <button type="button" class="btn btn-primary" t-on-click="() => this.actionForward(true)">
                                                Continue
                                            </button>
                                        </div>
                                    </div>
                                </div>
