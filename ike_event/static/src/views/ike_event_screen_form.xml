                <t t-if="state.sections['survey_data']">
                    <View t-props="state.subServiceSurveyInputViewProps" t-if="state.subServiceSurveyInputAux"/>
                    <View t-props="state.subServiceSurveyInputViewProps" t-else=""/>
                </t>
