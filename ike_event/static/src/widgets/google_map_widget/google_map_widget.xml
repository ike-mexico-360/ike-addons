<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="ike_event.GoogleMapWidget">
        <div>
            <div t-ref="place-autocomplete-card" class="place-autocomplete-card w-100 mb-1" t-att-class="{'d-none': props.readonly}" />
            <div t-ref="mapContainer" style="width:100%;" t-att-style="'height: ' + props.size + ';' " t-att-class="{'align-content-center': !state.mapLoaded}">
                <div t-if="!state.mapLoaded" class="d-flex justify-content-center">
                    <t t-if="state.loadingMap">
                        <div class="d-flex justify-content-center">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </t>
                    <t t-else="">
                        <button class="btn btn-primary" t-on-click="loadMap">
                            Load Map
                        </button>
                    </t>
                </div>
            </div>
        </div>
    </t>

</templates>