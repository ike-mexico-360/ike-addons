<templates xml:space="preserve">

    <t t-name="ike_event.postfixField">
        <t t-if="props.readonly">
            <span t-esc="formattedValue"/>
        </t>
        <t t-else="">
            <div class="o_input d-inline-flex align-items-center">
                <input
                    t-ref="numpadDecimal"
                    class="o_input text-start pe-1"
                    t-att-placeholder="props.placeholder"
                    type="text"
                    inputmode="numeric"
                    autocomplete="off"
                    style="width: 80px;"
                />
                <span class="text-muted" t-esc="postfixText"/>
            </div>
        </t>
    </t>

</templates>