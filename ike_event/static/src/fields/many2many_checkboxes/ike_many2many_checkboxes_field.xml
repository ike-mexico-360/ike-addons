<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ike_event.IkeMany2ManyCheckboxesField">
        <div class="d-flex flex-row flex-wrap gap-3">
            <t t-foreach="items" t-as="item" t-key="item[0]">
                <label class="d-flex flex-row gap-2 align-items-center justify-content-between text-nowrap">
                    <t t-if="props.icons and props.icons.length">
                        <i class="fa fa-light fa-lg" t-att-class="props.icons[item_index % props.icons.length]"/>
                    </t>
                    <span t-out="item[1]"/>
                    <div class="d-flex">
                        <input
                            type="checkbox"
                            t-att-name="id"
                            t-att-value="item[0]"
                            t-att-checked="isSelected(item)"
                            t-att-disabled="props.readonly"
                            t-att-id="`${id}_${item[0]}`"
                            t-on-change="(ev) => this.onChange(item[0], ev)"
                        />
                    </div>
                </label>
            </t>
        </div>
    </t>
</templates>
