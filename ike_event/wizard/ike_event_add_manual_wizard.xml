<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ike_add_manual_supplier_wizard_form" model="ir.ui.view">
        <field name="name">ike.add.manual.supplier.wizard.form</field>
        <field name="model">ike.event.manual.supplier.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Supplier">
                <group>
                    <field name="event_id" invisible="1"/>
                    <field name="truck_domain" invisible="1"/>
                    <field name="supplier_id" options="{'no_create': True}" context="{'edit': False}"/>
                    <field name="supplier_phone"/>
                    <field name="truck_id"
                        options="{'no_create': True}"
                        context="{'edit': False}"
                        domain="truck_domain" />
                </group>

                <footer>
                    <button name="action_confirm"
                            string="save"
                            type="object"
                            class="btn-primary"/>

                    <button string="Return"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>


    <record id="ike_add_manual_supplier_wizard_action" model="ir.actions.act_window">
        <field name="name">Add Supplier</field>
        <field name="res_model">ike.event.manual.supplier.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">
            {'active_id': active_id}
        </field>
    </record>
</odoo>
