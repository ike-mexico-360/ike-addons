<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_custom_membership_plan_form_inherit_ike_event_api" model="ir.ui.view">
        <field name="name">view_custom_membership_plan_form_inherit_ike_event_api</field>
        <field name="model">custom.membership.plan</field>
        <field name="inherit_id" ref="custom_nu.view_custom_membership_plan_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='product_line_ids']" position="after">
                <page name="technical_configuration" string="Technical configuration" groups="base.group_no_one">
                    <group>
                        <field name="x_event_totalizer_endpoint_url" readonly="disabled"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
