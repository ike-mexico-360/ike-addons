<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View ike.event.binnacle.category View List -->
    <record id="view_ike_event_binnacle_category_list" model="ir.ui.view">
        <field name="name">view.ike.event.binnacle.category.list</field>
        <field name="model">ike.event.binnacle.category</field>
        <field name="arch" type="xml">
            <list delete="0" edit="0" duplicate="0">
                <field name="name"/>
                <field name="parent_id"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- View ike.event.binnacle.category form -->
    <record id="view_ike_event_binnacle_category_form" model="ir.ui.view">
        <field name="name">view.ike.event.binnacle.category.form</field>
        <field name="model">ike.event.binnacle.category</field>
        <field name="arch" type="xml">
            <form delete="0" duplicate="0">
               <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <div class="oe_title">
                        <label for="name" class="o_form_label_required"/>
                        <h1>
                            <field name="name" placeholder="Name..." readonly="disabled"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="parent_id" domain="[('disabled', '=', False)]" readonly="disabled"/>
                        </group>
                        <group>
                            <field name="disabled" invisible="1"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- View ike.event.binnacle.category search -->
    <record id="view_ike_event_binnacle_category_search" model="ir.ui.view">
        <field name="name">view.ike.event.binnacle.category.search</field>
        <field name="model">ike.event.binnacle.category</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <group expand="1" string="Group By">
                    <filter string="Name" name="name" domain="[]" context="{'group_by':'name'}"/>
                    <filter string="Parent" name="parent" domain="[]" context="{'group_by':'parent_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action ike.event.binnacle.category -->
    <record id="action_ike_event_binnacle_category" model="ir.actions.act_window">
        <field name="name">Ike Event Binnacle Category</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">ike.event.binnacle.category</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('view_ike_event_binnacle_category_list')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('view_ike_event_binnacle_category_form')})]"/>
        <field name="domain">[]</field>
        <field name="context">{'search_default_filter_enabled': 1,}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                There is no examples click here to add new Ike Event Binnacle Category.
            </p>
        </field>
    </record>

</odoo>
