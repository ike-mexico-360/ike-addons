<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ike_event_comment_wizard_form" model="ir.ui.view">
        <field name="name">ike.event.comment.wizard.form</field>
        <field name="model">ike.event.comment.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Comment">
                <sheet>
                    <group>
                        <field name="body"
                            placeholder="Write your comment here..."
                            widget="text"
                            nolabel="1"/>
                        <field name="is_supplier"/>
                        <field name="x_supplier_message_binnacle_domain" invisible="1"/>
                        <field name="x_supplier_message_id" 
                            domain="x_supplier_message_binnacle_domain"
                            options="{'no_open': True, 'no_create': True, 'no_edit': True}"
                            context="{'edit': False}"
                            readonly="count_supplier == 1"
                            force_save="1"
                            invisible="not is_supplier"/>
                        <field name="event_id" invisible="1"/>
                        <field name="event_binnacle_id" invisible="1"/>
                        
                    </group>
                </sheet>
                <footer>
                    <button
                        name="action_save_confirm"
                        type="object"
                        string="Save Comment"
                        class="btn-primary"
                        icon="fa-check"/>
                    <button
                        string="Cancel"
                        special="cancel"
                        class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
