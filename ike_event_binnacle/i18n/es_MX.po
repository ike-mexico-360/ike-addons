#. module: ike_event_binnacle
#: model:mail.template,body_html:ike_event_binnacle.ike_binnacle_stage_mail_template_4_4
msgid ""
"<t>\n"
"                    <strong>Has beed added:</strong>\n"
"\n"
"                    <t t-set=\"lines\" t-value=\"object.service_product_ids\"/>\n"
"\n"
"                    <t t-if=\"lines\">\n"
"                        <t t-set=\"printed\" t-value=\"0\"/>\n"
"\n"
"                        <t t-foreach=\"lines\" t-as=\"line\">\n"
"                            <t t-if=\"not line.display_type and not line.covered\">\n"
"                                <t t-if=\"printed &gt; 0\"> | </t>\n"
"\n"
"                                <t t-out=\"line.product_id.name or line.name\"/>\n"
"\n"
"                                <t t-set=\"printed\" t-value=\"printed + 1\"/>\n"
"                            </t>\n"
"                        </t>\n"
"\n"
"                        <t t-if=\"printed &gt; 0\">.</t>\n"
"                        <t t-else=\"\">\n"
"                            <em>No out-of-coverage concepts.</em>\n"
"                        </t>\n"
"                    </t>\n"
"                </t>\n"
"            "
msgstr ""
"<t>\n"
"                    <strong>Conceptos agregados:</strong>\n"
"\n"
"                    <t t-set=\"lines\" t-value=\"object.service_product_ids\"/>\n"
"\n"
"                    <t t-if=\"lines\">\n"
"                        <t t-set=\"printed\" t-value=\"0\"/>\n"
"\n"
"                        <t t-foreach=\"lines\" t-as=\"line\">\n"
"                            <!-- Ignorar secciones/notas -->\n"
"                            <t t-if=\"not line.display_type and not line.covered\">\n"
"                                <!-- Separador -->\n"
"                                <t t-if=\"printed &gt; 0\"> | </t>\n"
"\n"
"                                <!-- Nombre del concepto -->\n"
"                                <t t-out=\"line.product_id.name or line.name\"/>\n"
"\n"
"                                <!-- Contador -->\n"
"                                <t t-set=\"printed\" t-value=\"printed + 1\"/>\n"
"                            </t>\n"
"                        </t>\n"
"\n"
"                        <!-- Punto final solo si hubo resultados -->\n"
"                        <t t-if=\"printed &gt; 0\">.</t>\n"
"                        <t t-else=\"\">\n"
"                            <em>No hay conceptos fuera de cobertura.</em>\n"
"                        </t>\n"
"                    </t>\n"
"                </t>\n"
"            "

