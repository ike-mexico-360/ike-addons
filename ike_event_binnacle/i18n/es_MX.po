#. module: ike_event_binnacle
#: model:mail.template,body_html:ike_event_binnacle.ike_binnacle_stage_mail_template_4_2
msgid ""
"<div>\n"
"                    <!-- Guardamos el subservicio en una variable -->\n"
"                    <t t-if=\"object.sub_service_res_model and object.sub_service_res_id\">\n"
"                        <t t-set=\"sub_service\" t-value=\"object.env[object.sub_service_res_model].browse(object.sub_service_res_id)\"/>\n"
"\n"
"                        <t t-if=\"sub_service.exists() and sub_service.service_vehicle_type_ids\">\n"
"                            <strong>Vehicle selected:</strong>\n"
"                            <ul>\n"
"                                <t t-foreach=\"sub_service.service_vehicle_type_ids\" t-as=\"vehicle\">\n"
"                                    <li>\n"
"                                        <span t-out=\"vehicle.display_name\"/>\n"
"                                    </li>\n"
"                                </t>\n"
"                            </ul>\n"
"                        </t>\n"
"\n"
"                        <t t-else=\"\">\n"
"                            <em>No vehicle selected.</em>\n"
"                        </t>\n"
"                    </t>\n"
"\n"
"                    <t t-else=\"\">\n"
"                        <em>No vehicle selected.</em>\n"
"                    </t>\n"
"                </div>\n"
"            "
msgstr ""
"<div>\n"
"                    <!-- Guardamos el subservicio en una variable -->\n"
"                    <t t-if=\"object.sub_service_res_model and object.sub_service_res_id\">\n"
"                        <t t-set=\"sub_service\" t-value=\"object.env[object.sub_service_res_model].browse(object.sub_service_res_id)\"/>\n"
"\n"
"                        <t t-if=\"sub_service.exists() and sub_service.service_vehicle_type_ids\">\n"
"                            <strong>Vehículo seleccionado:</strong>\n"
"                            <ul>\n"
"                                <t t-foreach=\"sub_service.service_vehicle_type_ids\" t-as=\"vehicle\">\n"
"                                    <li>\n"
"                                        <span t-out=\"vehicle.display_name\"/>\n"
"                                    </li>\n"
"                                </t>\n"
"                            </ul>\n"
"                        </t>\n"
"\n"
"                        <t t-else=\"\">\n"
"                            <em>No hay vehículo seleccionado.</em>\n"
"                        </t>\n"
"                    </t>\n"
"\n"
"                    <t t-else=\"\">\n"
"                        <em>No hay vehículo seleccionado.</em>\n"
"                    </t>\n"
"                </div>\n"
"            "

#. module: ike_event_binnacle
#: model:mail.template,body_html:ike_event_binnacle.ike_binnacle_stage_mail_template_7_5
msgid ""
"<span><t t-set=\"link\" t-value=\"object.service_supplier_link_ids.filtered(lambda l: l.id == ctx.get('supplier_link_id'))[:1]\"/>\n"
"\n"
"                <t t-if=\"link\">\n"
"                <t t-set=\"link\" t-value=\"link[0]\"/>\n"
"\n"
"                    <!-- CONCEPTS ADDITIONALS -->\n"
"                    <strong>Concepts additionals:</strong>\n"
"\n"
"                    <t t-set=\"new_ids\" t-value=\"link.new_concept_ids or []\"/>\n"
"\n"
"                    <t t-set=\"outside_lines\" t-value=\"link.supplier_product_ids.filtered(                             lambda l: not l.display_type and not l.covered and l.id in new_ids                         )\"/>\n"
"\n"
"                    <t t-if=\"outside_lines\">\n"
"                        <t t-foreach=\"outside_lines\" t-as=\"line\">\n"
"                            <br/>• <t t-out=\"line.product_id.display_name\"/>\n"
"                        </t>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <br/><em>No additional concepts.</em>\n"
"                    </t>\n"
"\n"
"                    <br/><br/>\n"
"\n"
"                    <!-- AUTHORIZATION TYPE -->\n"
"                    <strong>Authorization type:</strong>\n"
"\n"
"                    <t t-if=\"link.type_authorization_id\">\n"
"                        <t t-out=\"link.type_authorization_id.name\"/>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <em>No authorization type.</em>\n"
"                    </t>\n"
"\n"
"                    <br/><br/>\n"
"\n"
"                    <!-- RESPONSIBLE -->\n"
"                    <strong>Responsible authorizator:</strong>\n"
"\n"
"                    <t t-set=\"responsible_name\" t-value=\"link.nu_user_id.display_name if link.authorization_by_nu else link.authorizer_id.display_name\"/>\n"
"\n"
"                    <t t-if=\"responsible_name\">\n"
"                        <t t-out=\"responsible_name\"/>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <em>No responsible assigned.</em>\n"
"                    </t>\n"
"\n"
"                    <br/><br/>\n"
"\n"
"                    <!-- MOTIVE -->\n"
"                    <strong>Motive:</strong>\n"
"\n"
"                    <t t-if=\"link.reason_authorizer_id\">\n"
"                        <t t-out=\"link.reason_authorizer_id.name\"/>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <em>No motive assigned.</em>\n"
"                    </t>\n"
"\n"
"                </t>\n"
"\n"
"                <!-- Si por alguna raz&#243;n no llega el contexto -->\n"
"                <t t-else=\"\">\n"
"                    <em>No supplier information available.</em>\n"
"                </t>\n"
"\n"
"            </span>"
msgstr ""
"<span><t t-set=\"link\" t-value=\"object.service_supplier_link_ids.filtered(lambda l: l.id == ctx.get('supplier_link_id'))[:1]\"/>\n"
"\n"
"                <t t-if=\"link\">\n"
"                <t t-set=\"link\" t-value=\"link[0]\"/>\n"
"\n"
"                    <!-- CONCEPTS ADDITIONALS -->\n"
"                    <strong>Conceptos adicionales:</strong>\n"
"\n"
"                    <t t-set=\"new_ids\" t-value=\"link.new_concept_ids or []\"/>\n"
"\n"
"                    <t t-set=\"outside_lines\" t-value=\"link.supplier_product_ids.filtered(                             lambda l: not l.display_type and not l.covered and l.id in new_ids                         )\"/>\n"
"\n"
"                    <t t-if=\"outside_lines\">\n"
"                        <t t-foreach=\"outside_lines\" t-as=\"line\">\n"
"                            <br/>• <t t-out=\"line.product_id.display_name\"/>\n"
"                        </t>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <br/><em>No hay conceptos adicionales.</em>\n"
"                    </t>\n"
"\n"
"                    <br/><br/>\n"
"\n"
"                    <!-- AUTHORIZATION TYPE -->\n"
"                    <strong>Tipo de autorización:</strong>\n"
"\n"
"                    <t t-if=\"link.type_authorization_id\">\n"
"                        <t t-out=\"link.type_authorization_id.name\"/>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <em>No se asigno tipo de autorización.</em>\n"
"                    </t>\n"
"\n"
"                    <br/><br/>\n"
"\n"
"                    <!-- RESPONSIBLE -->\n"
"                    <strong>Autorizador responsable:</strong>\n"
"\n"
"                    <t t-set=\"responsible_name\" t-value=\"link.nu_user_id.display_name if link.authorization_by_nu else link.authorizer_id.display_name\"/>\n"
"\n"
"                    <t t-if=\"responsible_name\">\n"
"                        <t t-out=\"responsible_name\"/>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <em>No se asigno autorizador responsable.</em>\n"
"                    </t>\n"
"\n"
"                    <br/><br/>\n"
"\n"
"                    <!-- MOTIVE -->\n"
"                    <strong>Motivo:</strong>\n"
"\n"
"                    <t t-if=\"link.reason_authorizer_id\">\n"
"                        <t t-out=\"link.reason_authorizer_id.name\"/>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <em>No hay motivo.</em>\n"
"                    </t>\n"
"\n"
"                </t>\n"
"\n"
"                <!-- Si por alguna raz&#243;n no llega el contexto -->\n"
"                <t t-else=\"\">\n"
"                    <em>No hay informacion del proveedor.</em>\n"
"                </t>\n"
"\n"
"            </span>"

#. module: ike_event_binnacle
#: model:mail.template,body_html:ike_event_binnacle.ike_binnacle_stage_mail_template_5_6
msgid ""
"<strong>Search type:</strong>\n"
"                <t t-out=\"object._fields['supplier_search_type'].convert_to_export(object.supplier_search_type, object)\"/>\n"
"                <br/>\n"
"                <strong>Recommended supplier:</strong>\n"
"                <t t-set=\"last_search\" t-value=\"max(object.service_supplier_ids.mapped('search_number') or [0])\"/>\n"
"                <br/>\n"
"                <ol>\n"
"                    <t t-foreach=\"object.service_supplier_ids\" t-as=\"line\">\n"
"                        <t t-if=\"line.search_number == last_search and not line.display_type\">\n"
"                            <li>\n"
"                                <strong><t t-out=\"line.supplier_id.name\"/></strong><br/>\n"
"                                <t t-out=\"line.name\"/>\n"
"                            </li>\n"
"                        </t>\n"
"                    </t>\n"
"                </ol>\n"
"            "
msgstr ""
"<strong>Tipo de busqueda:</strong>\n"
"                <t t-out=\"object._fields['supplier_search_type'].convert_to_export(object.supplier_search_type, object)\"/>\n"
"                <br/>\n"
"                <strong>Proveedores recomendados:</strong>\n"
"                <t t-set=\"last_search\" t-value=\"max(object.service_supplier_ids.mapped('search_number') or [0])\"/>\n"
"                <br/>\n"
"                <ol>\n"
"                    <t t-foreach=\"object.service_supplier_ids\" t-as=\"line\">\n"
"                        <t t-if=\"line.search_number == last_search and not line.display_type\">\n"
"                            <li>\n"
"                                <strong><t t-out=\"line.supplier_id.name\"/></strong><br/>\n"
"                                <t t-out=\"line.name\"/>\n"
"                            </li>\n"
"                        </t>\n"
"                    </t>\n"
"                </ol>\n"
"            "

