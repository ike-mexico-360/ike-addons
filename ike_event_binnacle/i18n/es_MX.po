#. module: ike_event_binnacle
#: model:mail.template,body_html:ike_event_binnacle.ike_binnacle_stage_mail_template_7_3
msgid ""
"<t>\n"
"                    <!-- Obtener supplier desde contexto -->\n"
"                    <t t-set=\"current_supplier_id\" t-value=\"ctx.get('current_supplier_id')\"/>\n"
"\n"
"                    <!-- Buscar supplier -->\n"
"                    <t t-set=\"supplier\" t-value=\"current_supplier_id and object.service_supplier_ids.filtered(lambda s: s.id == current_supplier_id)[:1] or False\"/>\n"
"\n"
"                    <!-- Validar supplier -->\n"
"                    <t t-if=\"supplier and supplier[0]\">\n"
"                        <t t-set=\"supplier\" t-value=\"supplier[0]\"/>\n"
"\n"
"                        <div>\n"
"                            <strong>Supplier:</strong>\n"
"                            <t t-out=\"supplier.supplier_id.name\"/>\n"
"                        </div>\n"
"                        \n"
"                        <div t-if=\"supplier.truck_id and supplier.truck_id.license_plate\">\n"
"                            <strong>Plates:</strong>\n"
