#. module: ike_event_binnacle
#: model:mail.template,body_html:ike_event_binnacle.ike_binnacle_stage_mail_template_4_3
msgid ""
"<t>\n"
"                        <strong>Covered concepts:</strong>\n"
"\n"
"                        <t t-set=\"lines\" t-value=\"object.service_product_ids\"/>\n"
"\n"
"                        <t t-if=\"lines\">\n"
"                            <t t-set=\"printed\" t-value=\"0\"/>\n"
"\n"
"                            <t t-foreach=\"lines\" t-as=\"line\" t-index=\"i\">\n"
"                                <t t-if=\"not line.display_type and line.covered\">\n"
"                                    <t t-if=\"printed &gt; 0\"> | </t>\n"
"\n"
"                                    <t t-out=\"line.product_id.name or line.name\"/>\n"
"\n"
"                                    <t t-set=\"printed\" t-value=\"printed + 1\"/>\n"
"                                </t>\n"
"                            </t>\n"
"\n"
"                            <t t-if=\"printed &gt; 0\">.</t>\n"
"                            <t t-else=\"\">\n"
"                                <em>No covered concepts available.</em>\n"
"                            </t>\n"
"                        </t>\n"
"                    </t>\n"
"                "
msgstr ""
"<t>\n"
"                        <strong>Conceptos de cobertura:</strong>\n"
"\n"
"                        <t t-set=\"lines\" t-value=\"object.service_product_ids\"/>\n"
"\n"
"                        <t t-if=\"lines\">\n"
"                            <t t-set=\"printed\" t-value=\"0\"/>\n"
"\n"
"                            <t t-foreach=\"lines\" t-as=\"line\" t-index=\"i\">\n"
"                                <!-- Ignorar secciones/notas -->\n"
"                                <t t-if=\"not line.display_type and line.covered\">\n"
"                                    <!-- Separador -->\n"
"                                    <t t-if=\"printed &gt; 0\"> | </t>\n"
"\n"
"                                    <!-- Nombre del concepto -->\n"
"                                    <t t-out=\"line.product_id.name or line.name\"/>\n"
"\n"
"                                    <!-- Contador manual -->\n"
"                                    <t t-set=\"printed\" t-value=\"printed + 1\"/>\n"
"                                </t>\n"
"                            </t>\n"
"\n"
"                            <!-- Punto  solo si se imprimi&#243; algo -->\n"
"                            <t t-if=\"printed &gt; 0\">.</t>\n"
"                            <t t-else=\"\">\n"
"                                <em>No hay conceptos.</em>\n"
"                            </t>\n"
"                        </t>\n"
"                    </t>\n"
"                "

