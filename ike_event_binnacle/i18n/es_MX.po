#. module: ike_event_binnacle
#: model:mail.template,body_html:ike_event_binnacle.ike_binnacle_stage_mail_template_10_4
msgid ""
"<t>\n"
"                <p>\n"
"                    <strong>Agreement costs</strong><br/>\n"
"                    <t t-if=\"object.assigned_user_id\">\n"
"                        <strong>Concluded by: </strong>\n"
"                        <t t-out=\"object.assigned_user_id.name or 'N/A'\"/>\n"
"                    </t>\n"
"                </p>\n"
"\n"
"                <br/>\n"
"\n"
"                <t t-set=\"valid_suppliers\" t-value=\"object.selected_supplier_ids.filtered(                     lambda s: s.state not in ['cancel', 'cancel_supplier', 'cancel_event']                 )\"/>\n"
"\n"
"                <t t-set=\"all_lines\" t-value=\"env['ike.event.supplier.product'].search([                     ('event_id', '=', object.id),                     ('display_type', '=', False),                     ('parent_product_id', '=', False),                     ('event_supplier_link_id', 'in', valid_suppliers.mapped('supplier_link_id').ids)                 ])\"/>\n"
"\n"
"                <t t-set=\"unique_suppliers\" t-value=\"list(dict.fromkeys(all_lines.mapped('supplier_id')))\"/>\n"
"\n"
"                <table style=\"width:100%; border: 1px solid black; font-size:13px;\">\n"
"                    <thead style=\"background-color:#4a90e2; color:white;\">\n"
"                        <tr>\n"
"                            <th style=\"border:1px solid #000; padding:6px;\">Concept</th>\n"
"                            <th style=\"border:1px solid #000; padding:6px;\">Quantity</th>\n"
"                            <th style=\"border:1px solid #000; padding:6px;\">Unit Price</th>\n"
"                            <th style=\"border:1px solid #000; padding:6px;\">Cost</th>\n"
"                        </tr>\n"
"                    </thead>\n"
"                    <tbody>\n"
"\n"
"                        <t t-foreach=\"unique_suppliers\" t-as=\"supp\">\n"
"                            <t t-set=\"supplier_lines\" t-value=\"all_lines.filtered(lambda l: l.supplier_id.id == supp.id)\"/>\n"
"\n"
"                            <tr style=\"background-color:#d9e8fb;\">\n"
"                                <td colspan=\"4\" style=\"border:1px solid #000; padding:6px; font-weight:bold;\">\n"
"                                    <t t-out=\"supp.name\"/>\n"
"                                </td>\n"
"                            </tr>\n"
"\n"
"                            <t t-foreach=\"supplier_lines\" t-as=\"sl\">\n"
"                                <tr>\n"
"                                    <td style=\"border:1px solid #000; padding:6px;\">\n"
"                                        <t t-out=\"sl.product_id.display_name\"/>\n"
"                                    </td>\n"
"                                    <td style=\"border:1px solid #000; padding:6px;\">\n"
"                                        <t t-out=\"sl.quantity\"/>\n"
"                                    </td>\n"
"                                    <td style=\"border:1px solid #000; padding:6px;\">\n"
"                                        <t t-out=\"'${:,.2f}'.format(sl.unit_price)\"/>\n"
"                                    </td>\n"
"                                    <td style=\"border:1px solid #000; padding:6px;\">\n"
"                                        <t t-out=\"'${:,.2f}'.format(sl.cost_price)\"/>\n"
"                                    </td>\n"
"                                </tr>\n"
"                            </t>\n"
"\n"
"                            <tr style=\"font-weight:bold; background-color:#f5f5f5;\">\n"
"                                <td colspan=\"3\" style=\"border:1px solid #000; padding:6px; text-align:right;\">\n"
"                                    Subtotal <t t-out=\"supp.name\"/>\n"
"                                </td>\n"
"                                <td style=\"border:1px solid #000; padding:6px;\">\n"
"                                    <t t-out=\"'${:,.2f}'.format(sum(supplier_lines.mapped('cost_price')))\"/>\n"
"                                </td>\n"
"                            </tr>\n"
"\n"
"                        </t>\n"
"\n"
"                        <tr style=\"font-weight:bold; background-color:#4a90e2; color:white;\">\n"
"                            <td colspan=\"3\" style=\"border:1px solid #000; padding:6px; text-align:right;\">\n"
"                                TOTAL\n"
"                            </td>\n"
"                            <td style=\"border:1px solid #000; padding:6px;\">\n"
"                                <t t-out=\"'${:,.2f}'.format(sum(all_lines.mapped('cost_price')))\"/>\n"
"                            </td>\n"
"                        </tr>\n"
"\n"
"                    </tbody>\n"
"                </table>\n"
"            </t>\n"
"            "
msgstr ""
"<t>\n"
"                <p>\n"
"                    <strong>Costos convenio</strong><br/>\n"
"                    <t t-if=\"object.assigned_user_id\">\n"
"                        <strong>Concluido por: </strong>\n"
"                        <t t-out=\"object.assigned_user_id.name or 'N/A'\"/>\n"
"                    </t>\n"
"                </p>\n"
"\n"
"                <br/>\n"
"\n"
"                <t t-set=\"valid_suppliers\" t-value=\"object.selected_supplier_ids.filtered(                     lambda s: s.state not in ['cancel', 'cancel_supplier', 'cancel_event']                 )\"/>\n"
"\n"
"                <t t-set=\"all_lines\" t-value=\"env['ike.event.supplier.product'].search([                     ('event_id', '=', object.id),                     ('display_type', '=', False),                     ('parent_product_id', '=', False),                     ('event_supplier_link_id', 'in', valid_suppliers.mapped('supplier_link_id').ids)                 ])\"/>\n"
"\n"
"                <t t-set=\"unique_suppliers\" t-value=\"list(dict.fromkeys(all_lines.mapped('supplier_id')))\"/>\n"
"\n"
"                <table style=\"width:100%; border: 1px solid black; font-size:13px;\">\n"
"                    <thead style=\"background-color:#4a90e2; color:white;\">\n"
"                        <tr>\n"
"                            <th style=\"border:1px solid #000; padding:6px;\">Conceptos</th>\n"
"                            <th style=\"border:1px solid #000; padding:6px;\">Cantidad</th>\n"
"                            <th style=\"border:1px solid #000; padding:6px;\">Precio unitario</th>\n"
"                            <th style=\"border:1px solid #000; padding:6px;\">Costo</th>\n"
"                        </tr>\n"
"                    </thead>\n"
"                    <tbody>\n"
"\n"
"                        <t t-foreach=\"unique_suppliers\" t-as=\"supp\">\n"
"                            <t t-set=\"supplier_lines\" t-value=\"all_lines.filtered(lambda l: l.supplier_id.id == supp.id)\"/>\n"
"\n"
"                            <tr style=\"background-color:#d9e8fb;\">\n"
"                                <td colspan=\"4\" style=\"border:1px solid #000; padding:6px; font-weight:bold;\">\n"
"                                    <t t-out=\"supp.name\"/>\n"
"                                </td>\n"
"                            </tr>\n"
"\n"
"                            <t t-foreach=\"supplier_lines\" t-as=\"sl\">\n"
"                                <tr>\n"
"                                    <td style=\"border:1px solid #000; padding:6px;\">\n"
"                                        <t t-out=\"sl.product_id.display_name\"/>\n"
"                                    </td>\n"
"                                    <td style=\"border:1px solid #000; padding:6px;\">\n"
"                                        <t t-out=\"sl.quantity\"/>\n"
"                                    </td>\n"
"                                    <td style=\"border:1px solid #000; padding:6px;\">\n"
"                                        <t t-out=\"'${:,.2f}'.format(sl.unit_price)\"/>\n"
"                                    </td>\n"
"                                    <td style=\"border:1px solid #000; padding:6px;\">\n"
"                                        <t t-out=\"'${:,.2f}'.format(sl.cost_price)\"/>\n"
"                                    </td>\n"
"                                </tr>\n"
"                            </t>\n"
"\n"
"                            <tr style=\"font-weight:bold; background-color:#f5f5f5;\">\n"
"                                <td colspan=\"3\" style=\"border:1px solid #000; padding:6px; text-align:right;\">\n"
"                                    Subtotal <t t-out=\"supp.name\"/>\n"
"                                </td>\n"
"                                <td style=\"border:1px solid #000; padding:6px;\">\n"
"                                    <t t-out=\"'${:,.2f}'.format(sum(supplier_lines.mapped('cost_price')))\"/>\n"
"                                </td>\n"
"                            </tr>\n"
"\n"
"                        </t>\n"
"\n"
"                        <tr style=\"font-weight:bold; background-color:#4a90e2; color:white;\">\n"
"                            <td colspan=\"3\" style=\"border:1px solid #000; padding:6px; text-align:right;\">\n"
"                                TOTAL\n"
"                            </td>\n"
"                            <td style=\"border:1px solid #000; padding:6px;\">\n"
"                                <t t-out=\"'${:,.2f}'.format(sum(all_lines.mapped('cost_price')))\"/>\n"
"                            </td>\n"
"                        </tr>\n"
"\n"
"                    </tbody>\n"
"                </table>\n"
"            </t>\n"
"            "

