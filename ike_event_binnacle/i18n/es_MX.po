"\n"
"                    <t t-if=\"suppliers\">\n"
"                        <ul style=\"border-radius: 0px; border-style: none; padding: 0px 0px 0px 32px; margin: 0px 0px 16px; box-sizing: border-box; border-color: #4a5573; border-width: 0px; scrollbar-color: #ebebef #ffffff; scrollbar-width: thin; list-style-type: disc;\">\n"
"                            <t t-foreach=\"suppliers\" t-as=\"supplier\">\n"
