msgstr ""
"<div data-oe-version=\"1.2\" style=\"border-radius: 0px; border-style: none; padding: 0px; margin: 0px; box-sizing: border-box; border-color: #4a5573; border-width: 0px; scrollbar-color: #ebebef #ffffff; scrollbar-width: thin;\"><br/></div><div style=\"border-radius: 0px; border-style: none; padding: 0px; margin: 0px; box-sizing: border-box; border-color: #4a5573; border-width: 0px; scrollbar-color: #ebebef #ffffff; scrollbar-width: thin;\"><t>\n"
