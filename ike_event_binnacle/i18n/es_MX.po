#. module: ike_event_binnacle
#: model:mail.template,body_html:ike_event_binnacle.ike_binnacle_stage_mail_template_7_5
msgid ""
"<t t-set=\"link\" t-value=\"object.service_supplier_link_ids.filtered(lambda l: l.id == ctx.get('supplier_link_id'))[:1]\"/>\n"
"\n"
"                <t t-if=\"link\">\n"
"                    <t t-set=\"link\" t-value=\"link[0]\"/>\n"
"\n"
"                    <!-- CONCEPTS PENDING AUTHORIZATION -->\n"
"                    <strong>Concepts additionals:</strong>\n"
"\n"
"                    <t t-set=\"pending_lines\" t-value=\"link.supplier_product_ids.filtered(                             lambda l: not l.display_type and l.authorization_pending                         )\"/>\n"
"\n"
"                    <t t-if=\"pending_lines\">\n"
"                        <table border=\"1\" cellpadding=\"5\" cellspacing=\"0\" width=\"100%\" style=\"border-collapse: collapse;\">\n"
"                            <thead style=\"background-color:#4a90e2; color:white;\">\n"
"                                <tr>\n"
"                                    <th style=\"border:1px solid #000; padding:6px;\">Concept</th>\n"
"                                    <th style=\"border:1px solid #000; padding:6px;\">Cost</th>\n"
"                                </tr>\n"
"                            </thead>\n"
"                            <tbody>\n"
"                                <t t-foreach=\"pending_lines\" t-as=\"line\">\n"
"                                    <tr>\n"
"                                        <td style=\"border:1px solid #000; padding:6px;\">\n"
"                                            <t t-out=\"line.product_id.display_name or line.name\"/>\n"
"                                        </td>\n"
"                                        <td style=\"border:1px solid #000; padding:6px;\" align=\"right\">\n"
"                                            <t t-set=\"price\" t-value=\"line.base_unit_price if line.base_unit_price else line.unit_price\"/>\n"
"                                            <t t-out=\"'${:,.2f}'.format(price)\"/>\n"
"                                        </td>\n"
"                                    </tr>\n"
"                                </t>\n"
"                            </tbody>\n"
"                        </table>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <em>No concepts pending authorization.</em>\n"
"                    </t>\n"
"                    <br/>\n"
"\n"
"                    <!-- AUTHORIZATION TYPE -->\n"
"                    <strong>Authorization type:</strong>\n"
"\n"
"                    <t t-if=\"link.type_authorization_id\">\n"
"                        <t t-out=\"link.type_authorization_id.name\"/>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <em>No authorization type.</em>\n"
"                    </t>\n"
"\n"
"                    <br/><br/>\n"
"\n"
"                    <!-- RESPONSIBLE -->\n"
"                    <strong>Responsible authorizator:</strong>\n"
"\n"
"                    <t t-set=\"responsible_name\" t-value=\"link.nu_user_id.display_name if link.authorization_by_nu else link.authorizer_id.display_name\"/>\n"
"\n"
"                    <t t-if=\"responsible_name\">\n"
"                        <t t-out=\"responsible_name\"/>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <em>No responsible assigned.</em>\n"
"                    </t>\n"
"\n"
"                    <br/><br/>\n"
"\n"
"                    <!-- MOTIVE -->\n"
"                    <strong>Motive:</strong>\n"
"\n"
"                    <t t-if=\"link.reason_authorizer_id\">\n"
"                        <t t-out=\"link.reason_authorizer_id.name\"/>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <em>No motive assigned.</em>\n"
"                    </t>\n"
"\n"
"                </t>\n"
"\n"
"                <t t-else=\"\">\n"
"                    <em>No supplier information available.</em>\n"
"                </t>\n"
"\n"
"            "
msgstr ""
"<t t-set=\"link\" t-value=\"object.service_supplier_link_ids.filtered(lambda l: l.id == ctx.get('supplier_link_id'))[:1]\"/>\n"
"\n"
"                <t t-if=\"link\">\n"
"                    <t t-set=\"link\" t-value=\"link[0]\"/>\n"
"\n"
"                    <!-- CONCEPTS PENDING AUTHORIZATION -->\n"
"                    <strong>Conceptos adicionales:</strong>\n"
"\n"
"                    <t t-set=\"pending_lines\" t-value=\"link.supplier_product_ids.filtered(                             lambda l: not l.display_type and l.authorization_pending                         )\"/>\n"
"\n"
"                    <t t-if=\"pending_lines\">\n"
"                        <table border=\"1\" cellpadding=\"5\" cellspacing=\"0\" width=\"100%\" style=\"border-collapse: collapse;\">\n"
"                            <thead style=\"background-color:#4a90e2; color:white;\">\n"
"                                <tr>\n"
"                                    <th style=\"border:1px solid #000; padding:6px;\">Concepto</th>\n"
"                                    <th style=\"border:1px solid #000; padding:6px;\">Costo</th>\n"
"                                </tr>\n"
"                            </thead>\n"
"                            <tbody>\n"
"                                <t t-foreach=\"pending_lines\" t-as=\"line\">\n"
"                                    <tr>\n"
"                                        <td style=\"border:1px solid #000; padding:6px;\">\n"
"                                            <t t-out=\"line.product_id.display_name or line.name\"/>\n"
"                                        </td>\n"
"                                        <td style=\"border:1px solid #000; padding:6px;\" align=\"right\">\n"
"                                            <t t-set=\"price\" t-value=\"line.base_unit_price if line.base_unit_price else line.unit_price\"/>\n"
"                                            <t t-out=\"'${:,.2f}'.format(price)\"/>\n"
"                                        </td>\n"
"                                    </tr>\n"
"                                </t>\n"
"                            </tbody>\n"
"                        </table>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <em>No hay conceptos adicionales</em>\n"
"                    </t>\n"
"                    <br/>\n"
"\n"
"                    <!-- AUTHORIZATION TYPE -->\n"
"                    <strong>Tipo de autorización:</strong>\n"
"\n"
"                    <t t-if=\"link.type_authorization_id\">\n"
"                        <t t-out=\"link.type_authorization_id.name\"/>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <em>No se seleccionado tipo de autorización</em>\n"
"                    </t>\n"
"\n"
"                    <br/><br/>\n"
"\n"
"                    <!-- RESPONSIBLE -->\n"
"                    <strong>Autorizador responsable:</strong>\n"
"\n"
"                    <t t-set=\"responsible_name\" t-value=\"link.nu_user_id.display_name if link.authorization_by_nu else link.authorizer_id.display_name\"/>\n"
"\n"
"                    <t t-if=\"responsible_name\">\n"
"                        <t t-out=\"responsible_name\"/>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <em>No se selcicono autorizador responsable</em>\n"
"                    </t>\n"
"\n"
"                    <br/><br/>\n"
"\n"
"                    <!-- MOTIVE -->\n"
"                    <strong>Motivo:</strong>\n"
"\n"
"                    <t t-if=\"link.reason_authorizer_id\">\n"
"                        <t t-out=\"link.reason_authorizer_id.name\"/>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <em>No se selecciono motivo.</em>\n"
"                    </t>\n"
"\n"
"                </t>\n"
"\n"
"                <t t-else=\"\">\n"
"                    <em>No hay información</em>\n"
"                </t>\n"
"\n"
"            "

