#. module: ike_event_binnacle
#: model:mail.template,body_html:ike_event_binnacle.ike_binnacle_stage_mail_template_5_6
msgid ""
"<strong>Search type:</strong>\n"
"                <t t-out=\"object._fields['supplier_search_type'].convert_to_export(object.supplier_search_type, object) \"/>\n"
"\n"
"                <t t-if=\"ctx.get('search_priority')\">\n"
"                    <strong>Priority:</strong>\n"
"\n"
"                    <t t-if=\"str(ctx.get('search_priority')) == '3'\">High</t>\n"
"                    <t t-elif=\"str(ctx.get('search_priority')) == '2'\">Medium</t>\n"
"                    <t t-elif=\"str(ctx.get('search_priority')) == '1'\">Low</t>\n"
"                </t>\n"
"\n"
"                <br/>\n"
"                <strong>Recommended supplier:</strong>\n"
"\n"
"                <t t-set=\"last_search\" t-value=\"max(object.service_supplier_ids.mapped('search_number') or [0])\"/>\n"
"\n"
"                <!-- Filtrar proveedores v&#225;lidos -->\n"
"                <t t-set=\"suppliers\" t-value=\"object.service_supplier_ids.filtered(                     lambda l: l.search_number == last_search                     and not l.display_type                     and (                         not ctx.get('search_priority')                         or str(l.priority) == str(ctx.get('search_priority'))                     )                 ).sorted(                     key=lambda l: (                         int(l.priority),                          l.estimated_duration,                          l.estimated_cost                     )                 )\"/>\n"
"\n"
"                <!-- Si hay proveedores -->\n"
"                <t t-if=\"suppliers\">\n"
"                    <ol>\n"
"                        <t t-foreach=\"suppliers\" t-as=\"line\">\n"
"                            <li>\n"
"                                <strong><t t-out=\"line.supplier_id.name\"/></strong><br/>\n"
"                                <t t-out=\"line.name\"/>\n"
"                            </li>\n"
"                        </t>\n"
"                    </ol>\n"
"                </t>\n"
"\n"
"                <!-- Si no hay -->\n"
"                <t t-else=\"\">\n"
"                    <p>No supplier was found</p>\n"
"                </t>\n"
"\n"
"            "
msgstr ""
"<strong>Tipo de búsqueda:</strong>\n"
"                <t t-out=\"object._fields['supplier_search_type'].convert_to_export(object.supplier_search_type, object) \"/>\n"
"\n"
"                <t t-if=\"ctx.get('search_priority')\">\n"
"                    <strong>Prioridad:</strong>\n"
"\n"
"                    <t t-if=\"str(ctx.get('search_priority')) == '3'\">Alta</t>\n"
"                    <t t-elif=\"str(ctx.get('search_priority')) == '2'\">Media</t>\n"
"                    <t t-elif=\"str(ctx.get('search_priority')) == '1'\">Baja</t>\n"
"                </t>\n"
"\n"
"                <br/>\n"
"                <strong>Proveedores recomendados:</strong>\n"
"\n"
"                <t t-set=\"last_search\" t-value=\"max(object.service_supplier_ids.mapped('search_number') or [0])\"/>\n"
"\n"
"                <!-- Filtrar proveedores v&#225;lidos -->\n"
"                <t t-set=\"suppliers\" t-value=\"object.service_supplier_ids.filtered(                     lambda l: l.search_number == last_search                     and not l.display_type                     and (                         not ctx.get('search_priority')                         or str(l.priority) == str(ctx.get('search_priority'))                     )                 ).sorted(                     key=lambda l: (                         int(l.priority),                          l.estimated_duration,                          l.estimated_cost                     )                 )\"/>\n"
"\n"
"                <!-- Si hay proveedores -->\n"
"                <t t-if=\"suppliers\">\n"
"                    <ol>\n"
"                        <t t-foreach=\"suppliers\" t-as=\"line\">\n"
"                            <li>\n"
"                                <strong><t t-out=\"line.supplier_id.name\"/></strong><br/>\n"
"                                <t t-out=\"line.name\"/>\n"
"                            </li>\n"
"                        </t>\n"
"                    </ol>\n"
"                </t>\n"
"\n"
"                <!-- Si no hay -->\n"
"                <t t-else=\"\">\n"
"                    <p>No se encontraron proveedores</p>\n"
"                </t>\n"
"\n"
"            "

