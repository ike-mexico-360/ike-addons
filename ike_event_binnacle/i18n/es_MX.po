"                        <t t-set=\"responsible_name\" t-value=\"link.nu_user_id.display_name if link.authorization_by_nu else link.authorizer_id.display_name\"/>\n"
"\n"
"                        <t t-if=\"responsible_name\">\n"
"\n"
"                            <t t-if=\"printed_resp &gt; 0\"> | </t>\n"
"\n"
"                            <t t-out=\"responsible_name\"/>\n"
"\n"
"                            <t t-set=\"printed_resp\" t-value=\"printed_resp + 1\"/>\n"
"                        </t>\n"
"\n"
"                    </t>\n"
"\n"
"                    <t t-if=\"printed_resp == 0\">\n"
"                        <em>No responsible assigned.</em>\n"
"                    </t>\n"
"                    <t t-else=\"\">.</t>\n"
"                </t>\n"
"            "
msgstr ""
"<t> \n"
"                    <strong>Autorizador responsable:</strong>\n"
"\n"
"                    <t t-set=\"printed_resp\" t-value=\"0\"/>\n"
"\n"
"                    <t t-foreach=\"object.service_supplier_link_ids\" t-as=\"link\">\n"
"\n"
"                        <t t-set=\"responsible_name\" t-value=\"link.nu_user_id.display_name if link.authorization_by_nu else link.authorizer_id.display_name\"/>\n"
"\n"
"                        <t t-if=\"responsible_name\">\n"
"\n"
"                            <t t-if=\"printed_resp &gt; 0\"> | </t>\n"
"\n"
"                            <t t-out=\"responsible_name\"/>\n"
"\n"
"                            <t t-set=\"printed_resp\" t-value=\"printed_resp + 1\"/>\n"
"                        </t>\n"
"\n"
"                    </t>\n"
"\n"
"                    <t t-if=\"printed_resp == 0\">\n"
"                        <em>No hay autorizador responsable asignado.</em>\n"
"                    </t>\n"
"                    <t t-else=\"\">.</t>\n"
"                </t>\n"
"            "

