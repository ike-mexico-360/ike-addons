msgid ""
"<t> \n"
"                    <strong>Responsible authorizator:</strong>\n"
"\n"
"                    <t t-set=\"printed_resp\" t-value=\"0\"/>\n"
"\n"
"                    <t t-foreach=\"object.service_supplier_link_ids\" t-as=\"link\">\n"
