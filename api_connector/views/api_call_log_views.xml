<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- API Call Log Form View -->
    <record id="view_api_call_log_form" model="ir.ui.view">
        <field name="name">api.call.log.form</field>
        <field name="model">api.call.log</field>
        <field name="arch" type="xml">
            <form string="API Call Log" create="false" edit="false">
                <header>
                    <button name="action_retry_call" 
                            string="Retry Call" 
                            type="object" 
                            class="btn-primary"
                            icon="fa-refresh"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name"/>
                        </h1>
                        <h3 class="text-muted">
                            <field name="connector_id" readonly="1"/>
                        </h3>
                    </div>

                    <group>
                        <group string="Call Information">
                            <field name="call_date"/>
                            <field name="success" widget="boolean"/>
                            <field name="status_code"/>
                            <field name="execution_time" widget="float_time"/>
                        </group>
                        <group string="Response Information">
                            <field name="response_size" widget="integer"/>
                            <field name="status_icon" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Request Data Tab -->
                        <page string="Request Data" name="request">
                            <field name="request_data" 
                                   widget="text"
                                   readonly="1"/>
                        </page>

                        <!-- Response Data Tab -->
                        <page string="Response Data" name="response">
                            <field name="response_data" 
                                   widget="text"
                                   readonly="1"/>
                        </page>

                        <!-- Error Details Tab -->
                        <page string="Error Details" name="error" 
                              invisible="success == True">
                            <field name="error_message" readonly="1" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- API Call Log Tree View -->
    <record id="view_api_call_log_tree" model="ir.ui.view">
        <field name="name">api.call.log.tree</field>
        <field name="model">api.call.log</field>
        <field name="arch" type="xml">
            <list sample="1" create="false" edit="false">
                <field name="status_icon" string=""/>
                <field name="call_date"/>
                <field name="connector_id"/>
                <field name="success" widget="boolean"/>
                <field name="status_code"/>
                <field name="execution_time" widget="float_time"/>
                <field name="response_size" widget="integer"/>
                <field name="error_message" optional="hide"/>
                <button name="action_view_details" 
                        string="View Details" 
                        type="object" 
                        icon="fa-eye" 
                        class="btn-link"/>
                <button name="action_retry_call" 
                        string="Retry" 
                        type="object" 
                        icon="fa-refresh" 
                        class="btn-link"/>
            </list>
        </field>
    </record>

    <!-- API Call Log Search View -->
    <record id="view_api_call_log_search" model="ir.ui.view">
        <field name="name">api.call.log.search</field>
        <field name="model">api.call.log</field>
        <field name="arch" type="xml">
            <search string="API Call Logs">
                <field name="connector_id" string="API Connection"/>
                <field name="call_date"/>
                <field name="status_code"/>
                <field name="error_message" string="Error"/>
                <filter string="Successful" name="success" domain="[('success', '=', True)]"/>
                <filter string="Failed" name="failed" domain="[('success', '=', False)]"/>
                <separator/>
                <filter string="Today" name="today" 
                        domain="[('call_date', '>=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)))]"/>
                <filter string="Last 7 Days" name="week" 
                        domain="[('call_date', '>=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter string="Last 30 Days" name="month" 
                        domain="[('call_date', '>=', (context_today() - datetime.timedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter string="API Connection" name="group_connector" context="{'group_by': 'connector_id'}"/>
                    <filter string="Success Status" name="group_success" context="{'group_by': 'success'}"/>
                    <filter string="Status Code" name="group_status_code" context="{'group_by': 'status_code'}"/>
                    <filter string="Call Date" name="group_call_date" context="{'group_by': 'call_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- API Call Log Action -->
    <record id="action_api_call_log" model="ir.actions.act_window">
        <field name="name">API Call Logs</field>
        <field name="res_model">api.call.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_week': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No API calls logged yet!
            </p>
            <p>
                API call logs will appear here when you start making outbound API calls.
                Use the logs to monitor performance, debug issues, and track API usage.
            </p>
        </field>
    </record>
</odoo>
