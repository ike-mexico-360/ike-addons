<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- API Connector Form View -->
    <record id="view_api_connector_form" model="ir.ui.view">
        <field name="name">api.connector.form</field>
        <field name="model">api.connector</field>
        <field name="arch" type="xml">
            <form string="API Connection">
                <header>
                    <button name="execute_call" 
                            string="Execute Call" 
                            type="object" 
                            class="btn-primary"
                            icon="fa-rocket"/>
                </header>
                <sheet>
                    <!-- HTTP Method Ribbon -->
                    <widget name="web_ribbon" title="GET" bg_color="text-bg-success" invisible="method != 'GET'"/>
                    <widget name="web_ribbon" title="POST" bg_color="text-bg-primary" invisible="method != 'POST'"/>
                    <widget name="web_ribbon" title="PUT" bg_color="text-bg-warning" invisible="method != 'PUT'"/>
                    <widget name="web_ribbon" title="PATCH" bg_color="text-bg-info" invisible="method != 'PATCH'"/>
                    <widget name="web_ribbon" title="DELETE" bg_color="text-bg-danger" invisible="method != 'DELETE'"/>
                    
                    <!-- Button Box -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" 
                                name="action_view_collection" 
                                type="object" 
                                icon="fa-folder-open"
                                invisible="not collection_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Collection</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" 
                                name="export_config" 
                                type="object" 
                                icon="fa-download"
                                invisible="not id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Export Config</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Connection Name..." required="1"/>
                        </h1>
                        <h3>
                            <field name="full_url" readonly="1" class="text-muted"/>
                        </h3>

                    </div>

                    <notebook>
                        <!-- Basic Configuration Tab -->
                        <page string="Basic Configuration" name="basic">
                            <group>
                                <group string="API Details">
                                    <field name="collection_id" options="{'no_create': True}"/>
                                    <field name="api_type" widget="radio" options="{'horizontal': true}"/>
                                    <field name="method" readonly="api_type != 'rest'"/>
                                    <field name="use_collection_url" invisible="not collection_id"/>
                                    <field name="base_url" 
                                           placeholder="https://api.example.com"
                                           readonly="use_collection_url and collection_id"/>
                                    <field name="endpoint_path" placeholder="/api/v1/endpoint or /api/v2/saleorder/read/{id}"/>
                                    <field name="endpoint_variables" 
                                           widget="text"
                                           colspan="2"
                                           placeholder='{"id": "123", "user_id": "456", "filter": "active"}'
                                           help="JSON variables to replace {variable} placeholders in endpoint path and request body"/>
                                </group>
                                <group string="Settings">
                                    <field name="timeout"/>
                                    <field name="verify_ssl"/>
                                    <field name="expected_response_type"/>
                                    <field name="is_system_critical" 
                                           help="Protect this route from accidental deletion"/>
                                </group>
                            </group>
                        </page>

                        <!-- Authentication Tab -->
                        <page string="Authentication" name="auth">
                            <group>
                                <field name="auth_type" widget="radio"/>
                            </group>
                            
                            <!-- Inherit from Collection -->
                            <div invisible="auth_type != 'inherit'">
                                <div class="alert alert-info" role="alert">
                                    <h5>Collection Authentication</h5>
                                    <p>This endpoint will use the authentication configured in its collection.</p>
                                    <p invisible="collection_id">Please select a collection first to inherit authentication.</p>
                                </div>
                                <group>
                                    <field name="collection_id" readonly="1" invisible="not collection_id"/>
                                </group>
                            </div>
                            
                            <group invisible="auth_type in ['inherit', 'none']">
                                <!-- Basic Auth -->
                                <group string="Basic Authentication" 
                                       invisible="auth_type != 'basic'">
                                    <field name="auth_username" required="auth_type == 'basic'"/>
                                    <field name="auth_password" password="True" 
                                           required="auth_type == 'basic'"/>
                                </group>

                                <!-- Bearer Token -->
                                <group string="Bearer Token" 
                                       invisible="auth_type != 'bearer'">
                                    <field name="auth_token" password="True" 
                                           required="auth_type == 'bearer'"/>
                                </group>

                                <!-- API Key -->
                                <group string="API Key" 
                                       invisible="auth_type != 'api_key'">
                                    <field name="auth_header_name" 
                                           required="auth_type == 'api_key'"/>
                                    <field name="auth_token" password="True" 
                                           required="auth_type == 'api_key'"/>
                                </group>

                                <!-- OAuth 2.0 -->
                                <group string="OAuth 2.0 Configuration" 
                                       invisible="auth_type != 'oauth2'">
                                    <field name="oauth_client_id" required="auth_type == 'oauth2'"/>
                                    <field name="oauth_client_secret" password="True" required="auth_type == 'oauth2'"/>
                                    <field name="oauth_token_url" required="auth_type == 'oauth2'" 
                                           placeholder="https://api.example.com/oauth/token"/>
                                    <field name="oauth_authorization_url" 
                                           placeholder="https://api.example.com/oauth/authorize"/>
                                    <field name="oauth_scope" placeholder="read write"/>
                                </group>
                                
                                <group string="OAuth 2.0 Tokens" 
                                       invisible="auth_type != 'oauth2'">
                                    <div class="row">
                                        <div class="col-8">
                                            <field name="oauth_access_token" readonly="1"/>
                                        </div>
                                        <div class="col-4">
                                            <button name="get_oauth_token" 
                                                    string="Get New Access Token" 
                                                    type="object" 
                                                    class="btn-warning"
                                                    icon="fa-key"/>
                                        </div>
                                    </div>
                                    <field name="oauth_refresh_token" readonly="1"/>
                                    <field name="oauth_token_expires_at" readonly="1"/>
                                    <div class="text-muted">
                                        <p><strong>Alternative:</strong> You can also manually paste a token in the field below:</p>
                                    </div>
                                    <field name="auth_token" password="True" 
                                           placeholder="Manual token (optional if using OAuth flow above)"/>
                                </group>
                            </group>
                        </page>

                        <!-- Headers Tab -->
                        <page string="Headers" name="headers">
                            <group>
                                <field name="custom_headers" 
                                       widget="text"
                                       colspan="2"
                                       placeholder='{"Content-Type": "application/json", "Accept": "application/json"}'/>
                                <div class="text-muted" colspan="2">
                                    <p>Enter custom headers in JSON format. Authentication headers are added automatically based on the Authentication tab.</p>
                                </div>
                            </group>
                        </page>

                        <!-- Request Body Tab -->
                        <page string="Request Body" name="body" 
                              invisible="api_type == 'rest' and method in ['GET', 'DELETE']">
                            <group>
                                <field name="request_body_type" widget="radio"/>
                            </group>
                            
                            <!-- Form Data Fields -->
                            <div invisible="request_body_type not in ['form', 'form_multipart']">
                                <h5>Form Data</h5>
                                <field name="form_data" 
                                       widget="text"
                                       placeholder='{"key1": "value1", "key2": "value2"}'/>
                            </div>
                            
                            <!-- File Upload for Multipart -->
                            <div invisible="request_body_type != 'form_multipart'">
                                <h5>File Upload</h5>
                                <field name="file_field_name" 
                                       placeholder="ufile"
                                       help="Name of the file field (e.g., 'ufile', 'file', 'attachment')"/>
                                <field name="attachment_ids" widget="many2many_tags"/>
                                <div class="text-info mt-2">
                                    <i class="fa fa-info-circle" title="File Upload Information"/> 
                                    <strong>File Upload:</strong> Select attachments to upload with multipart form data.
                                    Files will be sent using the field name above.
                                </div>
                            </div>
                            
                            <!-- JSON Body -->
                            <div invisible="request_body_type != 'json'">
                                <h5>JSON Body</h5>
                                <field name="request_body" 
                                       widget="text"
                                       placeholder='{"key": "value", "dynamic": "{variable_name}"}'/>
                            </div>
                            
                            <!-- XML Body -->
                            <group string="XML Body" invisible="request_body_type != 'xml'">
                                <field name="request_body" 
                                       widget="text"
                                       placeholder='&lt;request&gt;&lt;data&gt;{variable_name}&lt;/data&gt;&lt;/request&gt;'/>
                            </group>
                            
                            <!-- Raw Text Body -->
                            <group string="Raw Text Body" invisible="request_body_type != 'raw'">
                                <field name="request_body" 
                                       widget="text"
                                       placeholder='Raw text content with {variable_name} substitution'/>
                            </group>
                            
                            <!-- Binary Body -->
                            <group string="Binary Body (Base64)" invisible="request_body_type != 'binary'">
                                <field name="request_body" 
                                       widget="text"
                                       placeholder='iVBORw0KGgoAAAANSUhEUgAA... (base64 encoded data)'/>
                            </group>
                        </page>

                        <!-- Response Tab -->
                        <page string="Response" name="response">
                            <div class="alert alert-info" role="alert" invisible="last_response_data">
                                <p><i class="fa fa-info-circle me-2" title="Information"/>No API response yet. Click "Test Connection" or "Execute Call" to see the response here.</p>
                            </div>
                            
                            <div invisible="not last_response_data">
                                <group>
                                    <group string="Response Summary">
                                        <field name="last_response_success" widget="boolean" readonly="1"/>
                                        <field name="last_response_status" readonly="1"/>
                                        <field name="last_response_time" readonly="1" string="Response Time (ms)"/>
                                    </group>
                                </group>
                                
                                <!-- Response Data -->
                                <group string="Response Data" invisible="not last_response_data">
                                    <field name="last_response_data" 
                                           widget="text"
                                           colspan="2"
                                           readonly="1"
                                           nolabel="1"/>
                                </group>
                                
                                <!-- Error Details -->
                                <group string="Error Details" invisible="not last_response_error">
                                    <field name="last_response_error" readonly="1" nolabel="1"/>
                                </group>
                            </div>
                        </page>

                        <!-- Statistics Tab -->
                        <page string="Statistics" name="stats">
                            <group>
                                <group string="Call Statistics">
                                    <field name="total_calls" readonly="1"/>
                                    <field name="success_calls" readonly="1"/>
                                    <field name="success_rate" widget="percentage" readonly="1"/>
                                    <field name="last_call_date" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        
                        <!-- Documentation Tab -->
                        <page string="Documentation" name="documentation" invisible="not id">
                            <div class="alert alert-info" role="alert">
                                <h4><i class="fa fa-info-circle" title="Information"/> API Connector Overview</h4>
                                <p>API Connectors are individual endpoint configurations that can execute HTTP requests to external APIs. They can inherit settings from Collections for shared authentication and base URLs.</p>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <h5>Basic Information</h5>
                                    <div class="text-muted">
                                        <p><strong>Connector ID for cron jobs:</strong></p>
                                    </div>
                                    <field name="id" readonly="1"/>
                                </div>
                                
                                <div class="col-md-6">
                                    <h5>Key Features</h5>
                                    <ul>
                                        <li><strong>HTTP Methods:</strong> GET, POST, PUT, PATCH, DELETE</li>
                                        <li><strong>Authentication:</strong> None, Basic Auth, Bearer Token, API Key, OAuth 2.0</li>
                                        <li><strong>Request Types:</strong> JSON, XML, Form Data, Multipart (with file upload), Binary, Raw Text</li>
                                        <li><strong>Dynamic Variables:</strong> Use {variable_name} syntax in URLs, headers, and body</li>
                                        <li><strong>Collection Inheritance:</strong> Inherit base URL, auth, and variables from parent collection</li>
                                        <li><strong>Monitoring:</strong> Automatic logging of all calls with success rates and response times</li>
                                    </ul>
                                </div>
                            </div>
                            
                            <div class="alert alert-success" role="alert">
                                <h5><i class="fa fa-cog" title="Configuration"/> Variable Priority Order</h5>
                                <p>Variables are resolved in this order (highest to lowest priority):</p>
                                <ol>
                                    <li><strong>Dynamic variables</strong> passed during execution (cron, manual call)</li>
                                    <li><strong>Endpoint variables</strong> defined in this connector</li>
                                    <li><strong>Collection variables</strong> from the parent collection</li>
                                </ol>
                            </div>
                            
                            <div class="alert alert-warning" role="alert">
                                <h5><i class="fa fa-code" title="Code Example"/> Cron Usage Example</h5>
                                <p>Use this connector in scheduled actions:</p>
                                <pre style="background: #f8f9fa; padding: 10px; border-radius: 4px; font-family: monospace;">
connector = env['api.connector'].browse(<field name="id" readonly="1"/>)
result = connector.execute_call({
    'order_id': record.id,
    'date': datetime.date.today().strftime('%Y-%m-%d'),
    'user_name': env.user.name
})</pre>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- API Connector Tree View -->
    <record id="view_api_connector_tree" model="ir.ui.view">
        <field name="name">api.connector.tree</field>
        <field name="model">api.connector</field>
        <field name="arch" type="xml">
            <list sample="1">
                <field name="collection_id" optional="show"/>
                <field name="name"/>
                <field name="api_type"/>
                <field name="method" 
                       decoration-success="method == 'GET'"
                       decoration-primary="method == 'POST'"
                       decoration-warning="method == 'PUT'"
                       decoration-info="method == 'PATCH'"
                       decoration-danger="method == 'DELETE'"/>
                <field name="full_url"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="is_system_critical" string="Critical" readonly="1"
                       decoration-warning="is_system_critical == True"/>
                <field name="success_rate" widget="percentage" 
                       decoration-success="success_rate >= 0.9"
                       decoration-warning="success_rate >= 0.7 and success_rate &lt; 0.9"
                       decoration-danger="success_rate &lt; 0.7"/>
                <field name="total_calls"/>
                <field name="last_call_date"/>
                <button name="execute_call" 
                        string="Execute" 
                        type="object" 
                        icon="fa-rocket" 
                        class="btn-link"/>
            </list>
        </field>
    </record>

    <!-- API Connector Search View -->
    <record id="view_api_connector_search" model="ir.ui.view">
        <field name="name">api.connector.search</field>
        <field name="model">api.connector</field>
        <field name="arch" type="xml">
            <search string="API Connections">
                <field name="name" string="Name"/>
                <field name="collection_id" string="Collection"/>
                <field name="base_url" string="URL"/>
                <field name="api_type"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="REST" name="rest" domain="[('api_type', '=', 'rest')]"/>
                <filter string="JSON-RPC" name="jsonrpc" domain="[('api_type', '=', 'jsonrpc')]"/>
                <filter string="GraphQL" name="graphql" domain="[('api_type', '=', 'graphql')]"/>
                <filter string="SOAP" name="soap" domain="[('api_type', '=', 'soap')]"/>
                <separator/>
                <filter string="GET" name="method_get" domain="[('method', '=', 'GET')]"/>
                <filter string="POST" name="method_post" domain="[('method', '=', 'POST')]"/>
                <filter string="PUT" name="method_put" domain="[('method', '=', 'PUT')]"/>
                <filter string="DELETE" name="method_delete" domain="[('method', '=', 'DELETE')]"/>
                <group>
                    <filter string="Collection" name="group_collection" context="{'group_by': 'collection_id'}"/>
                    <filter string="API Type" name="group_api_type" context="{'group_by': 'api_type'}"/>
                    <filter string="HTTP Method" name="group_method" context="{'group_by': 'method'}"/>
                    <filter string="Authentication" name="group_auth_type" context="{'group_by': 'auth_type'}"/>
                    <filter string="Status" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- API Connector Action -->
    <record id="action_api_connector" model="ir.actions.act_window">
        <field name="name">API Connections</field>
        <field name="res_model">api.connector</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first API connection!
            </p>
            <p>
                Configure outbound API calls using our Postman-like interface.
                Support for REST, JSON-RPC, GraphQL, and SOAP APIs.
            </p>
        </field>
    </record>
    
    <!-- Import Configuration Action for Connectors -->
    <record id="action_import_connector_config" model="ir.actions.act_window">
        <field name="name">Import Connector Configuration</field>
        <field name="res_model">import.config.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_config_type': 'connector'}</field>
    </record>
</odoo>
