    <menuitem id="menu_api_connector_monitoring"
              name="Monitoring"
              parent="menu_api_connector_main"
              sequence="20"/>

    <!-- Call Logs Menu -->
    <menuitem id="menu_api_call_logs"
              name="Call Logs"
              parent="menu_api_connector_monitoring"
