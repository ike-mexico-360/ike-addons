<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Main Menu -->
    <menuitem id="menu_api_connector_main"
              name="API Connector"
              sequence="90"
              web_icon="api_connector,static/description/icon.png"
              groups="api_connector.group_api_connector_user,api_connector.group_api_connector_manager"/>

    <!-- Configuration Menu -->
