<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- API Collection Form View -->
    <record id="view_api_collection_form" model="ir.ui.view">
        <field name="name">api.collection.form</field>
        <field name="model">api.collection</field>
        <field name="arch" type="xml">
            <form string="API Collection">
                <header>
                    <button name="create_connector_from_collection" 
                            string="Add Endpoint" 
                            type="object" 
                            class="btn-primary"
                            icon="fa-plus"/>
                </header>
                <sheet>
                    <!-- Button Box -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" 
                                name="action_view_connectors" 
                                type="object" 
                                icon="fa-link">
                            <field name="connector_count" widget="statinfo" string="Endpoints"/>
                        </button>
                        <button class="oe_stat_button" 
                                name="export_config" 
                                type="object" 
                                icon="fa-download"
                                invisible="not id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Export Config</span>
                            </div>
                        </button>
                    </div>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Collection Name..." required="1"/>
                        </h1>
                        <h3>
                            <field name="description" placeholder="Description of this API collection..."/>
                        </h3>

                    </div>

                    <notebook>
                        <!-- Collection Settings -->
                        <page string="Collection Settings" name="settings">
                            <group>
                                <group string="Default Configuration">
                                    <field name="base_url" placeholder="https://api.example.com"/>
                                    <field name="auth_type"/>
                                </group>
                                <group string="Statistics">
                                    <field name="total_calls" readonly="1"/>
                                    <field name="success_rate" widget="percentage" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <!-- Authentication -->
                        <page string="Authentication" name="auth">
                            <group>
                                <field name="auth_type" widget="radio"/>
                            </group>
                            
                            <group invisible="auth_type == 'none'">
                                <!-- Basic Auth -->
                                <group string="Basic Authentication" 
                                       invisible="auth_type != 'basic'">
                                    <field name="auth_username" required="auth_type == 'basic'"/>
                                    <field name="auth_password" password="True" 
                                           required="auth_type == 'basic'"/>
                                </group>

                                <!-- Bearer Token -->
                                <group string="Bearer Token" 
                                       invisible="auth_type != 'bearer'">
                                    <field name="auth_token" password="True" 
                                           required="auth_type == 'bearer'"/>
                                </group>

                                <!-- API Key -->
                                <group string="API Key" 
                                       invisible="auth_type != 'api_key'">
                                    <field name="auth_header_name" 
                                           required="auth_type == 'api_key'"/>
                                    <field name="auth_token" password="True" 
                                           required="auth_type == 'api_key'"/>
                                </group>

                                <!-- OAuth 2.0 -->
                                <group string="OAuth 2.0 Configuration" 
                                       invisible="auth_type != 'oauth2'">
                                    <field name="oauth_client_id" required="auth_type == 'oauth2'"/>
                                    <field name="oauth_client_secret" password="True" required="auth_type == 'oauth2'"/>
                                    <field name="oauth_token_url" required="auth_type == 'oauth2'" 
                                           placeholder="https://api.example.com/oauth/token"/>
                                    <field name="oauth_authorization_url" 
                                           placeholder="https://api.example.com/oauth/authorize"/>
                                    <field name="oauth_scope" placeholder="read write"/>
                                </group>
                                
                                <group string="OAuth 2.0 Tokens" 
                                       invisible="auth_type != 'oauth2'">
                                    <div class="row">
                                        <div class="col-8">
                                            <field name="oauth_access_token" readonly="1"/>
                                        </div>
                                        <div class="col-4">
                                            <button name="get_oauth_token" 
                                                    string="Get New Access Token" 
                                                    type="object" 
                                                    class="btn-warning"
                                                    icon="fa-key"/>
                                        </div>
                                    </div>
                                    <field name="oauth_refresh_token" readonly="1"/>
                                    <field name="oauth_token_expires_at" readonly="1"/>
                                    <div class="text-muted">
                                        <p><strong>Alternative:</strong> You can also manually paste a token in the field below:</p>
                                    </div>
                                    <field name="auth_token" password="True" 
                                           placeholder="Manual token (optional if using OAuth flow above)"/>
                                </group>
                            </group>
                        </page>

                        <!-- Headers and Variables -->
                        <page string="Headers and Variables" name="variables">
                            <div class="row">
                                <div class="col-md-6">
                                    <h5>Default Headers</h5>
                                    <field name="default_headers" 
                                           widget="text"
                                           placeholder='{"Content-Type": "application/json", "Accept": "application/json"}'/>
                                </div>
                                <div class="col-md-6">
                                    <h5>Collection Variables</h5>
                                    <field name="collection_variables" 
                                           widget="text"
                                           placeholder='{"api_version": "v2", "environment": "prod", "project_id": "123"}'/>
                                    <div class="text-muted mt-2">
                                        <p>Variables can be used in endpoint URLs and bodies with {variable_name} syntax.</p>
                                    </div>
                                </div>
                            </div>
                        </page>
                        
                        <!-- Documentation Tab -->
                        <page string="Documentation" name="documentation" invisible="not id">
                            <div class="alert alert-info" role="alert">
                                <h4><i class="fa fa-info-circle" title="Information"/> API Collection Overview</h4>
                                <p>API Collections group multiple endpoints with shared configuration. They provide centralized authentication, base URLs, default headers, and variables that can be inherited by all child connectors.</p>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <h5>Basic Information</h5>
                                    <div class="text-muted">
                                        <p><strong>Collection ID for cron jobs:</strong></p>
                                    </div>
                                    <field name="id" readonly="1"/>
                                </div>
                                
                                <div class="col-md-6">
                                    <h5>Collection Benefits</h5>
                                    <ul>
                                        <li><strong>Shared Authentication:</strong> Configure once, use across all endpoints</li>
                                        <li><strong>Common Base URL:</strong> Centralized API endpoint management</li>
                                        <li><strong>Default Headers:</strong> Apply standard headers to all requests</li>
                                        <li><strong>Collection Variables:</strong> Define reusable values for all endpoints</li>
                                        <li><strong>Bulk Operations:</strong> Execute multiple endpoints in sequence</li>
                                        <li><strong>Centralized Statistics:</strong> Monitor success rates across all endpoints</li>
                                    </ul>
                                </div>
                            </div>
                            
                            <div class="alert alert-success" role="alert">
                                <h5><i class="fa fa-sitemap" title="Structure"/> Inheritance Model</h5>
                                <p>Child connectors can inherit from collections:</p>
                                <ul>
                                    <li><strong>Base URL:</strong> Enable "Use Collection URL" in connector</li>
                                    <li><strong>Authentication:</strong> Set connector auth type to "Inherit"</li>
                                    <li><strong>Variables:</strong> Collection variables are automatically available</li>
                                    <li><strong>Headers:</strong> Default headers are merged with connector-specific ones</li>
                                </ul>
                            </div>
                            
                            <div class="alert alert-warning" role="alert">
                                <h5><i class="fa fa-code" title="Code Example"/> Bulk Execution Example</h5>
                                <p>Execute all endpoints in this collection:</p>
                                <pre style="background: #f8f9fa; padding: 10px; border-radius: 4px; font-family: monospace;">
collection = env['api.collection'].browse(<field name="id" readonly="1"/>)
for connector in collection.connector_ids:
    result = connector.execute_call({
        'batch_id': batch.id,
        'timestamp': datetime.datetime.now().isoformat()
    })</pre>
                            </div>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- API Collection Tree View -->
    <record id="view_api_collection_tree" model="ir.ui.view">
        <field name="name">api.collection.tree</field>
        <field name="model">api.collection</field>
        <field name="arch" type="xml">
            <list string="API Collections" sample="1">
                <field name="name"/>
                <field name="base_url"/>
                <field name="auth_type"/>
                <field name="connector_count"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="success_rate" widget="percentage" 
                       decoration-success="success_rate >= 0.9"
                       decoration-warning="success_rate >= 0.7 and success_rate &lt; 0.9"
                       decoration-danger="success_rate &lt; 0.7"/>
                <field name="total_calls"/>
            </list>
        </field>
    </record>

    <!-- API Collection Search View -->
    <record id="view_api_collection_search" model="ir.ui.view">
        <field name="name">api.collection.search</field>
        <field name="model">api.collection</field>
        <field name="arch" type="xml">
            <search string="API Collections">
                <field name="name" string="Collection Name"/>
                <field name="base_url" string="Base URL"/>
                <field name="auth_type"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Authentication Type" name="group_auth_type" context="{'group_by': 'auth_type'}"/>
                    <filter string="Status" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- API Collection Action -->
    <record id="action_api_collection" model="ir.actions.act_window">
        <field name="name">API Collections</field>
        <field name="res_model">api.collection</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first API collection!
            </p>
            <p>
                Group related API endpoints together and share common configuration like base URL, authentication, and variables.
            </p>
        </field>
    </record>
    
    <!-- Import Configuration Action for Collections -->
    <record id="action_import_collection_config" model="ir.actions.act_window">
        <field name="name">Import Collection Configuration</field>
        <field name="res_model">import.config.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_config_type': 'collection'}</field>
    </record>
</odoo>
