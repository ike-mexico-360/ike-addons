<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Import Config Wizard Form -->
    <record id="view_import_config_wizard_form" model="ir.ui.view">
        <field name="name">import.config.wizard.form</field>
        <field name="model">import.config.wizard</field>
        <field name="arch" type="xml">
            <form string="Import API Configuration">
                <div class="alert alert-info" role="alert">
                    <h4><i class="fa fa-upload" title="Upload"/> Import Configuration</h4>
                    <p>Select a JSON configuration file exported from API Connector to import connectors or collections.</p>
                </div>
                
                <group>
                    <group string="File Selection">
                        <field name="config_file" filename="filename" required="1"/>
                        <field name="filename" invisible="1"/>
                        <field name="config_type" widget="radio"/>
                        <field name="collection_id" 
                               invisible="config_type != 'connector'"
                               options="{'no_create': True}"/>
                    </group>
                    
                    <group string="Preview" invisible="not preview_data">
                        <field name="preview_data" widget="text" readonly="1" nolabel="1"/>
                    </group>
                </group>
                
                <footer>
                    <button name="action_import" 
                            string="Import Configuration" 
                            type="object" 
                            class="btn-primary"/>
                    <button string="Cancel" 
                            class="btn-secondary" 
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Import Config Wizard Action -->
    <record id="action_import_config_wizard" model="ir.actions.act_window">
        <field name="name">Import Configuration</field>
        <field name="res_model">import.config.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
