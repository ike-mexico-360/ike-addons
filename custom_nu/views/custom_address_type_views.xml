<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View custom_address_type.py View List -->
    <record id="custom_nus_address_type_view_list" model="ir.ui.view">
        <field name="name">custom.nus.address.type.view.list</field>
        <field name="model">custom.address.type</field>
        <field name="arch" type="xml">
            <list edit="false" delete="false" duplicate="false">
                <field name="name"/>
                <field name="description" />
            </list>
        </field>
    </record>

    <!-- View custom_address_type.py form -->
    <record id="custom_nus_address_type_view_form" model="ir.ui.view">
        <field name="name">custom.nus.address.type.view.form</field>
        <field name="model">custom.address.type</field>
        <field name="arch" type="xml">
            <form string="Custom_address_type" edit="true" delete="false" duplicate="false">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <div class="oe_title" >
                        <label for="name" class="o_form_label_required"/>
                        <h1>
                            <field name="name" placeholder="Name..." readonly="disabled" />
                        </h1>
                    </div>
                    <label for="description"/>
                    <field name="description" readonly="disabled"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- View custom_address_type.py search -->
    <record id="custom_nus_address_type_view_search" model="ir.ui.view">
        <field name="name">custom.nus.address.type.view.search</field>
        <field name="model">custom.address.type</field>
        <field name="arch" type="xml">
            <search>
                <field name="disabled"/>
                <field name="name" string="Nombre" filter_domain="[('name', 'ilike', self)]"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]"/>
                <group expand="1" string="Group By">
                    <filter string="Name" name="name" domain="[]" context="{'group_by':'name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action custom_address_type -->
    <record id="custom_nus_address_type_action" model="ir.actions.act_window">
        <field name="name">Address types</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">custom.address.type</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_enabled': 1}</field>
    </record>
</odoo>
