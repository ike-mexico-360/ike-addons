<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_custom_nu" model="ir.module.category">
        <field name="name">Custom NUs</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_custom_nus_user" model="res.groups">
        <field name="name">User (Read Only)</field>
        <field name="category_id" ref="module_category_custom_nu"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_custom_nus_admin" model="res.groups">
        <field name="name">Administrator (No Delete)</field>
        <field name="category_id" ref="module_category_custom_nu"/>
        <field name="implied_ids" eval="[(4, ref('group_custom_nus_user'))]"/>
    </record>

    <record id="custom_master_catalog.custom_group_supplier_operational" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_custom_nus_user'))]"/>
    </record>
    <record id="custom_master_catalog.custom_group_event_coordinator" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_custom_nus_admin'))]"/>
    </record>
    <record id="custom_master_catalog.custom_group_ccc_boss" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_custom_nus_user'))]"/>
    </record>
    <record id="custom_master_catalog.custom_group_ccc_coordinator" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_custom_nus_user'))]"/>
    </record>
    <record id="custom_master_catalog.custom_group_commercial_supervisor" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_custom_nus_user'))]"/>
    </record>
    <record id="custom_master_catalog.custom_group_supplier_contralory" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_custom_nus_user'))]"/>
    </record>
    <record id="custom_master_catalog.custom_group_supplier_support" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_custom_nus_user'))]"/>
    </record>
</odoo>