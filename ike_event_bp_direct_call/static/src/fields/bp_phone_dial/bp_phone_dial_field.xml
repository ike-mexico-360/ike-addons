<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="ike_event_api.BPPhoneDialField">
        <div class="o_phone_content d-inline-flex w-100">
            <t t-if="props.readonly">
                <div class="d-flex flex-row gap-1">
                    <span t-esc="props.record.data[props.name]"/>
                    <button class="btn btn-link my-0 py-0" t-on-click="dialNumber" t-if="state.showDialIcon"><i class="fa fa-phone"/></button>
                </div>
            </t>
            <t t-else="">
                <input
                    class="o_input"
                    t-att-id="props.id"
                    type="tel"
                    autocomplete="off"
                    t-att-placeholder="props.placeholder"
                    t-ref="input"
                />
                <button class="btn btn-link my-0 py-0" t-on-click="dialNumber" t-if="state.showDialIcon"><i class="fa fa-phone"/></button>
            </t>
        </div>
    </t>

</templates>
