<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="res_config_settings_view_form_inherit_bp_direct_call" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.bp_direct_call</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="40"/>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@name='integration']" position="inside">
                    <setting id="x_bp_tenant" string="Tenant for use Bright Pattern services" groups="base.group_no_one">
                        <field name="x_bp_tenant"/>
                    </setting>
                    <setting id="x_bp_default_service" string="Default service for use Bright Pattern services" groups="base.group_no_one">
                        <field name="x_bp_default_service"/>
                    </setting>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
