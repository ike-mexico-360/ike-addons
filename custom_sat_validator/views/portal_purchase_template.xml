<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="ike_event_portal_my_purchase_order" name="Purchase Order Detail" inherit_id="purchase.portal_my_purchase_order">
        <xpath expr="//a[@id='print_invoice_report']" position="after">

            <div t-if="request.env.user.has_group('base.group_system') or request.env.user.has_group('ike_event_portal.custom_group_portal_finance')"
                 class="card p-3 mt-3 border rounded">

                <label class="form-label fw-bold">
                    Valid XML
                </label>

                <input type="file"
                    id="xml_file"
                    class="form-control mb-2"
                    accept=".xml"/>

                <button type="button"
                        id="validate_xml_btn"
                        class="btn btn-primary"
                        t-att-data-order-id="order.id"> Valid XML
                </button>

                <div id="xml_validation_result"
                    class="mt-3"/>

               <t t-set="cfdi_validators"
                    t-value="request.env['custom.sat.validator'].sudo().search(
                        [
                            ('purchase_id', '=', order.id),
                            ('sat_status' , '=', 'Vigente')

                        ],
                        order='create_date desc'
                )"/>

                <t t-if="cfdi_validators">

                    <hr class="my-3"/>

                    <h6>Vendor bill</h6>

                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>invoice</th>
                                <th>Action</th>
                                <th></th>
                            </tr>
                        </thead>

                        <tbody>
                            <t t-foreach="order.invoice_ids"
                            t-as="invoice"
                            t-key="invoice.id">

                                <tr>
                                    <td>
                                        <span t-out="invoice.display_name"/>
                                    </td>

                                    <td>
                                        <a t-attf-href="/my/purchase/download_cfdi_pdf2/#{invoice.id}"
                                        class="btn btn-success btn-sm"
                                        target="_blank">
                                            <i class="fa fa-file-pdf-o me-1"/>
                                            Download PDF
                                        </a>
                                    </td>

                                </tr>

                            </t>

                        </tbody>

                    </table>

                </t>

                <!-- Escenario 2: acaba de validar en esta sesión sin recargar (manejado por OWL via JS) -->
                <a id="download_cfdi_pdf_btn"
                   class="btn btn-success mt-2"
                   style="display:none;"
                   target="_blank">
                    <i class="fa fa-file-pdf-o me-1"/>
                    Download CFDI PDF
                </a>
            </div>
        </xpath>
    </template>
</odoo>