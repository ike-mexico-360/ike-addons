<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="helpdesk_config_setting_view" model="ir.ui.view">
        <field name="name">helpdesk.config.setting.view</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Helpdesk" data-string="Helpdesk Settings" name="sh_all_in_one_helpdesk">
                    <block title="Ticket Settings" name="ticket_setting_container">
                        <field name="company_id" invisible="1" />
                        <setting>
                            <field name="category" />
                        </setting>
                        <setting>
                            <field name="sub_category"  />
                        </setting>
                        <setting>
                            <field name="customer_rating" />
                        </setting>
                        <setting>
                            <field name="auto_close_ticket" />
                        </setting>
                        <setting invisible="auto_close_ticket == False">
                            <field name="close_days" required="auto_close_ticket == True" />
                        </setting>
                        <setting>
                            <field name="sh_file_size" />
                        </setting>
                        <setting>
                            <field name="enable_manual_add_timesheet" />
                        </setting>
                        <setting>
                            <field name="sh_default_team_id" />
                            <!-- <field name="sh_default_user_id_domain" invisible="1"/> -->
                        </setting>
                        <setting invisible="sh_default_team_id == False">
                            <field name="sh_default_user_id" required="sh_default_team_id != False" options="{ 'no_create': True}"/>
                            <!-- domain="sh_default_user_id_domain" required="sh_default_team_id != False"-->
                        </setting>
                    </block>
                    <block title="Ticket Stage Settings" name="ticket_stage_setting_container">
                        <setting>
                            <field name="new_stage_id"/>
                        </setting>
                        <setting>
                            <field name="reopen_stage_id"/>
                        </setting>
                        <setting>
                            <field name="cancel_stage_id"/>
                        </setting>
                        <setting>
                            <field name="done_stage_id"/>
                        </setting>
                        <setting>
                            <field name="close_stage_id"/>
                        </setting>
                        <setting>
                        </setting>
                        <setting>
                            <field name="sh_customer_replied"/>
                        </setting>
                        <setting>
                            <field name="sh_staff_replied"/>
                        </setting>
                        <setting invisible="sh_customer_replied == False">
                            <field name="sh_customer_replied_stage_id" required="sh_customer_replied == True" />
                        </setting>
                        <setting invisible="sh_staff_replied == False">
                            <field name="sh_staff_replied_stage_id" required="sh_staff_replied == True" />
                        </setting>
                    </block>
                    <block title="Ticket Mail Template Settings" name="ticket_mail_template_setting_container">
                        <setting>
                            <field name="allocation_mail_template_id"/>
                        </setting>
                        <setting>
                            <field name="reply_mail_template_id"/>
                        </setting>
                        <setting>
                            <field name="sh_receive_email_seeing_ticket"/>
                        </setting>
                        <setting>
                            <field name="access_for_everyone"/>
                        </setting>
                    </block>
                    <block title="Ticket Dashboard Settings" name="ticket_dashboard_setting_container">
                        <setting>
                            <field name="dashboard_filter" widget="many2many_tags" />
                        </setting>
                        <setting>
                            <field name="dashboard_tables" widget="many2many_tags" />
                        </setting>
                    </block>
                    <block title="Multi Users in Ticket Configuration" name="multi_user_in_ticket_setting_container">
                        <setting >
                            <field name="sh_display_multi_user" />
                        </setting>
                    </block>
                    <block title="Manage Products Inside Helpdesk Ticket" name="manage_product_helpdesk_setting_container">
                        <setting >
                            <field name="sh_configure_activate" />
                        </setting>
                    </block>
                    <block title="Helpdesk Ticket Reminder Configuration" name="helpdesk_ticket_reminder_setting_container">
                        <setting >
                            <field name="sh_display_ticket_reminder" />
                        </setting>
                    </block>
                    <block title="Helpdesk Ticket Send Whatsapp Configuration" name="helpdesk_ticket_send_whatsapp_setting_container">
                        <setting >
                            <field name="sh_ticket_product_detail" help="Show Ticket Product details in message"/>
                        </setting>
                        <setting >
                            <field name="sh_signature" help="Show Signature"/>
                        </setting>
                        <setting >
                            <field name="sh_display_in_chatter" help="Show Message in Chatter"/>
                        </setting>
                        <setting >
                            <field name="sh_pdf_in_message" help="Send Report Url in Message"/>
                        </setting>
                        <setting >
                            <field name="sh_ticket_url_in_message" help="Send Ticket Url in Message"/>
                        </setting>
                    </block>
                    <block title="Helpdesk Auto Add Followers Configuration" name="helpdesk_auto_add_followers_setting_container">
                        <setting>
                            <field name="sh_auto_add_customer_as_follower" />
                        </setting>
                    </block>
                    <block title="Ticket Notification Configuration" name="sh_ticket_notification_configuration">
                        <setting>
                            <field name="sh_send_notification_create" />
                        </setting>
                        <setting>
                            <field name="sh_send_notification_assign"  />
                        </setting>
                        <setting>
                            <field name="sh_send_notification_done" />
                        </setting>
                        <setting>
                            <field name="sh_send_notification_cancelled" />
                        </setting>
                    </block>
                    <block title="Customer Hour Package Configuration" name="sh_customer_hour_package_configuration">
                        <setting>
                            <field name="sh_allocated_hours" />
                        </setting>
                    </block>
                    <block title="Ticket Auto Followup Configuration" name="sh_ticket_auto_followup_configuration">
                        <setting>
                            <field name="sh_auto_followup_stage_id" />
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
    <record id="action_helpdesk_configuration" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'sh_all_in_one_helpdesk'}</field>
    </record>
    <menuitem id="menu_config_helpdesk" name="Settings" parent="sh_all_in_one_helpdesk.helpdesk_config_menu" sequence="11" action="action_helpdesk_configuration" groups="base.group_system,sh_all_in_one_helpdesk.helpdesk_group_manager" />
</odoo>