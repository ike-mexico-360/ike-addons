<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="sh_res_partner_view_partner_form_view" model="ir.ui.view">
		<field name="name">res.partner</field>
		<field name="model">res.partner</field>
		<field name="inherit_id" ref="base.view_partner_form" />
		<field name="arch" type="xml">

			<xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_partner_tickets" type="object" class="oe_stat_button" icon="fa-ticket" context="{'partner_id': id}" invisible="partner_ticket_count == 0">
                    <div class="o_stat_info">
                        <field name="partner_ticket_count" class="o_stat_value" />
                        <span class="o_stat_text">Tickets</span>
                    </div>
                </button>
            </xpath>

			<field name="category_id" position="after">
				<field name="sh_allocated_hours" />
			</field>
			<xpath expr="//notebook" position="inside">
				<page name="sh_hour_packages" string="Hour Packages">
					<field name="sh_custom_hour_package_line" readonly="1" >
						<!-- <list editable="bottom"> -->
						<list>
                            <field name="name" placeholder="Name..."/>
							<field name="partner_id" />
                            <field name="sh_package_date" />
                            <field name="sh_initial_allocated_hours" />
                            <field name="sh_rolled_over_hours" />
                        	<field name="sh_total_allocated_hours" />
                        	<field name="sh_hours_consumed" />
                        	<field name="sh_remaining_hours_at_month_end" />
						</list>
						<form string="Customer Hour Package">
							<header>
                    			<field name="state" widget="statusbar" />
                			</header>
                			<sheet>
								<div class="oe_title">
									<label for="name"/>
									<h1>
										<field name="name" placeholder="Name..." readonly="create_uid" />
									</h1>
								</div>
								<group>
									<group>
										<field name="partner_id" required='1' readonly="create_uid" />
										<field name="sh_package_date" widget="daterange" options='{"end_date_field": "sh_package_date_end", "always_range": "1"}' required="sh_package_date or sh_package_date_end" readonly="create_uid" />
										<field name="sh_package_date_end" invisible="1" required="sh_package_date" readonly="create_uid"/>

										<field name="sh_initial_allocated_hours" widget="timesheet_uom" readonly="create_uid" />
										<field name="sh_rolled_over_hours" widget="timesheet_uom" readonly="1" />
									</group>
									<group>
										<field name="sh_total_allocated_hours" widget="timesheet_uom" readonly="create_uid" />
										<field name="sh_hours_consumed" widget="timesheet_uom" />
										<field name="sh_remaining_hours_at_month_end" widget="timesheet_uom" />
									</group>
								</group>
							</sheet>
						</form>
					</field>
				</page>
			</xpath>
		</field>
	</record>

</odoo>