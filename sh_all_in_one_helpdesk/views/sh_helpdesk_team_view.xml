<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="sh_helpdesk_team_form_view" model="ir.ui.view">
        <field name="name">sh.helpdesk.team.form.view</field>
        <field name="model">sh.helpdesk.team</field>
        <field name="arch" type="xml">
            <form string="Helpdesk Team">
                <sheet>
                	<div class="oe_button_box" name="button_box" groups="sh_all_in_one_helpdesk.group_helpdesk_sla_policy">
						<button name="action_view_sla" type="object" class="oe_stat_button" icon="fa-ticket" invisible="sla_count == 0" groups="sh_all_in_one_helpdesk.group_helpdesk_sla_policy">
                            <!-- attrs="{'invisible':[('sla_count','=',0)]}"-->
		                    <div class="o_stat_info">
		                        <field name="sla_count" class="o_stat_value" />
		                        <span class="o_stat_text">Helpdesk SLA</span>
		                    </div>
		                </button>
					</div>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="sh_resource_calendar_id"/>
                            <!-- ========================================================== -->
                            <!-- alias_feature ADD ALIAS FIELD IN FORM VIEW-->
                            <!-- ========================================================== -->

                            <label for="alias_name" string="Email Alias"/>
                            <div class="oe_inline" name="alias_def">
		                        <field name="alias_id" class="oe_read_only oe_inline" string="Email Alias" required="0"/>
		                        <div class="oe_edit_only oe_inline" name="edit_alias" style="display: inline;">
		                            <div>
		                                <field name="alias_name" class="w-25" />@<field name="alias_domain_id" class="oe_inline"/>
		                            </div>
		                            <button icon="fa-arrow-right" type="action" name="%(base_setup.action_general_configuration)d" string="Configure a custom domain" class="p-0 btn-link" />
		                        </div>
		                    </div>
		                    <!-- <div class="oe_inline" name="alias_def">
		                        <field name="alias_id" class="oe_read_only oe_inline" string="Email Alias" required="0"/>
		                        <div class="oe_edit_only oe_inline" name="edit_alias" style="display: inline;">
		                            <div invisible="alias_domain == False" >

		                                <field name="alias_name" class="oe_inline"/>@<field name="alias_domain" class="oe_inline" readonly="1"/>
		                            </div>
		                            <button icon="fa-arrow-right" type="action" name="%(base_setup.action_general_configuration)d" string="Configure a custom domain" class="p-0 btn-link" invisible="alias_domain != False" />
		                        </div>
		                    </div> -->
                        </group>
                        <group>
                            <field name="team_head" />
                            <!-- # Auto Assign Ticket Feature -->
                            <field name="sh_auto_assign_user" />
                            <field name="sh_assign_ticket_method" invisible="not sh_auto_assign_user" required="sh_auto_assign_user"/>
                            <field name="sh_helpdesk_stages" invisible="sh_assign_ticket_method!='equal_open_ticket'" widget='many2many_tags' required="sh_assign_ticket_method=='equal_open_ticket'"/>
                            <field name="sh_assign_ticket_filter" widget="domain" options="{'model': 'sh.helpdesk.ticket'}" invisible="sh_assign_ticket_method!='filter'" required="sh_assign_ticket_method=='filter'"/>
                            <!-- # Auto Assign Ticket Feature -->
                        </group>
                    </group>
                    <notebook>
                        <page name="members" string="Team Members">
                            <field name="team_members" widget="many2many">
                                <kanban quick_create="false" create="true" delete="true">
                                    <field name="id" />
                                    <field name="name" />
                                    <templates>
                                        <t t-name="card" class="flex-row">
                                            <aside class="o_kanban_aside_full">
                                                <field name="avatar_128" class="o_kanban_image_fill w-100" widget="image" options="{'img_class': 'object-fit-cover'}" alt="Avatar" />
                                            </aside>
                                            <main class="ps-2 ps-md-0">
                                                <field name="name" class="fw-bold"/>
                                            </main>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="sh_helpdesk_team_tree_view" model="ir.ui.view">
        <field name="name">sh.helpdesk.team.tree.view</field>
        <field name="model">sh.helpdesk.team</field>
        <field name="arch" type="xml">
            <list string="Helpdesk Team">
                <field name="name" />
                <field name="team_head" />
            </list>
        </field>
    </record>
    <record id="sh_helpdesk_team_action" model="ir.actions.act_window">
        <field name="name">Helpdesk Team</field>
        <field name="res_model">sh.helpdesk.team</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">Create a New Team</p>
        </field>
    </record>
    <menuitem id="sh_helpdesk_team_menu" name="Helpdesk Teams" parent="sh_all_in_one_helpdesk.helpdesk_config_menu" action="sh_helpdesk_team_action" sequence="1" />
</odoo>
