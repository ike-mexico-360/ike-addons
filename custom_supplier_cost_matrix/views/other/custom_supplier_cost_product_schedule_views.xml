<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="custom_supplier_cost_product_schedule_view_search" model="ir.ui.view">
        <field name="name">custom_supplier_cost_product_schedule.view.search</field>
        <field name="model">custom.supplier.cost.product.schedule</field>
        <field name="arch" type="xml">
            <search string="">
                <field name="name"/>
                <field name="active"/>
                <field name="disabled"/>
                <field name="name"/>
                <field name="disabled"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
            </search>
        </field>
    </record>

    <record id="custom_supplier_cost_product_schedule_view_list" model="ir.ui.view">
        <field name="name">custom_supplier_cost_product_schedule.view.tree</field>
        <field name="model">custom.supplier.cost.product.schedule</field>
        <field name="arch" type="xml">
            <list string="Opening Hours" delete="0" duplicate="0" edit="0">
                <field name="name" required="1"/>
                <field name="start_time" widget="float_time" readonly="disabled"/>
                <field name="end_time" widget="float_time" readonly="disabled"/>
            </list>
        </field>
    </record>

    <record id="custom_supplier_cost_product_schedule_view_form" model="ir.ui.view">
        <field name="name">custom_supplier_cost_product_schedule.view.form</field>
        <field name="model">custom.supplier.cost.product.schedule</field>
        <field name="arch" type="xml">
            <form string="" duplicate="0" delete="0">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" class="w-100" readonly="disabled" options="{'no_translate': True}"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="start_time" widget="float_time" readonly="disabled"/>
                            <field name="end_time" widget="float_time" readonly="disabled"/>
                        </group>
                        <group invisible="1">
                            <field name="create_date" invisible="1"/>
                            <field name="disabled" invisible="1" />
                            <field name="active" invisible="1" />
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="custom_supplier_cost_product_schedule_action" model="ir.actions.act_window">
        <field name="name">Opening Hours</field>
        <field name="res_model">custom.supplier.cost.product.schedule</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('custom_supplier_cost_product_schedule_view_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('custom_supplier_cost_product_schedule_view_form')})]"/>
        <field name="search_view_id" ref="custom_supplier_cost_product_schedule_view_search"/>
        <field name="context">{'search_default_filter_enabled': 1}</field>
    </record>

</odoo>
