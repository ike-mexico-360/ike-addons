<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="custom_master_catalog.IntegerField">
        <div class="d-flex gap-1">
            <t t-if="props.readonly">
                <span>
                    <span t-esc="formattedValue"/>
                    <span t-if="postfixText" t-out="postfixText" class="flex-shrink-0"/>
                </span>
            </t>
            <t t-else="">
                <input
                    t-on-focusin="onFocusIn"
                    t-on-focusout="onFocusOut"
                    t-att-id="props.id"
                    t-ref="numpadDecimal"
                    t-att-placeholder="props.placeholder"
                    t-att-type="props.inputType"
                    inputmode="decimal"
                    class="o_input"
                    autocomplete="off"
                    t-att-step="props.step" />
                <span t-if="postfixText" t-out="postfixText" class="flex-shrink-0"/>
            </t>
        </div>
    </t>

    <t t-name="custom_master_catalog.FloatField">
        <div class="d-flex gap-1">
            <t t-if="props.readonly">
                <span>
                    <span t-esc="formattedValue"/>
                    <span t-if="postfixText" t-out="postfixText" class="flex-shrink-0"/>
                </span>
            </t>
            <t t-else="">
                <input
                    t-on-focusin="onFocusIn"
                    t-on-focusout="onFocusOut"
                    t-att-id="props.id"
                    t-ref="numpadDecimal"
                    t-att-placeholder="props.placeholder"
                    t-att-type="props.inputType"
                    inputmode="decimal"
                    class="o_input"
                    autocomplete="off"
                    t-att-step="props.step" />
                <span t-if="postfixText" t-out="postfixText" class="flex-shrink-0"/>
            </t>
        </div>
    </t>

</templates>
