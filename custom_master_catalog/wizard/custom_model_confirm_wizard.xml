<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="custom_model_confirm_wizard_view_form" model="ir.ui.view">
        <field name="name">custom.model.confirm.wizard.view.form</field>
        <field name="model">custom.model.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                        <field name="res_ids" invisible="1"/>
                        <field name="res_model" invisible="1"/>
                        <field name="reason"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn btn-danger rounded-4 py-1"
                        invisible="not context.get('is_confirm')"/>
                    <button name="action_confirm" string="Cancel" type="object" class="btn btn-danger rounded-4 py-1"
                        invisible="not context.get('is_cancel')"/>
                    <button name="action_confirm" string="Reject" type="object" class="btn btn-danger rounded-4 py-1"
                        invisible="not context.get('is_reject')"/>
                    <button string="Close" class="btn-secondary rounded-4 py-1" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
