<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- groups="" -->

    <record id="contacts.res_partner_menu_contacts" model="ir.ui.menu">
        <field name="action" eval="False"/>
    </record>

    <record id="contacts.menu_localisation" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('custom_erp_odoo')])]"/>
    </record>

    <!-- Menu Contacts -->
    <menuitem id="res_partner_menu_contacts_contacts"
        name="Contacts"
        action="contacts.action_contacts"
        groups="base.group_system"
        parent="contacts.res_partner_menu_contacts"
        sequence="1"/>

    <!-- Menu Clients-->
    <menuitem id="res_partner_menu_clients_root"
        name="Clients"
        sequence="20"
        web_icon="custom_master_catalog,static/description/client.png"
        groups="base.group_user"/>

    <!-- Sub-menu Clients -->
    <menuitem id="res_partner_menu_clients"
        name="Clients"
        parent="res_partner_menu_clients_root"
        sequence="1">
        <menuitem id="res_partner_client_menu_clients"
            name="Clients"
            action="res_partner_client_action_window"
            sequence="1"/>
        <menuitem id="res_partner_account_menu_account"
            name="Accounts"
            action="res_partner_account_action_window"
            sequence="2"/>
    </menuitem>

    <!-- Sub-menu Config -->
    <menuitem id="res_partner_menu_clientes_config"
        name="Configuration"
        parent="res_partner_menu_clients_root"
        sequence="2"/>

    <menuitem id="res_partner_menu_account_config"
        name="Accounts"
        parent="res_partner_menu_clientes_config"
        sequence="1">
        <menuitem id="res_partner_menu_account_type_config"
            name="Accounts Types"
            action="custom_account_type_action"
            sequence="1"/>
        <menuitem id="res_partner_menu_account_identification_config"
            name="Account Identifications"
            action="custom_account_identification_action"
            sequence="2"/>
    </menuitem>

    <!-- Menu Suppliers -->
    <menuitem name="Suppliers"
        id="menu_suppliers"
        sequence="21"
        web_icon="custom_master_catalog,static/description/supplier.png"
        groups="base.group_user"/>

    <!-- Sub-menu Suppliers -->
    <menuitem id="res_partner_menu_suppliers"
        name="Suppliers"
        parent="menu_suppliers"
        groups="base.group_system"
        sequence="5">
        <menuitem id="res_partner_submenu_suppliers"
            action="res_partner_supplier_action_window"
            name="Suppliers"
            sequence="5"/>
        <menuitem id="res_partner_menu_supplier_centers"
            name="Care centers"
            action="res_partner_supplier_center_action_window"
            sequence="10"/>
        <menuitem id="custom_supplier_coverage_configuration_menu"
            action="custom_supplier_coverage_configuration_action"
            name="Configuration of Services and Subservices"
            sequence="15"/>
        <menuitem id="custom_fleet_vehicle_menu"
            action="custom_fleet_vehicle_action"
            name="Service vehicles"
            sequence="20"/>
        <menuitem id="custom_supplier_cost_matrix_configuration_menu"
            action="custom_supplier_cost_matrix_configuration_action"
            name="Supplier Cost Matrix Configuration"
            sequence="25"/>
    </menuitem>

    <!-- Sub-menu Config -->
    <menuitem id="res_partner_menu_suppliers_config"
        name="Configuration"
        parent="menu_suppliers"
        groups="base.group_system"
        sequence="10">
        <menuitem id="res_partner_menu_supplier_type"
            action="custom_master_catalog.custom_supplier_type_action"
            name="Supplier Types"
            sequence="5"/>
        <menuitem id="res_partner_menu_payment_term"
            action="custom_payment_type_action"
            name="Payment Types"
            sequence="10"/>
        <menuitem id="custom_vehicle_type_menu"
            name="Types of service vehicles"
            action="custom_vehicle_type_action"
            sequence="15"/>
        <menuitem id="custom_supplier_types_statuses_menu"
            name="Types of supplier status"
            action="custom_supplier_types_statuses_action"
            sequence="17"/>
        <menuitem id="custom_ike_concepts_product_view_menu"
            name="Concepts"
            action="custom_ike_concepts_product_action_server"
            sequence="20"/>
        <menuitem id="custom_vehicle_accessories_menu"
            name="Accessories"
            action="custom_ike_accessories_product_action_server"
            sequence="25"/>
    </menuitem>

    <!-- Menu Vehicles -->
    <menuitem id="vehicles_menu_root"
        name="Vehicles"
        sequence="23"
        web_icon="custom_master_catalog,static/description/vehicle.png"
        groups="base.group_user"/>

    <!-- Sub-menu Config -->
    <menuitem id="vehicles_config_menu"
        name="Configuration catalogs"
        parent="vehicles_menu_root"
        groups="base.group_system"
        sequence="5">
        <menuitem id="res_partner_menu_fleet_vehicle_models"
            action="custom_fleet_vehicle_model_action"
            name="Fleet Vehicle Models"
            sequence="5"/>
        <menuitem id="custom_fleet_vehicle_model_category_menu"
            name="Vehicle categories"
            action="custom_fleet_vehicle_model_category_action"
            sequence="10"/>
    </menuitem>

    <!-- Menu Configuration -->
    <menuitem id="configuration_menu_root"
        name="Configuration"
        sequence="24"
        web_icon="custom_master_catalog,static/description/configuration.png"
        groups="base.group_user"/>

    <menuitem id="res_partner_menu_type_event"
        action="custom_type_event_action"
        name="Types Events"
        parent="configuration_menu_root"
        sequence="5"/>

    <!-- Sub-menu Config -->
    <menuitem id="res_partner_menu_geographical_zones"
        name="Geographical Zones"
        parent="configuration_menu_root"
        groups="base.group_system"
        sequence="10">
        <menuitem id="res_menu_country"
            name="Countries"
            action="custom_ike_action_country"
            sequence="5"/>
        <menuitem id="res_menu_country_state"
            name="States"
            action="custom_ike_action_country_state"
            sequence="10"/>
        <menuitem id="res_menu_country_group"
            name="Country group"
            action="base.action_country_group"
            sequence="15"/>
        <menuitem id="custom_state_municipality_menu"
            name="Geographical Zones"
            action="custom_state_municipality_action"
            sequence="20"/>
        <menuitem id="custom_import_postal_codes_sepomex_menu"
            name="Import Postal Codes"
            action="custom_import_postal_codes_action"
            sequence="25"/>
    </menuitem>

</odoo>
