<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_x_subservice_product_template_filter" model="ir.ui.view">
        <field name="name">x_subservice.product.product.search</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Subservice" filter_domain="['|', ('default_code', 'ilike', self), ('name', 'ilike', self)]"/>
                <field name="categ_id" string="Service" filter_domain="[('categ_id.name', 'ilike', self)]"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <group expand="0" string="Group By">
                    <filter name="groupby_categ_id" string="Service" context="{'group_by': 'categ_id'}" />
                </group>
            </search>
        </field>
    </record>
    <record id="view_x_subservice_product_template_form" model="ir.ui.view">
        <field name="name">x_subservice.view_form</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <form delete="0" duplicate="0">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <div class="oe_title w-75">
                        <label for="name" class="o_form_label_required"/>
                        <h1>
                            <field name="name" options="{'line_breaks': False}" widget="text" class="text-break"
                                default_focus="1" required="1" readonly="disabled"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="x_categ_domain" invisible="1"/>
                            <field name="categ_id" options='{"no_open": True, "no_create": True}' required="1"
                                            domain="x_categ_domain"
                                            context="{'list_view_ref': 'custom_master_catalog.product_category_service_view_list'}"/>
                            <field name="x_description" readonly="disabled" widget="text"/>
                            <field name="x_min_required_photos"/>
                            <field name="create_date" invisible="1"/>
                            <field name="disabled" invisible="1" />
                            <field name="active" invisible="1" />
                            <field name="x_concepts_domain" invisible="1"/>
                            <field name="x_concepts_ids"
                                options="{'no_open': True, 'no_create': True}"
                                domain="x_concepts_domain"
                                widget="many2many_tags"
                                context="{
                                    'list_view_ref': 'custom_master_catalog.custom_ike_concepts_product_template_list',
                                    'form_view_ref': 'custom_master_catalog.custom_ike_concepts_product_template_form',
                                    'search_view_ref': 'custom_master_catalog.custom_ike_concept_product_template_filter',
                                    'hide_disabled_enabled_filters': 1,
                                }"
                                />
                        </group>
                    </group>
                    <notebook>
                        <page name="x_concepts" string="Concepts">
                            <group>
                                <field name="concept_line_ids" nolabel="1" readonly="disabled == True" class="my-1">
                                    <list editable="bottom" decoration-muted="disabled == True" delete="0" create="1"
                                          context="{'form_view_ref': 'custom_master_catalog.custom_geographical_area_product_view_form'}">
                                        <field name="concepts_domain" column_invisible="1"/>
                                        <field name="categ_id" column_invisible="1"/>
                                        <field name="event_type_id" required="1"/>
                                        <field name="base_concept_id" required="1" domain="concepts_domain"/>
                                        <field name="concepts_ids" widget="many2many_tags" domain="concepts_domain"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_x_subservice_product_template_list" model="ir.ui.view">
        <field name="name">x_subservice.view.list</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <list delete="0" edit="0" duplicate="0">
                <field name="name" string="Subservice" required="1"/>
                <field name="description" readonly="1"/>
                <field name="categ_id" string="Service" required="1"/>
                <field name="create_date" column_invisible="1"/>
                <field name="disabled" column_invisible="1" />
            </list>
        </field>
    </record>
    <record id="action_x_subservice_product_template_view" model="ir.actions.act_window">
        <field name="name">Subservices</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">list,form</field>
        <field name="path">subservices</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_x_subservice_product_template_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_x_subservice_product_template_form')})]"/>
        <field name="search_view_id" ref="view_x_subservice_product_template_filter"/>
        <field name="domain" eval="[
            ('sale_ok', '=', True),
            ('sh_product_subscribe', '=', True),
            ('purchase_ok', '=', False),
            ('x_accessory_ok', '=', False),
            ('type', '=', 'service'),
            ('list_price', '=', 1),
            ('standard_price', '=', 0),
            ('uom_id', '=', ref('l10n_mx.product_uom_service_unit')),
        ]"/> <!-- To be set in action.server -->
        <field name="context" eval="{
            'default_sale_ok': True,
            'default_sh_product_subscribe': True,
            'default_purchase_ok': False,
            'default_x_accessory_ok': False,
            'default_type': 'service',
            'default_list_price': 1,
            'default_standard_price': 0,
            'default_categ_id': False,
            'default_uom_id': ref('l10n_mx.product_uom_service_unit'),
            'x_subservice_view': True,
            'search_default_filter_enabled': 1,
        }"/>
        <field name="target">current</field>
    </record>

    <record id="x_subservice_product_template_view_action_server" model="ir.actions.server">
        <field name="name">Subservices</field>
        <field name="model_id" ref="model_product_product"/>
        <field name="state">code</field>
        <field name="code">
action = model.get_subservices_view_action()
        </field>
    </record>

</odoo>
