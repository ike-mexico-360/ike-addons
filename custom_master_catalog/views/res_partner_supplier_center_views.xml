<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="res_partner_supplier_center_view_search" model="ir.ui.view">
        <field name="name">res.partner.supplier.center.view.search</field>
        <field name="model">res.partner</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Center of attention"/>
                <field name="parent_id" string="Supplier"/>
                <field name="x_parent_vat"/>
                <field name="phone"/>
                <field name="email"/>
                <filter string="México" name="filter_by_mexico" domain="[('country_id.code', '=', 'MX')]"/>
                <separator/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]"/>
                <separator/>
                <group expand="1" string="Group By">
                    <filter string="Supplier" name="group_by_parent_id" domain="[]" context="{'group_by':'parent_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <!-- List View -->
    <record id="res_partner_supplier_center_view_list" model="ir.ui.view">
        <field name="name">res.partner.supplier.center.view.list</field>
        <field name="model">res.partner</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <list delete="0" edit="0" duplicate="0" import="0" decoration-muted="not active or disabled">
                <field name="name" string="Center of attention"/>
                <field name="parent_id" string="Supplier"/>
                <field name="x_parent_business_name" string="Supplier Business Name"/>
                <field name="x_parent_vat" string="Supplier VAT"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="disabled" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="res_partner_supplier_center_view_form" model="ir.ui.view">
        <field name="name">res.partner.supplier.center.view.form</field>
        <field name="model">res.partner</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <form string="Partners" delete="0" duplicate="0">
                <header>
                    <field name="company_type" invisible="1" readonly="1" />
                    <field name="is_company" invisible="1" readonly="1" />
                    <field name="disabled" invisible="1" />
                    <field name="active" invisible="1" readonly="1"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_cost_matrix_view"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-dollar"
                                >
                            <field name="x_cost_matrix_ids" widget="statinfo"
                                    string="Cost Matrix"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <field name="image_1920" widget='image' class="oe_avatar" options='{"preview_image": "avatar_128"}'/>
                    <div class="oe_title mb24">
                        <h1>
                            <field id="company" options="{'line_breaks': False}" widget="text" class="text-break" name="name" default_focus="1" placeholder="e.g. Lumber Inc" required="1" readonly="disabled == True"/>
                        </h1>
                        <label for="parent_id" string="Supplier"/>
                        <div class="o_row">
                            <field name="parent_id" readonly="disabled == True"
                                widget="res_partner_many2one"
                                placeholder="Supplier Name..."
                                domain="[('is_company', '=', True), ('x_is_supplier', '=', True), ('disabled', '=', False)]"
                                context="{'form_view_ref': 'custom_master_catalog.res_partner_supplier_view_form', 'list_view_ref': 'custom_master_catalog.res_partner_supplier_view_list'}"
                                options="{'no_create': True, 'no_open': True, 'no_create_edit': True}"
                                required="1"/>
                        </div>
                        <label for="x_parent_business_name" string="Supplier Business Name"/>
                        <h2 class="row">
                            <field name="x_parent_business_name" readonly="disabled == True"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="ref" string="Supplier Center Number" readonly="disabled == True or ref" invisible="1"/>
                            <field name="id" string="Supplier Center Number" readonly="1" invisible="not id"/>
                            <field name="x_parent_vat" string="Supplier VAT" readonly="disabled == True"/>
                            <label for="street" string="Address"/>
                            <div class="o_address_format">
                                <field name="street" placeholder="Street..." class="o_address_street" readonly="disabled == True"/>
                                <field name="street2" placeholder="Street 2..." class="o_address_street" readonly="disabled == True"/>
                                <div class="o_address_street">
                                    <field name="l10n_mx_edi_colony" placeholder="Colony..." style="flex: 2 1 auto" readonly="disabled == True"/>
                                </div>
                                <field name="city" placeholder="City" class="o_address_city" readonly="disabled == True"/>
                                <field name="state_id" class="o_address_state" placeholder="State"
                                       options="{'no_open': True, 'no_create': True}"
                                       context="{'default_country_id': country_id, 'list_view_ref': 'custom_master_catalog.custom_ike_view_country_state_tree'}"
                                       readonly="disabled == True"/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip" readonly="disabled == True"/>
                                <field name="country_id" placeholder="Country" class="o_address_country"
                                       options="{'no_open': True, 'no_create': True}" readonly="disabled == True"
                                       context="{'list_view_ref': 'custom_master_catalog.custom_ike_view_country_tree'}"/>
                            </div>
                        </group>
                        <group>
                            <field name="phone" required="1" readonly="disabled == True"/>
                            <field name="mobile" readonly="disabled == True"/>
                            <field name="email" context="{'gravatar_image': True}" readonly="disabled == True"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="x_geographical_areas" string="Geographical Coverage Areas">
                            <group>
                                <field name="x_allowed_product_ids" invisible="1"/>
                                <widget name="custom_municipality_selection" field_name="x_geographical_area_ids" readonly="disabled == True" colspan="2"/>
                                <field name="x_geographical_area_ids" nolabel="1" readonly="not x_allowed_product_ids or disabled == True">
                                    <list editable="bottom" decoration-muted="disabled == True"
                                          context="{'form_view_ref': 'custom_master_catalog.custom_geographical_area_product_view_form'}">
                                        <field name="partner_id" column_invisible="1"/>
                                        <field name="country_id" options="{'no_create': 1}"/>
                                        <field name="state_id" domain="['|', ('country_id', '=', country_id), ('disabled', '=', country_id)]" options="{'no_open': True, 'no_create': 1}"/>
                                        <field name="municipality_id" domain="['|', ('state_id', '=', state_id), ('disabled', '=', state_id)]" options="{'no_create': 1}"/>
                                        <!-- <field name="field_char"/>
                                        <field name="field_float"/> -->
                                        <field name="area_product_ids" widget="many2many_tags"
                                               domain="[('geographical_area_id', '=', id)]"
                                               options="{'color_field': 'color_computed'}"
                                               readonly="1" force_save="1">
                                            <list>
                                                <field name="product_id"/>
                                                <field name="color"/>
                                                <field name="color_computed"/>
                                                <field name="disabled"/>
                                            </list>
                                        </field>
                                        <button name="action_edit" string="Edit Sub-Services" type="object" class="btn-secondary" icon="fa-edit"/>
                                        <field name="disabled" optional="hide"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <!-- Action -->
    <data>
        <record id="res_partner_supplier_center_action_window" model="ir.actions.act_window">
            <field name="name">Supplier Center</field>
            <field name="path">supplier-center</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="res_partner_supplier_center_view_search"/>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('res_partner_supplier_center_view_list')}),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('custom_master_catalog.custom_res_partner_view_kanban')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('res_partner_supplier_center_view_form')})]"/>
            <field name="domain">[('parent_id.x_is_supplier', '=', True), ('type', '=', 'center')]</field>
            <field name="context">
                {
                    'default_company_type': 'company',
                    'default_is_company': True,
                    'default_type': 'center',
                    'x_supplier_center_view': True,
                    'search_default_filter_enabled': 1
                }
            </field>
        </record>
    </data>
</odoo>
