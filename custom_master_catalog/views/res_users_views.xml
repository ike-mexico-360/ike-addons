<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="custom_view_users_search" model="ir.ui.view">
        <field name="name">custom.view.users.search</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <search string="Users">
                <field name="name" filter_domain="[('name','ilike',self)]" string="User"/>
            </search>
        </field>
    </record>

    <record id="custom_view_users_list" model="ir.ui.view">
        <field name="name">custom.view.users.list</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list edit="false" create="false" delete="false" >
                <field name="name" readonly="1"/>
            </list>
        </field>
    </record>
</odoo>