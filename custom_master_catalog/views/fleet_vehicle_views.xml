<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="custom_fleet_vehicle_view_search" model="ir.ui.view">
        <field name="name">custom_fleet_vehicle.view.search</field>
        <field name="model">fleet.vehicle</field>
        <field name="arch" type="xml">
            <search string="">
                <field name="license_plate"/>
                <field name="model_id"/>
                <field name="x_vehicle_type"/>
                <field name="x_product_category_id"/>
                <field name="x_product_id"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <group expand="1" string="Group By">
                    <filter string="Model" name="group_by_model_id" domain="[]" context="{'group_by':'model_id'}"/>
                    <filter string="Service" name="group_by_x_product_category_id" domain="[]" context="{'group_by':'x_product_category_id'}"/>
                    <filter string="Subservice" name="group_by_x_product_id" domain="[]" context="{'group_by':'x_product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="custom_fleet_vehicle_view_tree" model="ir.ui.view">
        <field name="name">custom_fleet_vehicle.view.tree</field>
        <field name="model">fleet.vehicle</field>
        <field name="arch" type="xml">
            <list string="" delete="0" edit="0">
                <field name="license_plate"/>
                <field name="model_id"/>
                <field name="x_vehicle_type"/>
                <field name="x_product_category_id"/>
                <field name="x_product_id"/>
                <field name="x_federal_license_plates"/>
            </list>
        </field>
    </record>

    <record id="custom_fleet_vehicle_view_form" model="ir.ui.view">
        <field name="name">custom_fleet_vehicle.view.form</field>
        <field name="model">fleet.vehicle</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <form string="Vehicle" js_class="fleet_form" delete="0">
                <field name="service_activity" invisible="1"/>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <field name="company_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="country_code" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <field name="image_128" widget='image' class="oe_avatar" readonly="disabled"/>
                    <div class="oe_title">
                        <label for="model_id"/>
                        <h1>
                            <field name="model_id" placeholder="e.g. Model S" class="w-100" readonly="disabled" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                                context="{'form_view_ref': 'custom_master_catalog.custom_fleet_vehicle_model_view_form'}"/>
                        </h1>
                    </div>
                    <group class="mt-3">
                        <group>
                            <field name="x_partner_id" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}" domain="[('x_is_supplier', '=', True), ('disabled', '=', False)]" string="Supplier"
                                context="{'form_view_ref': 'custom_master_catalog.res_partner_supplier_view_form', 'list_view_ref': 'custom_master_catalog.res_partner_supplier_view_list', 'search_view_ref': 'custom_master_catalog.res_partner_supplier_view_search', 'hide_disabled_enabled_filters': 1}"
                                readonly="disabled"/>
                            <field name="x_vehicle_type" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                                context="{'list_view_ref': 'custom_master_catalog.custom_vehicle_type_view_list'}" readonly="disabled"
                                domain="[('disabled', '=', False)]"/>
                            <field name="license_plate" placeholder="e.g. PAE 326" readonly="disabled"/>
                            <field name="x_federal_license_plates" readonly="disabled"/>
                            <field name="x_maneuvers" readonly="disabled"/>
                            <field name="x_accessories" invisible="x_maneuvers == False" widget="many2many_tags"
                                readonly="disabled" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                                context="{'list_view_ref': 'custom_master_catalog.custom_ike_accessories_view_tree'}"
                                domain="[('disabled', '=', False)]"/>
                        </group>
                        <group>
                            <field name="x_product_category_id" readonly="1" context="{'form_view_ref': 'custom_master_catalog.product_category_service_view_form'}"
                                options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                            <field name="x_product_id" readonly="1" context="{'form_view_ref': 'custom_master_catalog.view_x_subservice_product_template_form'}"
                                options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                            <field name="x_category_ids" widget="many2many_tags" readonly="1"/>
                        </group>
                    </group>
                    <group invisible="1">
                        <field name="create_date" invisible="1"/>
                        <field name="disabled" invisible="1" />
                        <field name="active" invisible="1" />
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id='custom_fleet_vehicle_action' model='ir.actions.act_window'>
        <field name="name">Vehicles</field>
        <field name="res_model">fleet.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="custom_fleet_vehicle_view_search"/>
        <field name="domain">[]</field>
        <field name="context">{'search_default_filter_enabled': 1}</field>
        <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('custom_fleet_vehicle_view_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('custom_fleet_vehicle_view_form')})]"/>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Ready to manage your fleet more efficiently?
          </p><p>
            Let's create your first vehicle.
          </p>
        </field>
    </record>

</odoo>
