<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="res_partner_supplier_view_search" model="ir.ui.view">
        <field name="name">res.partner.supplier.view.search</field>
        <field name="model">res.partner</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Nombre" filter_domain="['|', ('vat', 'ilike', self), ('name', 'ilike', self)]"/>
                <field name="disabled"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
            </search>
        </field>
    </record>
    <!-- List View -->
    <record id="res_partner_supplier_view_list" model="ir.ui.view">
        <field name="name">res.partner.supplier.view.list</field>
        <field name="model">res.partner</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <list delete="0" edit="0" duplicate="0">
                <field name="id" string="Supplier number" readonly="1"/>
                <field name="name" string="Nombre comercial"/>
                <field name="vat"/>
                <field name="disabled" column_invisible="1"/>
            </list>
        </field>
    </record>
    <!-- Form View -->
    <record id="res_partner_supplier_view_form" model="ir.ui.view">
        <field name="name">res.partner.supplier.view.form</field>
        <field name="model">res.partner</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <form string="Partners" delete="0" duplicate="0">
                <div class="alert alert-warning oe_edit_only" role="alert" name="warning_company" invisible="not same_company_registry_partner_id">
                  A partner with the same <span><field name="company_registry_label"/></span> already exists (<field name="same_company_registry_partner_id" context="{'show_address': False, 'show_vat': False}"/>), are you sure you want to create a new one?
                </div>
                <header>
                    <field name="x_is_supplier" invisible="1"/>
                    <field name="disabled" invisible="1"/>
                    <field name="active" invisible="1"/>
                    <field name="create_date" invisible="1"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <field name="image_1920" widget='image' class="oe_avatar" options='{"preview_image": "avatar_128"}'/>
                    <div class="oe_title mb24">
                        <label for="name" string="Nombre comercial"/>
                        <h2 class="row">
                            <field name="name" required="1" string="Nombre comercial" readonly="disabled == True"/>
                        </h2>
                        <label for="x_business_name"/>
                        <div class="row">
                            <field name="x_business_name" required="1" readonly="disabled == True"/>
                        </div>
                    </div>
                    <group>
                        <group>
                            <field name="id" string="Supplier number" invisible="not id" readonly="1"/>
                            <field name="vat" required="1" readonly="disabled == True"/>
                            <label for="street" string="Address"/>
                            <div class="o_address_format">
                                <field name="street" placeholder="Street..." class="o_address_street" readonly="disabled == True"/>
                                <field name="street2" placeholder="Street 2..." class="o_address_street" readonly="disabled == True"/>
                                <div class="o_address_street">
                                    <field name="l10n_mx_edi_colony" placeholder="Colony..." style="flex: 2 1 auto" readonly="disabled == True"/>
                                </div>
                                <field name="city" placeholder="City" class="o_address_city" readonly="disabled == True"/>
                                <field name="state_id" class="o_address_state" placeholder="State" readonly="disabled == True"
                                       options="{'no_open': True, 'no_create': True}"
                                       context="{'default_country_id': country_id}"/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip" readonly="disabled == True"/>
                                <field name="country_id" placeholder="Country" class="o_address_country" readonly="disabled == True"
                                       options='{"no_open": True, "no_create": True}'/>
                            </div>
                        </group>
                        <group>
                            <field name="phone" readonly="disabled == True"/>
                            <field name="mobile" readonly="disabled == True"/>
                            <field name="email" readonly="disabled == True"/>
                            <field name="x_supplier_type_id"
                                domain="[('disabled', '=', False)]"
                                options='{"no_open": True, "no_create": True}' readonly="disabled == True"/>
                            <field name="x_payment_type_id"
                                domain="[('disabled', '=', False)]"
                                options='{"no_open": True, "no_create": True}' readonly="disabled == True"/>
                            <field name="x_ref_sap" readonly="disabled == True"/>

                        </group>
                    </group>
                    <notebook>
                        <page name="x_centers" string="Supplier Centers">
                            <field name="x_supplier_center_ids" mode="kanban" nolabel="1" delete="0"
                                readonly="disabled == True"
                                context="{
                                    'kanban_view_ref': 'custom_master_catalog.custom_res_partner_view_kanban',
                                    'form_view_ref': 'custom_master_catalog.res_partner_supplier_center_view_form',
                                    'default_is_company': True,
                                    'default_company_type': 'company',
                                    'default_type': 'center',
                                    'default_parent_id': id,
                                    'default_street': street,
                                    'default_street2': street2,
                                    'default_city': city,
                                    'default_state_id': state_id,
                                    'default_zip': zip,
                                    'default_country_id': country_id,
                                    'default_lang': lang,
                                    'default_user_id': user_id,
                                }" />
                        </page>
                        <page name="x_geographical_areas" string="Geographical Coverage Areas">
                            <group>
                                <field name="x_allowed_product_ids" invisible="1"/>
                                <widget name="custom_municipality_selection" field_name="x_geographical_area_ids" readonly="disabled == True" colspan="2"/>
                                <field name="x_geographical_area_ids" nolabel="1" readonly="not x_allowed_product_ids or disabled == True">
                                    <list editable="bottom" decoration-muted="disabled == True"
                                          context="{'form_view_ref': 'custom_master_catalog.custom_geographical_area_product_view_form'}">
                                        <field name="partner_id" column_invisible="1"/>
                                        <field name="country_id" options="{'no_create': 1}"/>
                                        <field name="state_id" domain="['|', ('country_id', '=', country_id), ('disabled', '=', country_id)]" options="{'no_create': 1}"/>
                                        <field name="municipality_id" domain="['|', ('state_id', '=', state_id), ('disabled', '=', state_id)]" options="{'no_create': 1}"/>
                                        <field name="area_product_ids" widget="many2many_tags"
                                               domain="[('geographical_area_id', '=', id)]"
                                               options="{'color_field': 'color_computed'}"
                                               readonly="1" force_save="1">
                                            <list>
                                                <field name="product_id"/>
                                                <field name="color"/>
                                                <field name="color_computed"/>
                                                <field name="disabled"/>
                                            </list>
                                        </field>
                                        <button name="action_edit" string="Edit Sub-Services" type="object" class="btn-secondary" icon="fa-edit"/>
                                        <field name="disabled" optional="hide"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <!-- Action -->
    <data>
        <record id="res_partner_supplier_action_window" model="ir.actions.act_window">
            <field name="name">Supplier</field>
            <field name="path">suppliers</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="res_partner_supplier_view_search"/>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('res_partner_supplier_view_list')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('res_partner_supplier_view_form')})]"/>
            <field name="domain">[('x_is_supplier', '=', True)]</field>
            <field name="context">
                {
                    'default_company_type': 'company',
                    'default_is_company': True,
                    'default_x_is_supplier': True,
                    'x_supplier_view': True,
                    'search_default_filter_enabled': 1,
                }
            </field>
        </record>
    </data>
</odoo>
