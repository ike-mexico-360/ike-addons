<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="custom_fleet_vehicle_model_view_search" model="ir.ui.view">
        <field name="name">custom_fleet_vehicle_model.view.search</field>
        <field name="model">fleet.vehicle.model</field>
        <field name="arch" type="xml">
            <search string="">
                <field name="name"/>
                <field name="brand_id"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <group expand="1" string="Group By">
                    <filter string="Brand" name="group_by_brand_id" domain="[]" context="{'group_by':'brand_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="custom_fleet_vehicle_model_view_tree" model="ir.ui.view">
        <field name="name">custom_fleet_vehicle_model.view.tree</field>
        <field name="model">fleet.vehicle.model</field>
        <field name="arch" type="xml">
            <list string="" delete="0" edit="0" duplicate="0">
                <field name="name"/>
                <field name="brand_id"/>
            </list>
        </field>
    </record>

    <record id="custom_fleet_vehicle_model_view_form" model="ir.ui.view">
        <field name="name">custom_fleet_vehicle_model.view.form</field>
        <field name="model">fleet.vehicle.model</field>
        <field name="priority" eval="50"/>
        <!-- <field name="mode">primary</field> -->
        <field name="arch" type="xml">
            <form string="" delete="0" duplicate="0">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <field name="image_128" widget='image' class="oe_avatar" readonly="disabled"/>
                    <div class="oe_title">
                        <label for="name" class="o_form_label_required"/>
                        <h1>
                            <field name="name" placeholder="e.g. Model S" readonly="disabled"/>
                        </h1>
                        <label for="brand_id" class="o_form_label_required"/>
                        <h2>
                            <field name="brand_id" placeholder="e.g. Tesla" readonly="disabled" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                                context="{'list_view_ref': 'custom_master_catalog.custom_fleet_vehicle_model_brand_view_tree', 'form_view_ref': 'custom_master_catalog.custom_fleet_vehicle_model_brand_view_form'}"/>
                        </h2>
                        <label for="x_vehicle_weight_category_id"/>
                        <h3>
                            <field name="x_vehicle_weight_category_id" readonly="disabled" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                        </h3>
                    </div>
                    <group invisible="1">
                        <field name="create_date" invisible="1"/>
                        <field name="disabled" invisible="1" />
                        <field name="active" invisible="1" />
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_fleet_vehicle_model_form_inherit_weight_category_form" model="ir.ui.view">
        <field name="name">view.fleet.vehicle.model.inherit.weight.category.form</field>
        <field name="model">fleet.vehicle.model</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_model_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="x_vehicle_weight_category_id" readonly="disabled" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
            </xpath>
        </field>
    </record>

    <record id="custom_fleet_vehicle_model_action" model="ir.actions.act_window">
        <field name="name">Fleet Vehicle Model</field>
        <field name="res_model">fleet.vehicle.model</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="custom_fleet_vehicle_model_view_search"/>
        <field name="domain">[]</field>
        <field name="context">{'search_default_filter_enabled': 1}</field>
        <field name="path">vehicle_model</field>
        <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('custom_fleet_vehicle_model_view_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('custom_fleet_vehicle_model_view_form')})]"/>
    </record>

</odoo>
