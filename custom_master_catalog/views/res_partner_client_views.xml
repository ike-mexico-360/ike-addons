<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="res_partner_client_view_search" model="ir.ui.view">
        <field name="name">res.partner.client.view.search</field>
        <field name="model">res.partner</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Nombre" filter_domain="['|', ('vat', 'ilike', self), ('name', 'ilike', self)]"/>
                <field name="id" string="Customer number"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
            </search>
        </field>
    </record>
    <!-- List View -->
    <record id="res_partner_client_view_list" model="ir.ui.view">
        <field name="name">res.partner.client.view.list</field>
        <field name="model">res.partner</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <list delete="0" edit="0" duplicate="0">
                <field name="id" string="Customer number"/>
                <field name="name"/>
                <field name="vat"/>
                <field name="disabled" column_invisible="1"/>
            </list>
        </field>
    </record>
    <!-- Form View -->
    <record id="res_partner_client_view_form" model="ir.ui.view">
        <field name="name">res.partner.client.view.form</field>
        <field name="model">res.partner</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <form string="Partners" delete="0" duplicate="0">
                <header>
                    <field name="disabled" invisible="1"/>
                    <field name="active" invisible="1"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <field name="image_1920" widget='image' class="oe_avatar" options='{"preview_image": "avatar_128"}' readonly="disabled == True"/>
                    <div class="oe_title">
                        <label for="name" string="Business Name"/>
                        <field name="name" invisible="1"/>
                        <h1>
                            <field id="company" options="{'line_breaks': False}" widget="text" class="text-break" name="name" default_focus="1" placeholder="e.g. Lumber Inc" required="1" readonly="disabled == True"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="id" string="Customer number" invisible="not id" readonly="1"/>
                            <field name="vat" readonly="disabled == True"/>
                            <label for="street" string="Address"/>
                            <div class="o_address_format">
                                <field name="street" placeholder="Street..." class="o_address_street" readonly="disabled == True"/>
                                <field name="street2" placeholder="Street 2..." class="o_address_street" readonly="disabled == True"/>
                                <div class="o_address_street">
                                    <field name="l10n_mx_edi_colony" placeholder="Colony..." style="flex: 2 1 auto" readonly="disabled == True"/>
                                </div>
                                <field name="city" placeholder="City" class="o_address_city" readonly="disabled == True"/>
                                <field name="state_id" class="o_address_state" placeholder="State" readonly="disabled == True"
                                       options="{'no_open': True, 'no_create': True}"
                                       context="{'default_country_id': country_id}"/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip" readonly="disabled == True"/>
                                <field name="country_id" placeholder="Country" class="o_address_country" readonly="disabled == True"
                                       options='{"no_open": True, "no_create": True}'/>
                            </div>
                        </group>
                        <group>
                            <field name="x_ref_sap" readonly="disabled == True"/>
                            <field name="disabled" invisible="1"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="x_accounts" string="Accounts" invisible="disabled == True">
                            <group>
                                <field name="x_account_child_ids" mode="kanban" nolabel="1" create="0" delete="0"
                                    readonly="disabled == True"
                                    context="{
                                        'kanban_view_ref': 'custom_master_catalog.custom_res_partner_view_kanban',
                                        'form_view_ref': 'custom_master_catalog.res_partner_account_view_form',
                                        'default_x_is_account': True,
                                        'default_is_company': True,
                                        'default_company_type': 'company',
                                        'default_type': 'other',
                                        'default_parent_id': id,
                                        'default_street': street,
                                        'default_street2': street2,
                                        'default_city': city,
                                        'default_state_id': state_id,
                                        'default_zip': zip,
                                        'default_country_id': country_id,
                                        'default_lang': lang,
                                        'default_user_id': user_id,
                                    }" />
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <!-- Actions -->
    <data>
        <record id="res_partner_client_action_window" model="ir.actions.act_window">
            <field name="name">Client</field>
            <field name="path">clients</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="res_partner_client_view_search"/>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('res_partner_client_view_list')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('res_partner_client_view_form')})]"/>
            <field name="domain">[('x_is_client', '=', True)]</field>
            <field name="context">
                {
                    'default_company_type': 'company',
                    'default_is_company': True,
                    'default_x_is_client': True,
                    'x_client_view': True,
                    'search_default_filter_enabled': 1,
                }
            </field>
        </record>
    </data>
</odoo>
