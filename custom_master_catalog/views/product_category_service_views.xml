<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="product_category_service_view_search" model="ir.ui.view">
        <field name="name">product.category.service.view.search</field>
        <field name="model">product.category</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Service"/>
                <field name="disabled"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
            </search>
        </field>
    </record>

    <!-- List View -->
    <record id="product_category_service_view_list" model="ir.ui.view">
        <field name="name">product.category.service.view.list</field>
        <field name="model">product.category</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <list delete="0" edit="false" duplicate="0">
                <field name="name" string="Service"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="product_category_service_view_form" model="ir.ui.view">
        <field name="name">product.category.service.view.form</field>
        <field name="model">product.category</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <form delete="0" duplicate="0">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <div class="oe_title w-75">
                        <label for="name" class="o_form_label_required"/>
                        <h1>
                            <field name="name" options="{'line_breaks': False}" widget="text" class="text-break"
                                default_focus="1" placeholder="Service name" required="1"
                                readonly="disabled"/>
                            </h1>
                    </div>
                    <group>
                        <group>
                            <field name="description" string="Service description" readonly="disabled" widget="text"/>
                            <field name="parent_id" invisible="1" string="Main service"/>
                        </group>
                        <group>
                            <field name="x_color" widget="color_picker" readonly="disabled"/>
                            <field name="create_date" invisible="1"/>
                            <field name="disabled" invisible="1" />
                            <field name="can_be_disabled" invisible="1" />
                            <field name="active" invisible="1" />
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    <!-- Action -->
    <data>
        <record id="product_category_service_action_window" model="ir.actions.act_window">
            <field name="name">Services</field>
            <field name="res_model">product.category</field>
            <field name="view_mode">list,form</field>
            <field name="path">services</field>
            <field name="search_view_id" ref="product_category_service_view_search"/>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('product_category_service_view_list')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('product_category_service_view_form')})]"/>
            <field name="domain" eval="[
                ('id', 'not in', [ref('product.product_category_all'), ref('product.product_category_1'), ref('product.cat_expense')]),
            ]"/>
            <field name="context">
                {
                    'x_service_view': True,
                    'search_default_filter_enabled': 1
                }
            </field>
            <field name="target">current</field>
        </record>
    </data>

</odoo>
