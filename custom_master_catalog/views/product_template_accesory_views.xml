<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="custom_ike_accessories_view_search" model="ir.ui.view">
        <field name="name">custom_ike_accessories.view.search</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <search string="">
                <field name="name"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
            </search>
        </field>
    </record>

    <record id="custom_ike_accessories_view_tree" model="ir.ui.view">
        <field name="name">custom_ike_accessories.view.tree</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <list string="" delete="0" edit="0" duplicate="0">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="custom_ike_accessories_view_form" model="ir.ui.view">
        <field name="name">custom_ike_accessories.view.form</field>
        <field name="model">product.product</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <form string="" delete="0" duplicate="0">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <field name="type" invisible="1"/>
                    <field name="x_accessory_ok" invisible="1"/>
                    <field name="image_128" widget='image' class="oe_avatar" readonly="disabled"/>
                    <div class="oe_title">
                        <label for="name" class="o_form_label_required"/>
                        <h1>
                            <field name="name" class="w-100" readonly="disabled"/>
                        </h1>
                    </div>
                    <group>
                        <field name="x_concept_ok" readonly="disabled"/>
                        <field name="create_date" invisible="1"/>
                        <field name="disabled" invisible="1" />
                        <field name="active" invisible="1" />
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="custom_ike_accessories_action" model="ir.actions.act_window">
        <field name="name">Accessories</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="custom_ike_accessories_view_search"/>
        <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('custom_ike_accessories_view_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('custom_ike_accessories_view_form')})]"/>
        <field name="domain" eval="[
            ('sale_ok', '=', False),
            ('sh_product_subscribe', '=', False),
            ('purchase_ok', '=', True),
            ('x_accessory_ok', '=', True),
            ('type', '=', 'service'),
            ('list_price', '=', 0),
            ('standard_price', '=', 0),
            ('categ_id', '=', ref('product.product_category_all')),
            ('uom_id', '=', ref('l10n_mx.product_uom_service_unit')),
        ]"/> <!-- To be set in action.server -->
        <field name="context" eval="{
            'default_sale_ok': False,
            'default_purchase_ok': True,
            'default_x_accessory_ok': True,
            'default_type': 'service',
            'default_list_price': 0,
            'default_standard_price': 0,
            'default_categ_id': ref('product.product_category_all'),
            'default_uom_id': ref('l10n_mx.product_uom_service_unit'),
            'search_default_filter_enabled': 1,
            'x_accessories_view': True,
        }"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first accessory!
            </p>
        </field>
    </record>

    <record id="custom_ike_accessories_product_action_server" model="ir.actions.server">
        <field name="name">Accessories</field>
        <field name="model_id" ref="model_product_product"/>
        <field name="state">code</field>
        <field name="code">
action = model.get_accessories_view_action()
        </field>
    </record>

</odoo>
