<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.portal</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="40"/>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@name='integration']" position="inside">
                    <setting id="events_allow_send_whatsapp" string="Send whatsapp notifications" help="Allow users to send whatsapp notifications" groups="base.group_no_one">
                        <field name="events_allow_send_whatsapp"/>
                    </setting>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
