<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Search -->
    <record id="view_custom_state_municipality_view_search" model="ir.ui.view">
        <field name="name">custom.state.municipality.view.search</field>
        <field name="model">custom.state.municipality</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <field name="state_id"/>
                <group expand="1" string="Group By">
                    <filter string="Mexico" name="filter_by_mexico" domain="[('country_id.code', '=', 'MX')]" context="{}"/>
                    <filter string="Country" name="group_by_country_id" domain="[]" context="{'group_by':'country_id'}"/>
                    <filter string="State" name="group_by_state_id" domain="[]" context="{'group_by':'state_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- List -->
    <record id="custom_state_municipality_view_list" model="ir.ui.view">
        <field name="name">custom.state.municipality.view.list</field>
        <field name="model">custom.state.municipality</field>
        <field name="arch" type="xml">
            <list import="false" edit="0"
                  decoration-danger="red_zone == True and active and not disabled"
                  decoration-muted="active == False or disabled == True">
                <field name="name"/>
                <field name="state_id"/>
                <field name="country_id" optional="hide"/>
                <!-- <field name="zip_code" optional="show"/> -->
                <field name="red_zone"/>
                <field name="disabled" column_invisible="1"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="custom_state_municipality_view_form" model="ir.ui.view">
        <field name="name">custom.state.municipality.view.form</field>
        <field name="model">custom.state.municipality</field>
        <field name="arch" type="xml">
            <form create="False" delete="1">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Name..." readonly="1"/>
                        </h1>
                    </div>
                    <header>
                        <field name="disabled" invisible="1"/>
                        <field name="active" invisible="1"/>
                    </header>
                    <group>
                        <group>
                            <field name="country_id" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}" readonly="1"
                                context="{'form_view_ref': 'custom_master_catalog.custom_ike_view_country_form'}"/>
                            <field name="state_id" context="{'form_view_ref': 'custom_master_catalog.custom_ike_view_country_state_form', 'list_view_ref': 'custom_master_catalog.custom_ike_view_country_state_tree'}"
                                   domain="[('country_id', '=', country_id)]" readonly="1"
                                   options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                        </group>
                        <group>
                            <!-- <field name="zip_code"/> -->
                            <field name="c_estado" readonly="1"/>
                            <field name="c_mnpio" readonly="1"/>
                            <field name="red_zone" readonly="disabled"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="codes" string="ZIP Codes">
                            <group>
                                <field name="code_ids" context="{'default_municipality_id': id}" nolabel="1" readonly="1">
                                    <list editable="top">
                                        <field name="municipality_id" column_invisible="1"/>
                                        <field name="zip_code"/>
                                        <field name="city"/>
                                        <field name="disabled" column_invisible="1"/>
                                        <field name="active" column_invisible="1"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                        <page string="ZIP Codes (inactive)" invisible="inactive_zip_codes_count == 0">
                            <group>
                                <field name="inactive_code_ids" context="{'active_test': False}" nolabel="1" readonly="1">
                                    <list editable="top">
                                        <field name="municipality_id" column_invisible="1"/>
                                        <field name="zip_code"/>
                                        <field name="city"/>
                                        <field name="disabled" column_invisible="1"/>
                                        <field name="active" column_invisible="1"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="custom_state_municipality_action" model="ir.actions.act_window">
        <field name="name">Municipalities</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">custom.state.municipality</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">
            {
                'search_default_filter_by_mexico': 1,
                'search_default_group_by_state_id': 1,
                'create': 0,
                'delete': 0,
            }
        </field>
    </record>

</odoo>
