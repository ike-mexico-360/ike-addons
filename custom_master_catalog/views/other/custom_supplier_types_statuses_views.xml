<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View Search -->
    <record id="custom_supplier_types_statuses_view_search" model="ir.ui.view">
        <field name="name">custom.supplier.types.statuses.view.search</field>
        <field name="model">custom.supplier.types.statuses</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="disabled"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <group expand="0" string="Group By">
                    <filter string="Service" name="group_by_service" context="{'group_by':'x_service_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- View Form -->
    <record id="custom_supplier_types_statuses_view_form" model="ir.ui.view">
        <field name="name">custom.supplier.types.statuses.view.form</field>
        <field name="model">custom.supplier.types.statuses</field>
        <field name="arch" type="xml">
            <form delete="0" duplicate="0">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <group>
                        <group>
                            <field name="name" readonly="disabled"/>
                            <field name="ref"/>
                            <field name="x_categ_domain" invisible="1"/>
                            <field name="x_service_id" readonly="disabled" domain="x_categ_domain"
                                options="{'no_create': True, 'no_create_edit': True}"
                                context="{'list_view_ref': 'custom_master_catalog.product_category_service_view_list'}"/>
                            <field name="description" widget="text" readonly="disabled"/>
                        </group>
                        <group>
                            <field name="affects_costs" readonly="disabled"/>
                            <field name="active" invisible="1"/>
                            <field name="disabled" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- View List -->
    <record id="custom_supplier_types_statuses_view_list" model="ir.ui.view">
        <field name="name">custom.supplier.types.statuses.view.list</field>
        <field name="model">custom.supplier.types.statuses</field>
        <field name="arch" type="xml">
            <list delete="0" edit="0" duplicate="0">
                <field name="name" string="Provider State"/>
                <field name="affects_costs"/>
                <field name="x_service_id"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="custom_supplier_types_statuses_action" model="ir.actions.act_window">
        <field name="name">Types of supplier status</field>
        <field name="res_model">custom.supplier.types.statuses</field>
        <field name="view_mode">list,form</field>
        <field name="context">
            {
                'search_default_filter_enabled': 1,
                'x_subservice_view': True
            }
        </field>
    </record>

</odoo>
