<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View custom.account.identification search -->
    <record id="custom_account_identification_view_search" model="ir.ui.view">
        <field name="name">custom.account.identification.view.search</field>
        <field name="model">custom.account.identification</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
            </search>
        </field>
    </record>

    <!-- View custom.account.identification View List -->
    <record id="custom_account_identification_view_list" model="ir.ui.view">
        <field name="name">custom.account.identification.view.list</field>
        <field name="model">custom.account.identification</field>
        <field name="arch" type="xml">
            <list delete="0" edit="0" decoration-muted="disabled == True">
                <field name="code"/>
                <field name="name"/>
                <field name="description" optional="show"/>
                <field name="regex"/>
                <field name="label"/>
                <field name="clause" />
                <field name="active" column_invisible="1"/>
                <field name="disabled" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- View custom.account.identification form -->
    <record id="custom_account_identification_view_form" model="ir.ui.view">
        <field name="name">custom.account.identification.view.form</field>
        <field name="model">custom.account.identification</field>
        <field name="arch" type="xml">
            <form delete="0">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <div class="oe_title">
                        <label for="name" class="o_form_label_required"/>
                        <h1>
                            <field name="name" placeholder="Name..." readonly="disabled"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" readonly="disabled"/>
                            <field name="description" readonly="disabled"/>
                        </group>
                        <group>
                            <field name="regex" readonly="disabled"/>
                            <field name="label" readonly="disabled"/>
                            <field name="clause" />
                        </group>
                    </group>
                    <group invisible="1">
                        <field name="create_date" invisible="1"/>
                        <field name="disabled" invisible="1" />
                        <field name="active" invisible="1" />
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    <!-- Action custom.account.identification.type -->
    <record id="custom_account_identification_action" model="ir.actions.act_window">
        <field name="name">Account Identification</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">custom.account.identification</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_filter_enabled': 1}</field>
    </record>

</odoo>
