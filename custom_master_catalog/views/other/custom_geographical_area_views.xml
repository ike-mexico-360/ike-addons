<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form -->
    <record id="custom_geographical_area_view_form" model="ir.ui.view">
        <field name="name">custom.geographical.area.view.form</field>
        <field name="model">custom.geographical.area</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id" readonly="1"
                                   options="{'no_open': True, 'no_create': True}"/>
                            <field name="country_id" options="{'no_open': True, 'no_create': True}"/>
                        </group>
                        <group>
                            <field name="state_id"
                                   domain="[('country_id', '=', country_id)]"
                                   options="{'no_open': True, 'no_create': True}"/>
                            <field name="municipality_id"
                                   domain="[('state_id', '=', state_id)]"
                                   options="{'no_open': True, 'no_create': True}"/>
                            <field name="disabled" widget="disable_field"
                                   options="{'disabled_reason_action': false, 'disabled_reason_field': 'disabled_reason'}"/>
                            <field name="active" invisible="1" />
                        </group>
                    </group>
                    <group>
                        <field name="disabled_reason" invisible="not disabled" force_save="1"/>
                        <field name="area_product_ids" widget="one2many" nolabel="1"
                               context="{'default_geographical_area_id': id, 'display_default_code': 0}">
                            <list editable="bottom">
                                <field name="geographical_area_id" column_invisible="1"/>
                                <field name="subservice_specification_domain" column_invisible="1"/>
                                <field name="product_id"
                                       domain="[('id', 'in', context.get('allowed_product_ids', []))]"
                                       context="{'display_default_code': 0,
                                       'list_view_ref': 'custom_master_catalog.view_x_subservice_product_template_list'}"
                                       options="{'no_open': True, 'no_create': True}"/>
                                <field name="subservice_specification_ids" widget="many2many_tags"
                                       domain="subservice_specification_domain"
                                       options="{'no_open': True, 'no_create': True}"/>
                                <field name="color" widget="color_picker"/>
                                <field name="disabled" widget="disable_field"
                                       options="{'disabled_reason_action': false, 'disabled_reason_field': 'disabled_reason'}"/>
                                <field name="disabled_reason" optional="hide" force_save="1"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Product Form -->
    <record id="custom_geographical_area_product_view_form" model="ir.ui.view">
        <field name="name">custom.geographical.area.product.view.form</field>
        <field name="model">custom.geographical.area.product.rel</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="geographical_area_id" invisible="0"/>
                        <field name="product_id" domain="[('type', '=', 'service')]" context="{'display_default_code': 0}"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                    <group>
                        <field name="disabled"/>
                    </group>
                </group>
            </form>
        </field>
    </record>
</odoo>
