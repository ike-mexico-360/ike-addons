<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View custom.supplier.coverage.configuration search -->
    <record id="custom_supplier_coverage_configuration_view_search" model="ir.ui.view">
        <field name="name">custom.supplier.coverage.configuration.view.search</field>
        <field name="model">custom.supplier.coverage.configuration</field>
        <field name="arch" type="xml">
            <search>
                <field name="supplier_id"/>
                <field name="vat"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="services_ids"/>
                <field name="subservices_ids"/>
                <field name="disabled"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Electronics" name="filter_electronics" domain="[('x_is_electronic', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Manual" name="filter_manual" domain="[('x_is_manual', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Extraordinary" name="filter_extraordinary" domain="[('x_is_extraordinary', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <group >
                    <filter string="Services" name="services" domain="[]" context="{'group_by':'services_ids'}"/>
                    <filter string="Subservices" name="subservices" domain="[]" context="{'group_by':'subservices_ids'}"/>
                    <filter string="Electronics" name="electronics" domain="[]" context="{'group_by':'x_is_electronic'}"/>
                    <filter string="Manual" name="manual" domain="[]" context="{'group_by':'x_is_manual'}"/>
                    <filter string="Extraordinary" name="extraordinary" domain="[]" context="{'group_by':'x_is_extraordinary'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- View custom.supplier.coverage.configuration View List -->
    <record id="custom_supplier_coverage_configuration_view_list" model="ir.ui.view">
        <field name="name">custom.supplier.coverage.configuration.view.list</field>
        <field name="model">custom.supplier.coverage.configuration</field>
        <field name="arch" type="xml">
            <list delete="0" edit="0" duplicate="0">
                <field name="supplier_id"/>
                <field name="vat" optional="show"/>
                <field name="phone" optional="show"/>
                <field name="email" optional="show"/>
                <field name="services_ids" widget="many2many_tags" optional="show"/>
                <field name="subservices_ids" widget="many2many_tags" optional="show"/>
                <field name="x_is_electronic" optional="show"/>
                <field name="x_is_manual" optional="show"/>
                <field name="x_is_extraordinary" optional="show"/>
                <field name="accept_cancellations" column_invisible="1"/>
                <field name="active" column_invisible="1"/>
                <field name="disabled" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- View custom.supplier.coverage.configuration form -->
    <record id="custom_supplier_coverage_configuration_view_form" model="ir.ui.view">
        <field name="name">custom.supplier.coverage.configuration.view.form</field>
        <field name="model">custom.supplier.coverage.configuration</field>
        <field name="arch" type="xml">
            <form delete="0" duplicate="0">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <group>
                        <group>
                            <field name="supplier_id" readonly="disabled" required="1" options='{"no_open": True, "no_create": True}'
                                domain="[('x_is_supplier', '=', True), ('disabled', '=', False)]"
                                context="{'list_view_ref': 'custom_master_catalog.res_partner_supplier_view_list', 'search_view_ref': 'custom_master_catalog.res_partner_supplier_view_search', 'hide_disabled_enabled_filters': 1}"/>
                            <label for="street" string="Address"/>
                            <div class="o_address_format">
                                <field name="street" placeholder="Street..." class="o_address_street"
                                    readonly="1" force_save="1"/>
                                <field name="street2" placeholder="Street 2..." class="o_address_street"
                                    readonly="1" force_save="1"/>
                                <field name="city" placeholder="City" class="o_address_city"
                                    readonly="1" force_save="1"/>
                                <field name="state_id" class="o_address_state" placeholder="State" options="{'no_open': True, 'no_quick_create': True}"
                                    readonly="1" force_save="1" context="{'country_id': country_id, 'default_country_id': country_id, 'zip': zip}"/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip"
                                    readonly="1" force_save="1"/>
                                <div name="partner_address_country" class="d-flex justify-content-between">
                                    <field name="country_id" placeholder="Country" class="o_address_country" options='{"no_open": True, "no_create": True}'
                                        readonly="1" force_save="1"/>
                                </div>
                            </div>
                        </group>
                        <group>
                            <field name="phone" readonly="1" force_save="1"/>
                            <field name="mobile" readonly="1" force_save="1"/>
                            <field name="email" readonly="1" force_save="1"/>
                            <field name="accept_cancellations" invisible="1"/>
                            <label for="waiting_time"/>
                            <div>
                                <field name="waiting_time" readonly="disabled" force_save="1" class="oe_inline"/> min
                            </div>
                            <field name="disabled" invisible="1"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="supplier_coverage_config_line_ids" string="Services and subservices">
                            <group>
                                <field name="supplier_coverage_config_line_ids" nolabel="1" mode="list" readonly="disabled">
                                    <list string="Productos" editable="bottom" limit="20" no_open="1" delete="0">
                                        <field name="x_service_domain" column_invisible="1"/>
                                        <field name="product_domain" column_invisible="1"/>
                                        <field name="service_id" options='{"no_open": True, "no_create": True}' required="1"
                                            domain="x_service_domain"
                                            context="{'list_view_ref': 'custom_master_catalog.product_category_service_view_list'}"/>
                                        <field name="product_id" options='{"no_open": True, "no_create": True}' required="1"
                                            domain="product_domain"
                                            context="{'list_view_ref': 'custom_master_catalog.view_x_subservice_product_template_list', 'display_default_code': 0}"/>
                                        <button type="object" name="action_disable_line"
                                            string="Disable"
                                            confirm="Are you sure you want to disable this subservice?"
                                            invisible="disabled"
                                            class="bg-danger text-white"/>
                                        <button type="object" name="action_enable_line"
                                            string="Enable"
                                            confirm="Are you sure you want to enable this subservice?"
                                            invisible="not disabled"
                                            class="bg-success text-white"/>
                                        <field name="disabled" widget="boolean" readonly="1" optional="show"/>
                                        <button type="object" name="action_open_geographic_subservice_wizard" title="Forecast Report" icon="fa-pencil-square-o"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    <!-- Action custom.supplier.coverage.configuration.type -->
    <record id="custom_supplier_coverage_configuration_action" model="ir.actions.act_window">
        <field name="name">Configuration of Services and Subservices</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">custom.supplier.coverage.configuration</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_filter_enabled': 1,}</field>
    </record>

</odoo>
