<odoo>
    <record id="custom_ike_view_country_state_search" model="ir.ui.view">
        <field name="name">custom_ike_res.country.state.search</field>
        <field name="model">res.country.state</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <search string="Country">
                <field name="name"/>
                <field name="code"/>
                <field name="country_id"/>
                <filter string="México" name="filter_by_mexico" domain="[('country_id.code', '=', 'MX')]"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <group string="Group By">
                    <filter name="groupby_country" string="Country" context="{'group_by': 'country_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="custom_ike_view_country_state_tree" model="ir.ui.view">
        <field name="name">custom_ike_res.country.state.list</field>
        <field name="model">res.country.state</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <list string="State" edit="false" delete="0" duplicate="0" create="0">
                <field name="name"/>
                <field name="code"/>
                <field name="country_id" options="{'no_create': True, 'no_open': True}"
                    context="{'list_view_ref': 'custom_master_catalog.custom_ike_view_country_tree', 'form_view_ref': 'custom_master_catalog.custom_ike_view_country_form', 'search_view_ref': 'custom_master_catalog.custom_ike_res_country_view_search', 'hide_disabled_enabled_filters': 1}"/>
                <field name="disabled" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="custom_ike_view_country_state_form" model="ir.ui.view">
        <field name="name">custom_ike_res.country.state.form</field>
        <field name="model">res.country.state</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <form string="State" delete="0" duplicate="0">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="country_id" options='{"no_open": True, "no_create": True}'
                            context="{'list_view_ref': 'custom_master_catalog.custom_ike_view_country_tree', 'form_view_ref': 'custom_master_catalog.custom_ike_view_country_form', 'search_view_ref': 'custom_master_catalog.custom_ike_res_country_view_search', 'hide_disabled_enabled_filters': 1}"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="custom_ike_action_country_state" model="ir.actions.act_window">
        <field name="name">Fed. States</field>
        <field name="res_model">res.country.state</field>
        <field name="search_view_id" ref="custom_ike_view_country_state_search"/>
        <field name="view_mode">list</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_filter_enabled': 1}</field>
        <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('custom_ike_view_country_state_tree')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a State
            </p><p>
                Federal States belong to countries and are part of your contacts' addresses.
            </p>
        </field>
    </record>
</odoo>