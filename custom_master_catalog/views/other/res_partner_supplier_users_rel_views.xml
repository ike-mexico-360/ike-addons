<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_partner_supplier_users_rel_view_search" model="ir.ui.view">
        <field name="name">res_partner_supplier_users_rel.view.search</field>
        <field name="model">res.partner.supplier_users.rel</field>
        <field name="arch" type="xml">
            <search string="">
                <field name="user_id" string="User" />
                <field name="supplier_id" string="Supplier" />
                <field name="center_of_attention_id" string="Center of Attention" />
                <group expand="0" string="Group By">
                    <filter string="Supplier" name="group_by_supplier" context="{'group_by': 'supplier_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_res_partner_supplier_users_rel_list" model="ir.ui.view">
        <field name="name">view.res_partner_supplier_users_rel.list</field>
        <field name="model">res.partner.supplier_users.rel</field>
        <field name="arch" type="xml">
            <list editable="bottom" open_form_view="view_res_partner_supplier_users_rel_form">
                <field name="user_id" domain="users_domain" options="{'no_create': True, 'no_edit': True, 'no_open': True}"
                    context="{'list_view_ref': 'custom_master_catalog.res_partner_supplier_view_list'}"/>
                <field name="partner_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}"
                    force_save="1" column_invisible="1" required="1"/>
                <field name="user_type"/>
                <field name="supplier_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}"
                    context="{'list_view_ref': 'custom_master_catalog.res_partner_supplier_view_list'}"
                    domain="[('x_is_supplier', '=', True), ('disabled', '=', False)]" readonly="0" force_save="1" required="1"/>
                <field name="center_of_attention_id" domain="[('parent_id', '=', supplier_id), ('disabled', '=', False)]"
                    options="{'no_create': True, 'no_edit': True, 'no_open': True}" force_save="1"
                    context="{'list_view_ref': 'custom_master_catalog.res_partner_supplier_center_view_list'}"/>
                <field name="users_domain" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_res_partner_supplier_users_rel_form" model="ir.ui.view">
        <field name="name">view_res_partner_supplier_users_rel.form</field>
        <field name="model">res.partner.supplier_users.rel</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                        <group>
                            <field name="user_id" domain="users_domain" options="{'no_create': True, 'no_edit': True, 'no_open': True}"
                                context="{'list_view_ref': 'custom_master_catalog.res_partner_supplier_view_list'}"/>
                            <field name="users_domain" invisible="1"/>
                            <field name="partner_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" required="1"
                                readonly="1" invisible="1" force_save="1" groups="base.group_system"/>
                            <field name="user_type"/>
                        </group>
                        <group>
                            <field name="supplier_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" required="1"
                                context="{'list_view_ref': 'custom_master_catalog.res_partner_supplier_view_list'}"
                                domain="[('x_is_supplier', '=', True), ('disabled', '=', False)]" readonly="0"/>
                            <field name="center_of_attention_id" domain="[('parent_id', '=', supplier_id), ('disabled', '=', False)]"
                                options="{'no_create': True, 'no_edit': True, 'no_open': True}" force_save="1"
                                context="{'list_view_ref': 'custom_master_catalog.res_partner_supplier_center_view_list'}"
                                invisible="supplier_id == False"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="res_partner_supplier_users_rel_action" model="ir.actions.act_window">
        <field name="name">User - Supplier</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.partner.supplier_users.rel</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_group_by_supplier': 1}</field>
    </record>

</odoo>
