<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view" model="ir.ui.view">
        <field name="name">product.template.common.form.inherit.product.mapping</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Product Mappings" name="x_mappings">
                    <field name="x_mapping_ids" widget="one2many">
                        <list editable="bottom">
                            <field name="parent_id" column_invisible="1"/>
                            <field name="categ_id" />
                            <field name="product_id" context="{'display_default_code': 0}" options="{'no_create': 1}" string="Subservice"/>
                            <field name="product_default_code" optional="hide"/>
                            <field name="active"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
