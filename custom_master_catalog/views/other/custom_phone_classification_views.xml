<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="custom_ike_phone_classification_view_search" model="ir.ui.view">
        <field name="name">custom_ike_phone_classification.view.search</field>
        <field name="model">custom.phone.classification</field>
        <field name="arch" type="xml">
            <search string="">
                <field name="name"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
            </search>
        </field>
    </record>

    <record id="custom_ike_phone_classification_view_form" model="ir.ui.view">
        <field name="name">custom_ike_phone_classification.view.form</field>
        <field name="model">custom.phone.classification</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <form string="" delete="0" duplicate="0">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <div class="oe_title">
                        <label for="name" class="o_form_label_required"/>
                        <h1>
                            <field name="name" class="w-100" readonly="disabled" required="1"/>
                        </h1>
                    </div>
                    <group invisible="1">
                        <field name="create_date" invisible="1"/>
                        <field name="disabled" invisible="1" />
                        <field name="active" invisible="1" />
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="custom_ike_phone_classification_view_tree" model="ir.ui.view">
        <field name="name">custom_ike_phone_classification.view.tree</field>
        <field name="model">custom.phone.classification</field>
        <field name="arch" type="xml">
            <list string="" delete="0" edit="0" duplicate="0">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="custom_ike_phone_classification_action" model="ir.actions.act_window">
        <field name="name">Phone classification</field>
        <field name="res_model">custom.phone.classification</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="custom_ike_phone_classification_view_search"/>
        <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('custom_ike_phone_classification_view_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('custom_ike_phone_classification_view_form')})]"/>
        <field name="context">{
            'search_default_filter_enabled': 1
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first phone classification!
            </p>
        </field>
    </record>

</odoo>
