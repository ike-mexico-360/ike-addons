<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View Search -->
    <record id="custom_service_operational_area_view_search" model="ir.ui.view">
        <field name="name">custom.service.operational.area.view.search</field>
        <field name="model">custom.service.operational.area</field>
        <field name="arch" type="xml">
            <search string="Operational Area">
                <field name="name"/>
            </search>
        </field>
    </record>

    <!-- View Form -->
    <record id="custom_service_operational_area_view_form" model="ir.ui.view">
        <field name="name">custom.service.operational.area.view.form</field>
        <field name="model">custom.service.operational.area</field>
        <field name="arch" type="xml">
            <form string="Operational Area" delete="false">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <div class="oe_title">
                        <label for="name" class="o_form_label">Name</label>
                        <h1>
                            <field name="name" placeholder="Operational area name" class="o_input"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="disabled" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View List -->
    <record id="custom_service_operational_area_view_list" model="ir.ui.view">
        <field name="name">custom.service.operational.area.view.list</field>
        <field name="model">custom.service.operational.area</field>
        <field name="arch" type="xml">
            <list string="Operational area" delete="false" edit="0">
                <field name="name"/>
                <field name="disabled" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="custom_service_operational_area_action" model="ir.actions.act_window">
        <field name="name">Operational Area</field>
        <field name="res_model">custom.service.operational.area</field>
        <field name="view_mode">list,form</field>
    </record>

     <!-- Menu  -->
    <menuitem id="custom_service_operational_area_menu"
        name="Operational area"
        parent="product_category_service_menu_root"
        action="custom_service_operational_area_action"
        sequence="10"/>

</odoo>