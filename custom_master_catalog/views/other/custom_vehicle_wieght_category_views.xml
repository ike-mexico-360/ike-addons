<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View Search -->
    <record id="custom_vehicle_weight_category_view_search" model="ir.ui.view">
        <field name="name">custom.vehicle.weight.category.view.search</field>
        <field name="model">custom.vehicle.weight.category</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="disabled"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <group expand="0" string="Group By">
                </group>
            </search>
        </field>
    </record>

    <!-- View Form -->
    <record id="custom_vehicle_weight_category_view_form" model="ir.ui.view">
        <field name="name">custom.vehicle.weight.category.view.form</field>
        <field name="model">custom.vehicle.weight.category</field>
        <field name="arch" type="xml">
            <form delete="0">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <div class="oe_title">
                        <label for="name" class="o_form_label_required"/>
                        <h1>
                            <field name="name" placeholder="Name" readonly="disabled"/>
                        </h1>
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- View List -->
    <record id="custom_vehicle_weight_category_view_list" model="ir.ui.view">
        <field name="name">custom.vehicle.weight.category.view.list</field>
        <field name="model">custom.vehicle.weight.category</field>
        <field name="arch" type="xml">
            <list delete="0" edit="false">
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="custom_vehicle_weight_category_action" model="ir.actions.act_window">
        <field name="name">Weight Category vehicles</field>
        <field name="res_model">custom.vehicle.weight.category</field>
        <field name="view_mode">list,form</field>
            <field name="context">
                {
                    'search_default_filter_enabled': 1,
                }
            </field>
    </record>

</odoo>