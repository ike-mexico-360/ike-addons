<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="custom_subservice_specification_view_search" model="ir.ui.view">
        <field name="name">custom.subservice.specification.view.search</field>
        <field name="model">custom.subservice.specification</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Subservice specifications"/>
                <field name="disabled"/>
                <filter string="Disabled" name="filter_disabled" domain="[('disabled', '=', True)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <filter string="Enabled" name="filter_enabled" domain="[('disabled', '=', False)]" invisible="context.get('hide_disabled_enabled_filters', 0) == 1"/>
                <group expand="0" string="Group By">
                    <filter string="Service" name="group_by_service" context="{'group_by': 'service_id'}"/>
                    <filter string="Subservice" name="group_by_subservice" context="{'group_by': 'subservice_ids'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- List View -->
    <record id="custom_subservice_specification_view_list" model="ir.ui.view">
        <field name="name">custom.subservice.specification.view.list</field>
        <field name="model">custom.subservice.specification</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <list edit="0" delete="0" duplicate="0">
                <field name="name"/>
                <field name="service_id"/>
                <field name="subservice_ids"
                    widget="many2many_tags"
                    context="{'display_default_code': 0}"/>
                <field name="vehicle_category_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="custom_subservice_specification_view_form" model="ir.ui.view">
        <field name="name">custom.subservice.specification.view.form</field>
        <field name="model">custom.subservice.specification</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <form delete="0" duplicate="0">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Disabled" bg_color="text-bg-secondary" invisible="not disabled or not active"/>
                    <div class="oe_title mb24">
                        <h1>
                            <label for="name" class="o_form_label_required"/>
                            <field name="name" options="{'line_breaks': False}" class="text-break"
                                default_focus="1" required="1"
                                readonly="disabled"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="service_id" readonly="disabled" domain="x_categ_domain"
                                options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                                context="{'list_view_ref': 'custom_master_catalog.product_category_service_view_list'}"/>
                            <field name="all_subservice" readonly="disabled"/>
                            <field name="subservice_ids" readonly="disabled"
                                widget="many2many_tags"
                                options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                                context="{'list_view_ref': 'custom_master_catalog.product_category_service_view_list', 'display_default_code': 0}"/>
                        </group>
                        <group>
                            <field name="vehicle_category_id" readonly="disabled"
                                options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                                context="{'list_view_ref': 'custom_master_catalog.custom_fleet_vehicle_model_category_view_list'}"/>
                            <field name="create_date" invisible="1"/>
                            <field name="disabled" invisible="1" />
                            <field name="active" invisible="1" />
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    <!-- Action -->
    <data>
        <record id="custom_subservice_specification_action" model="ir.actions.act_window">
            <field name="name">Subservice specifications</field>
            <field name="res_model">custom.subservice.specification</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="custom_subservice_specification_view_search"/>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('custom_subservice_specification_view_list')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('custom_subservice_specification_view_form')})]"/>
            <field name="context">
                {
                    'x_custom_subservice_specification_view': True,
                    'search_default_filter_enabled': 1,
                    'x_subservice_view': True,
                    'display_default_code': 0
                }
            </field>
        </record>
    </data>

</odoo>
