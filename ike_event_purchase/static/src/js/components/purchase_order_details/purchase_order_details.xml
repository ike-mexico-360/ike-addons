<templates id="template" xml:space="preserve">
    <t t-name="ike_event_purchase.PurchaseOrderDetails">
        <t t-if="state.order_data">
            <div t-if="state.order_data.x_dispute_state == 'submitted'" class="alert alert-warning alert-dismissible d-print-none" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="close"></button>
                <strong>
                    <t t-out="translate('The dispute has been submitted.')"/>
                </strong>
            </div>
            <div t-if="state.order_data.x_dispute_state == 'resolved' and state.order_data.x_dispute_approved" class="alert alert-success alert-dismissible d-print-none" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="close"></button>
                <strong>
                    <t t-out="translate('The dispute has been approved.')"/>
                </strong>
            </div>
            <div t-if="state.order_data.x_dispute_state == 'rejected'" class="alert alert-danger alert-dismissible d-print-none" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="close"></button>
                <strong>
                    <t t-out="translate('The dispute has been rejected.')"/>
                </strong>
            </div>
            <div class="row" t-if="state.order_data.state == 'sent'">
                <div class="col-12">
                    <div class="d-flex flex-row justify-content-end">
                        <!-- ToDo: Mostrar también cuando ya se aprobó los cambios -->
                        <button class="btn text-white bg-success bg-opacity-10 rounded-pill px-3 shadow-sm me-2 mb-2" t-on-click="accept_prices" t-if="!state.show_dispute_fields &amp;&amp; ['none', 'resolved'].includes(state.order_data.x_dispute_state)">
                            <t t-out="translate('Accept')"/>
                        </button>
                        <button class="btn text-white bg-danger bg-opacity-10 rounded-pill px-3 me-2 mb-2" t-on-click="toggle_dispute_fields" t-if="!state.show_dispute_fields &amp;&amp; ['none', 'resolved'].includes(state.order_data.x_dispute_state)">
                            <t t-out="translate('Start Dispute')"/>
                        </button>
                        <button class="btn text-white bg-danger bg-opacity-10 rounded-pill px-3 me-2 mb-2" t-on-click="toggle_dispute_fields" disabled="disabled" t-if="state.show_dispute_fields &amp;&amp; ['none', 'resolved'].includes(state.order_data.x_dispute_state)">
                            <t t-out="translate('Start Dispute')"/>
                        </button>
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <t t-set="show_dispute_columns" t-value="state.show_dispute_fields || state.order_data.x_dispute_state == 'submitted' || ['resolved', 'rejected'].includes(state.order_data.x_dispute_state)"/>
                    <t t-set="show_approved_columns" t-value="['resolved', 'rejected'].includes(state.order_data.x_dispute_state)"/>
                    <t t-set="show_dispute_values" t-value="['submitted', 'resolved', 'rejected'].includes(state.order_data.x_dispute_state) &amp;&amp; !state.show_dispute_fields"/>
                    <thead>
                        <tr class="bg-primary text-white">
                            <th class="py-3 px-3 rounded-start">
                                <t t-out="translate('Concept')"/>
                            </th>
                            <th class="py-3 px-3 text-end" t-if="['sent', 'to_consolidate', 'consolidated'].includes(state.order_data.state)">
                                <t t-out="translate('Event Quantity')"/>
                            </th>
                            <th class="py-3 px-3 text-end" t-if="['sent', 'to_consolidate', 'consolidated'].includes(state.order_data.state)">
                                <t t-out="translate('Event Price')"/>
                            </th>
                            <th class="py-3 px-3 text-end">
                                <t t-out="translate('IKE Quantity')"/>
                            </th>
                            <th class="py-3 px-3 text-end">
                                <t t-out="translate('IKE Price')"/>
                            </th>
                            <th t-if="show_dispute_columns" class="py-3 px-3 text-end" style="width: 100px; max-width: 150px;">
                                <t t-out="translate('Dispute Quantity')"/>
                            </th>
                            <th t-if="show_dispute_columns" class="py-3 px-3 text-end" style="width: 150px; max-width: 200px;">
                                <t t-out="translate('Dispute Price')"/>
                            </th>
                            <th t-if="show_approved_columns" class="py-3 px-3 text-end" style="width: 100px; max-width: 150px;">
                                <t t-out="translate('Approved Quantity')"/>
                            </th>
                            <th t-if="show_approved_columns" class="py-3 px-3 text-end" style="width: 150px; max-width: 200px;">
                                <t t-out="translate('Approved Price')"/>
                            </th>
                            <!-- <th t-if="isInPurchaseOrderList" class="py-3 px-3">
                                <t t-out="translate('Origin Event')"/>
                            </th> -->
                            <th class="py-3 px-3 rounded-end"></th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.order_data.order_line" t-as="line" t-key="line.id">
                            <t t-if="line.display_type === 'line_section'">
                                <tr>
                                    <td class="py-2 px-3" colspan="10">
                                        <strong class="text-primary fs-6">
                                            <i class="fa fa-folder me-2"/>
                                            <t t-out="line.display_name"/>
                                        </strong>
                                    </td>
                                </tr>
                            </t>
                            <t t-elif="line.display_type === 'line_note'">
                                <tr>
                                    <td class="py-2 px-3 text-muted" colspan="10">
                                        <t t-out="line.display_name"/>
                                    </td>
                                </tr>
                            </t>
                            <t t-else="">
                                <t t-set="is_new_line" t-value="line.new_line"/>
                                <tr>
                                    <!-- Concept -->
                                    <td class="align-content-center">
                                        <span t-out="line.display_name" t-if="!is_new_line"/>
                                        <t t-if="is_new_line">
                                            <select class="form-control" name="product_id"
                                            t-att-style="state.invalid_lines.has(line.id + '_product_id') ? 'border: 1px solid red' : ''"
                                            t-on-change="(ev) => onchange_disputed_value(line.id, 'product_id', +ev.target.value)"
                                        >
                                                <option value="">
                                                    <t t-out="translate('Select a product')"/>
                                                </option>
                                                <t t-foreach="state.product_ids" t-as="product" t-key="product_index">
                                                    <option t-att-value="product.id" t-out="product.name"/>
                                                </t>
                                            </select>
                                        </t>
                                    </td>
                                    <td class="text-end align-content-center" t-if="['sent', 'to_consolidate', 'consolidated'].includes(state.order_data.state)">
                                        <t t-out="formatNumber(line.x_product_qty_event)" t-if="!is_new_line" />
                                    </td>
                                    <td class="text-end align-content-center" t-if="['sent', 'to_consolidate', 'consolidated'].includes(state.order_data.state)">
                                        <t t-out="formatNumber(line.x_price_unit_event)" t-if="!is_new_line"/>
                                    </td>
                                    <!-- Quantity -->
                                    <td class="text-end align-content-center">
                                        <div t-if="!is_new_line">
                                            <span t-out="formatNumber(line.product_qty)"/>
                                        </div>
                                    </td>
                                    <!-- Price -->
                                    <td class="text-end align-content-center">
                                        <!-- <t t-if="is_new_line &amp;&amp; !line.has_matrix_cost &amp;&amp; line.product_id !== null">
                                        <input t-if="state.show_dispute_fields" type="number" class="form-control text-end"
                                        t-att-value="line.price_unit" t-on-change="(ev) => onchange_disputed_value(line.id, 'price_unit', +ev.target.value)"
                                        t-att-style="state.invalid_lines.has(line.id + '_price_unit') ? 'border: 1px solid red' : ''"
                                    />
                                    </t>
                                    <t t-else=""> -->
                                        <t t-out="formatNumber(line.price_unit)"/>
                                        <!-- </t> -->
                                    </td>
                                    <!-- Dispute fields -->
                                    <td class="text-end align-content-center" t-if="show_dispute_columns">
                                        <t t-out="formatNumber(line.x_product_qty_dispute)" t-if="show_dispute_values"/>
                                        <input t-if="is_new_line || state.show_dispute_fields" type="number" class="form-control text-end"
                                    t-att-value="formatNumber(line.x_product_qty_dispute)" t-on-change="(ev) => onchange_disputed_value(line.id, 'x_product_qty_dispute', +ev.target.value)"
                                    t-att-style="state.invalid_lines.has(line.id + '_x_product_qty_dispute') ? 'border: 1px solid red' : ''"
                                />
                                    </td>
                                    <td class="text-end align-content-center" t-if="show_dispute_columns">
                                        <t t-out="formatNumber(line.x_price_unit_dispute)" t-if="show_dispute_values"/>
                                        <input t-if="is_new_line || state.show_dispute_fields" type="number" class="form-control text-end"
                                    t-att-value="formatNumber(line.x_price_unit_dispute)" t-on-change="(ev) => onchange_disputed_value(line.id, 'x_price_unit_dispute', +ev.target.value)"
                                    t-att-style="state.invalid_lines.has(line.id + '_x_price_unit_dispute') ? 'border: 1px solid red' : ''"
                                />
                                    </td>
                                    <td class="text-end align-content-center" t-if="show_approved_columns">
                                        <t t-out="formatNumber(line.x_product_qty_approved)" t-if="!is_new_line"/>
                                    </td>
                                    <td t-if="is_new_line">
                                        <button class="btn btn-sm btn-outline-danger rounded-pill px-3" t-on-click="() => remove_line(line.id)">
                                            <i class="fa fa-trash"/>
                                        </button>
                                    </td>
                                    <td class="text-end align-content-center" t-if="show_approved_columns">
                                        <t t-out="formatNumber(line.x_price_unit_approved)" t-if="!is_new_line"/>
                                    </td>
                                    <!-- <td t-if="isInPurchaseOrderList" class="align-content-center">
                                        <t t-out="line.x_origin_event || ''"/>
                                    </td> -->
                                    <td class="py-3 px-3"></td>
                                </tr>
                            </t>
                        </t>
                        <tr class="border-top-3 fw-bold" style="border-top: 3px solid #000;">
                            <td class="py-3 px-3">
                                <t t-out="translate('Subtotal')"/>
                            </td>
                            <td class="py-3 px-3 text-end" t-if="['sent', 'to_consolidate', 'consolidated'].includes(state.order_data.state)">
                            </td>
                            <td class="py-3 px-3 text-end" t-if="['sent', 'to_consolidate', 'consolidated'].includes(state.order_data.state)">
                                <span t-out="formatNumber(state.order_data.amount_untaxed_event)"/>
                            </td>
                            <td class="py-3 px-3 text-end">
                            </td>
                            <td class="py-3 px-3 text-end">
                                <span t-out="formatNumber(state.order_data.amount_untaxed)"/>
                            </td>
                            <td t-if="show_dispute_columns" class="py-3 px-3 text-end">
                            </td>
                            <td t-if="show_dispute_columns" class="py-3 px-3 text-end">
                                <span t-out="formatNumber(state.order_data.amount_untaxed_dispute)"/>
                            </td>
                            <td t-if="show_approved_columns" class="py-3 px-3 text-end">
                            </td>
                            <td t-if="show_approved_columns" class="py-3 px-3 text-end">
                                <span t-out="formatNumber(state.order_data.amount_untaxed_approved)"/>
                            </td>
                            <!-- <td t-if="isInPurchaseOrderList" class="py-3 px-3"></td> -->
                            <td class="py-3 px-3"></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="row text-center mb-3" t-if="state.show_dispute_fields">
                <div class="col-12 mb-3 mt-3">
                    <button class="btn text-white bg-primary bg-opacity-10 rounded-pill px-3" t-on-click="add_line">
                        <t t-out="translate('Add concept')"/>
                    </button>
                </div>
                <div class="col-12 mb-3">
                    <span>
                        <t t-out="translate('Specify the reason for the change')"/>
                    </span>
                    <input t-if="state.show_dispute_fields" type="text" class="form-control text-start"
                        t-att-value="state.order_data.x_change_comments" required="true" t-ref="x_change_comments"
                        t-on-change="(ev) => onchange_reasons('x_change_comments', ev.target.value)"
                        t-att-style="state.highlight_change_reason ? 'border: 1px solid red' : ''"
                    />
                </div>
                <div class="col-12">
                    <button class="btn text-white bg-success bg-opacity-10 rounded-pill px-3 shadow-sm me-2" t-on-click="send_dispute" t-if="state.show_dispute_fields">
                        <t t-out="translate('Send Dispute')"/>
                    </button>
                </div>
            </div>
            <!-- Files Section -->
            <!-- <div t-if="isInRfqList" class="card border-0 shadow-sm rounded-3 mt-4">
                <div class="card-header bg-light d-flex align-items-center gap-2 py-2">
                    <i class="fa fa-paperclip text-primary"/>
                    <span class="fw-bold text-primary"><t t-out="translate('Files')"/></span>
                </div>
                <div class="card-body">
                    <t t-set="imageAtts" t-value="(state.order_data.order_attachment_ids || []).filter(a => a.mimetype and a.mimetype.startsWith('image/'))"/>
                    <t t-set="otherAtts" t-value="(state.order_data.order_attachment_ids || []).filter(a => !a.mimetype or !a.mimetype.startsWith('image/'))"/>
                    <div t-if="imageAtts.length" class="d-flex flex-wrap gap-2 mb-3">
                        <t t-foreach="imageAtts" t-as="att" t-key="att.id">
                            <a t-att-href="'/web/image/' + att.id" target="_blank">
                                <img t-att-src="'/web/image/' + att.id"
                                     class="rounded border"
                                     style="width:120px; height:90px; object-fit:cover;"/>
                            </a>
                        </t>
                    </div>
                    <div t-if="otherAtts.length" class="d-flex flex-wrap gap-2 mb-3">
                        <t t-foreach="otherAtts" t-as="att" t-key="att.id">
                            <a t-att-href="'/web/content/' + att.id + '?download=true'" target="_blank"
                               class="badge bg-light text-dark border text-decoration-none py-2 px-3">
                                <i class="fa fa-file me-1"/>
                                <t t-out="att.name"/>
                            </a>
                        </t>
                    </div>
                    <label class="text-primary" style="cursor:pointer;">
                        <i class="fa fa-plus-circle me-1"/>
                        <t t-out="translate('Attach files')"/>
                        <input type="file" class="d-none" multiple="multiple" t-on-change="onDirectFileSelect"/>
                    </label>
                </div>
            </div> -->

            <!-- Message Composer -->
            <div t-if="isInRfqList" class="card border-0 shadow-sm rounded-3 mt-4">
                <div class="card-header bg-light d-flex align-items-center gap-2 py-2">
                    <i class="fa fa-comment text-primary"/>
                    <span class="fw-bold text-primary"><t t-out="translate('Send a Message')"/></span>
                </div>
                <div class="card-body pb-2">
                    <textarea class="form-control mb-2"
                        t-ref="composerTextarea"
                        rows="3"
                        t-att-placeholder="translate('Write a message...')"
                        t-on-input="onComposerInput"/>
                    <!-- Selected file previews -->
                    <div t-if="state.composerFiles.length" class="d-flex flex-wrap gap-2 mb-2">
                        <t t-foreach="state.composerFiles" t-as="file" t-key="file_index">
                            <div class="d-flex align-items-center gap-1 border rounded px-2 py-1 bg-light">
                                <img t-if="file.preview" t-att-src="file.preview"
                                     style="max-height:32px; max-width:40px; object-fit:cover;" class="rounded"/>
                                <i t-else="" class="fa fa-paperclip text-muted"/>
                                <small t-out="file.name" class="text-truncate" style="max-width:120px;"/>
                                <button type="button" class="btn btn-sm p-0 ms-1 text-danger border-0 bg-transparent"
                                        t-on-click="() => removeFile(file_index)">
                                    <i class="fa fa-times"/>
                                </button>
                            </div>
                        </t>
                    </div>
                    <!-- Actions row -->
                    <div class="d-flex justify-content-between align-items-center pt-1">
                        <!-- <label class="btn btn-sm btn-outline-secondary rounded-pill px-3 mb-0" style="cursor:pointer;">
                            <i class="fa fa-paperclip me-1"/>
                            <t t-out="translate('Attach')"/>
                            <input type="file" class="d-none" multiple="multiple" t-on-change="onFileSelect"/>
                        </label> -->
                        <button class="btn btn-sm btn-primary rounded-pill px-3"
                                t-on-click="postMessage"
                                t-att-disabled="!canSendMessage">
                            <i class="fa fa-paper-plane me-1"/>
                            <t t-out="state.isSendingMessage ? translate('Sending...') : translate('Send')"/>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Message History -->
            <div class="mt-4" t-if="state.order_data.message_ids.length">
                <h5 class="mb-3">
                    <t t-out="translate('Messages')"/>
                </h5>
                <t t-foreach="state.order_data.message_ids" t-as="msg" t-key="msg.id">
                    <div class="d-flex mb-3 gap-2">
                        <div class="flex-grow-1 border rounded p-3">
                            <div class="d-flex justify-content-between mb-1">
                                <strong t-out="msg.author_id.name"/>
                                <small class="text-muted" t-out="formatDate(msg.date)"/>
                            </div>
                            <!-- Message body (may contain HTML) -->
                            <div t-out="messageBody(msg.body)" t-if="msg.body"/>
                            <!-- Attachments -->
                            <t t-if="msg.attachment_ids and msg.attachment_ids.length">
                                <div class="d-flex flex-wrap gap-2 mt-2">
                                    <t t-foreach="msg.attachment_ids" t-as="att" t-key="att.id">
                                        <t t-if="att.mimetype and att.mimetype.startsWith('image/')">
                                            <a t-att-href="'/web/image/' + att.id" target="_blank">
                                                <img t-att-src="'/web/image/' + att.id"
                                                     class="img-thumbnail"
                                                     style="max-height:100px; max-width:150px; object-fit:cover;"/>
                                            </a>
                                        </t>
                                        <t t-else="">
                                            <a t-att-href="'/web/content/' + att.id + '?download=true'"
                                               target="_blank"
                                               class="badge bg-light text-dark border text-decoration-none py-2 px-3">
                                                <i class="fa fa-paperclip me-1"/>
                                                <t t-out="att.name"/>
                                            </a>
                                        </t>
                                    </t>
                                </div>
                            </t>
                            <!-- Regular field tracking changes (non-O2M) -->
                            <t t-set="regularTrackings" t-value="(msg.tracking_value_ids || []).filter((tv) => !tv.o2m_record_id)"/>
                            <ul class="mb-0 mt-2 small text-muted" t-if="regularTrackings.length">
                                <t t-foreach="regularTrackings" t-as="tv" t-key="tv.id">
                                    <li>
                                        <span t-out="tv.old_value_char || (tv.old_value_float != null ? '$' + tv.old_value_float : '—')"/>
                                        <i class="fa fa-arrow-right mx-1"/>
                                        <span t-out="tv.new_value_char || (tv.new_value_float != null ? '$' + tv.new_value_float : '—')"/>
                                    </li>
                                </t>
                            </ul>
                            <!-- O2M tracking changes grouped by field -->
                            <t t-foreach="(msg.o2mTrackings || [])" t-as="o2mGroup" t-key="o2mGroup.o2m_field_id">
                                <div class="mt-2">
                                    <strong class="small" t-out="o2mGroup.o2m_field_description"/>
                                    <t t-foreach="o2mGroup.o2mTrackingCommands" t-as="cmd" t-key="cmd.id">
                                        <div class="ms-3 small text-muted">
                                            <span class="badge bg-secondary me-1" t-out="cmd.o2m_command"/>
                                            <span t-out="cmd.o2m_record_name"/>
                                            <ul class="list-unstyled mb-0 ms-2" t-if="cmd.o2mTrackingValues.length">
                                                <t t-foreach="cmd.o2mTrackingValues" t-as="tv" t-key="tv.id">
                                                    <li>
                                                        <strong t-out="tv.changedField"/>:
                                                        <span t-out="tv.oldValue.value ?? '—'"/>
                                                        <i class="fa fa-arrow-right mx-1"/>
                                                        <span t-out="tv.newValue.value ?? '—'"/>
                                                    </li>
                                                </t>
                                            </ul>
                                        </div>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </div>
        </t>
        <t t-else="">
            <!-- Spinner loader -->
            <div class="text-center py-4">
                <i class="fa fa-spinner fa-spin"/>
                <t t-out="translate('Loading...')"/>
            </div>
        </t>
    </t>
</templates>