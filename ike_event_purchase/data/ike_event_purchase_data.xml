<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="cron_supplier_purchase_consolidate" model="ir.cron">
        <field name="name">Supplier Purchase Consolidate</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="model_id" ref="base.model_res_partner" />
        <field name="code">model._x_cron_consolidate_orders()</field>
        <field name="state">code</field>
    </record>

    <data noupdate="1">
        <record id="ir_cron_process_po_tickets_done" model="ir.cron">
            <field name="name">Purchase: Auto-complete Tickets from Event POs</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="state">code</field>
            <field name="code">model._cron_done_tickets_from_draft_po()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(datetime.now() + relativedelta(days=1)).strftime('%Y-%m-%d 00:00:00')"/>
        </record>
    </data>
</odoo>
