<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ike_event_screen_inherit_purchase_order_form" model="ir.ui.view">
        <field name="name">view.ike.event.screen.inherit.purchase.order.form</field>
        <field name="model">ike.event</field>
        <field name="inherit_id" ref="ike_event.view_ike_event_screen_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_open_duplicate_wizard']" position="after">
                <button
                    name="action_confirm_costs"
                    string="Confirm Costs"
                    type="object"
                    class="btn-primary"
                    groups="base.group_system,custom_master_catalog.custom_group_ccc_analyst,custom_master_catalog.custom_group_ccc_coordinator"
                    invisible="stage_ref not in ['verifying', 'cancel_verifying'] or x_purchase_ids_count &gt; 0"
                />
                <field name="x_purchase_ids_count" invisible="1"/>
                <field name="x_ticket_ids_count" invisible="1"/>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button name="x_action_view_purchases" string="Cost review"
                        type="object" class="oe_stat_button" icon="fa-shopping-cart"
                        groups="base.group_system,custom_master_catalog.custom_group_supplier_admin_system,custom_master_catalog.custom_group_supplier_contralory,custom_master_catalog.custom_group_supplier_support,custom_master_catalog.custom_group_bi_queries,custom_master_catalog.custom_group_ccc_boss"
                        invisible="x_purchase_ids_count &lt;= 0"/>

                    <!-- View Ticket -->
                    <button name="x_action_view_tickets" string="Tickets review"
                        type="object" class="oe_stat_button" icon="fa-ticket"
                        invisible="x_ticket_ids_count &lt;= 0"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>