<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="ike_event_purchase_purchase_order_portal_content" name="Purchase Order Portal Content" inherit_id="purchase.purchase_order_portal_content">
        <xpath expr="//address[@t-field='order.company_id.partner_id']" position="before">
            <strong class="d-block mb-1">
                <t t-esc="order.partner_id.name"/>
            </strong>
            <strong class="d-block mb-1">
                <t t-esc="order.x_event_id.name"/>
            </strong>
        </xpath>
        <xpath expr="//h3[@id='details']" position="after">
            <owl-component
                name="ike_event_purchase.purchase_order_details"
                t-att-props="json.dumps({'order_id': order.id})"
            />
        </xpath>
        <xpath expr="//div[hasclass('table-responsive')]/table" position="attributes">
            <attribute name="class">d-none</attribute>
        </xpath>
        <xpath expr="//table/thead/tr/th[4]" position="after">
            <th class="text-end">Dispute Price</th>
            <th class="text-end">Dispute Quantity</th>
            <th class="text-end">Approved Price</th>
            <th class="text-end">Approved Quantity</th>
        </xpath>
        <xpath expr="//tbody/t/tr/t/td[4]" position="after">
            <td class="text-end">
                <span t-field="line.x_price_unit_dispute"/>
            </td>
            <td class="text-end">
                <span t-field="line.x_product_qty_dispute"/>
            </td>
            <td class="text-end">
                <span t-field="line.x_price_unit_approved"/>
            </td>
            <td class="text-end">
                <span t-field="line.x_product_qty_approved"/>
            </td>
        </xpath>
        <xpath expr="//div[@id='total']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
        <xpath expr="//span[@t-field='order.date_order']" position="attributes">
            <attribute name="t-field">order.create_date</attribute>
        </xpath>
        <xpath expr="//span[@t-field='order.date_planned']/preceding-sibling::strong[1]" position="replace">
            <strong t-if="order.state not in ('sent')">Receipt Date:</strong>
        </xpath>
        <xpath expr="//span[@t-field='order.date_planned']" position="attributes">
            <attribute name="t-if">order.state not in ('sent')</attribute>
        </xpath>
    </template>
    <template id="ike_event_purchase_dispute_view" name="Purchase Order Portal Content Dispute" >
        <t t-call="portal.portal_layout">
            <owl-component
                name="ike_event_purchase.purchase_order_dispute"
                t-att-props="json.dumps({'order_id': order_sudo.id, 'action': dispute})"
            />
        </t>
    </template>
    <template id="ike_event_portal_my_purchase_orders" name="My Purchase Orders" inherit_id="purchase.portal_my_purchase_orders">
        <xpath expr="//t[1]" position="replace">
            <t t-call="portal.portal_layout">
                <t t-set="breadcrumbs_searchbar" t-value="True"/>
                <t t-call="portal.portal_searchbar">
                    <t t-set="title">Purchase Orders</t>
                </t>
                <form method="get" action="/my/purchase" class="row g-2 mb-3">
                    <div class="col-auto">
                        <input type="text" id="portal_po_search" name="search"
                               class="form-control" placeholder="Search by Purchase Order #..."/>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary">Search</button>
                    </div>
                </form>
                <script>
                    (function () {
                        var params = new URLSearchParams(window.location.search);
                        var val = params.get('search');
                        if (val) { document.getElementById('portal_po_search').value = val; }
                    })();
                </script>
                <t t-if="not orders">
                    <p class="o_view_nocontent_smiling_face">No purchase orders yet.</p>
                </t>
                <t t-if="orders" t-call="portal.portal_table">
                    <thead>
                        <tr class="active">
                            <th id="order_name_header">
                                <span class='d-none d-md-inline'>Purchase Order #</span>
                                <span class='d-block d-md-none'>Ref.</span>
                            </th>
                            <th id="order_event_header">
                                <span class='d-none d-md-inline'>Event</span>
                                <span class='d-block d-md-none'>Event</span>
                            </th>
                            <th id="order_confirmation_header">
                                <span class='d-none d-md-inline'>Confirmation Date</span>
                                <span class='d-block d-md-none'>Confirmation</span>
                            </th>
                            <th id="order_total_header">Total</th>
                        </tr>
                    </thead>
                    <t t-foreach="orders" t-as="order">
                        <tr>
                            <td id="order_name">
                                <a t-att-href="order.get_portal_url()">
                                    <t t-esc="order.name"/>
                                </a>
                            </td>
                            <td id="order_event">
                                <span t-field="order.x_event_id.name"/>
                            </td>
                            <td id="order_confirmation">
                                <span t-field="order.date_approve" t-options="{'widget': 'date'}"/>
                            </td>
                            <td id="order_total">
                                <span t-field="order.amount_total"/>
                            </td>
                        </tr>
                    </t>
                </t>
            </t>
        </xpath>
    </template>
    <template id="ike_event_portal_my_purchase_order" name="Purchase Order Detail" inherit_id="purchase.portal_my_purchase_order">
        <xpath expr="//t[@t-set='title']//h2[@t-field='order.amount_total']" position="attributes">
            <attribute name="t-field">order.amount_untaxed</attribute>
        </xpath>
        <xpath expr="//div[@id='purchase_order_communication']" position="replace">
            <div id="purchase_order_communication" invisible="1">
            </div>
        </xpath>
    </template>
    <template id="ike_event_portal_my_purchase_rfqs" name="My Requests For Quotation" inherit_id="purchase.portal_my_purchase_rfqs">
        <t t-set="breadcrumbs_searchbar" t-value="True"/>
        <xpath expr="//t[1]/t[4]" position="replace">
            <t t-if="rfqs" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th class="text-start">
                            <span class='d-none d-md-inline'>Request for Quotation #</span>
                            <span class='d-block d-md-none'>Ref.</span>
                        </th>
                        <th class="text-start">Event</th>
                        <th class="text-start"></th>
                        <th class="text-start">Order Deadline</th>
                        <th class="text-start">IKE Price</th>
                        <th class="text-start">Untaxed Amount Dispute</th>
                        <th class="text-start">Untaxed Amount Approved</th>

                    </tr>
                </thead>
                <t t-foreach="rfqs" t-as="rfq">
                    <tr>
                        <td class="text-start">
                            <a t-att-href="rfq.get_portal_url()">
                                <t t-esc="rfq.name"/>
                            </a>
                        </td>
                        <td class="text-start">
                            <span t-field="rfq.x_event_id.name"/>
                        </td>
                        <td class="text-start">
                            <t t-if="rfq.state == 'to_consolidate'">
                                <span class="badge bg-success">Aceptado</span>
                            </t>
                            <t t-elif="rfq.state == 'consolidated'">
                                <span class="badge bg-success">Aceptado</span>
                            </t>
                        </td>
                        <td class="text-start">
                            <span t-field="rfq.date_order" t-options="{'widget': 'date'}"/>
                        </td>
                        <td class="text-start">
                            <span t-field="rfq.amount_untaxed"/>
                        </td>
                        <td class="text-start">
                            <span t-field="rfq.amount_untaxed_dispute"/>
                        </td>
                        <td class="text-start">
                            <span t-field="rfq.amount_untaxed_approved"/>
                        </td>
                    </tr>
                </t>
            </t>
        </xpath>
    </template>
    <template id="portal_pager_override" inherit_id="portal.pager">
        <xpath expr="//ul" position="attributes">
            <attribute name="t-if"/>
        </xpath>
    </template>
</odoo>