<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="ike_event_purchase_purchase_order_portal_content" name="Purchase Order Portal Content" inherit_id="purchase.purchase_order_portal_content">
        <xpath expr="//address[@t-field='order.company_id.partner_id']" position="before">
            <strong class="d-block mb-1">
                <t t-esc="order.partner_id.name"/>
            </strong>
            <strong class="d-block mb-1">
                <t t-out="order.x_event_public_id.name"/>
            </strong>
        </xpath>
        <xpath expr="//h3[@id='details']" position="after">
            <owl-component
                name="ike_event_purchase.purchase_order_details"
                t-att-props="json.dumps({'order_id': order.id})"
            />
        </xpath>
        <xpath expr="//div[hasclass('table-responsive')]/table" position="attributes">
            <attribute name="class">d-none</attribute>
        </xpath>
        <xpath expr="//table/thead/tr/th[4]" position="after">
            <th class="text-end">Dispute Price</th>
            <th class="text-end">Dispute Quantity</th>
            <th class="text-end">Approved Price</th>
            <th class="text-end">Approved Quantity</th>
        </xpath>
        <xpath expr="//tbody/t/tr/t/td[4]" position="after">
            <td class="text-end">
                <span t-field="line.x_price_unit_dispute"/>
            </td>
            <td class="text-end">
                <span t-field="line.x_product_qty_dispute"/>
            </td>
            <td class="text-end">
                <span t-field="line.x_price_unit_approved"/>
            </td>
            <td class="text-end">
                <span t-field="line.x_product_qty_approved"/>
            </td>
        </xpath>
        <xpath expr="//div[@id='total']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
        <xpath expr="//span[@t-field='order.date_order']" position="attributes">
            <attribute name="t-field">order.create_date</attribute>
        </xpath>
        <xpath expr="//span[@t-field='order.date_planned']/preceding-sibling::strong[1]" position="replace">
            <strong t-if="order.state not in ('sent')">Receipt Date:</strong>
        </xpath>
        <xpath expr="//span[@t-field='order.date_planned']" position="attributes">
            <attribute name="t-if">order.state not in ('sent')</attribute>
        </xpath>
    </template>
    <template id="ike_event_purchase_dispute_view" name="Purchase Order Portal Content Dispute" >
        <t t-call="portal.portal_layout">
            <owl-component
                name="ike_event_purchase.purchase_order_dispute"
                t-att-props="json.dumps({'order_id': order_sudo.id, 'action': dispute})"
            />
        </t>
    </template>
    <template id="ike_event_portal_my_purchase_orders" name="My Purchase Orders" inherit_id="purchase.portal_my_purchase_orders">
        <xpath expr="//t[1]" position="replace">
            <t t-call="portal.portal_layout">
                <t t-if="not orders">
                    <p class="o_view_nocontent_smiling_face">No purchase orders yet.</p>
                </t>
                <t t-if="orders">
                    <div class="o_portal_purchase_order_list">
                        <owl-component
                            name="ike_event_purchase.PurchaseOrderList"
                            t-att-props="json.dumps({})"
                        />
                    </div>
                </t>
            </t>
        </xpath>
    </template>
    <template id="ike_event_portal_my_purchase_order" name="Purchase Order Detail" inherit_id="purchase.portal_my_purchase_order">
        <xpath expr="//t[@t-set='title']//h2[@t-field='order.amount_total']" position="attributes">
            <attribute name="t-field">order.amount_untaxed</attribute>
        </xpath>
        <xpath expr="//div[@id='purchase_order_communication']" position="replace">
            <div id="purchase_order_communication" invisible="1">
            </div>
        </xpath>
    </template>
    <template id="ike_event_portal_my_purchase_rfqs" name="My Requests For Quotation" inherit_id="purchase.portal_my_purchase_rfqs">
        <xpath expr="//t[@t-set='breadcrumbs_searchbar']" position="attributes">
            <attribute name="t-value">False</attribute>
        </xpath>
        <xpath expr="//t[@t-call='portal.portal_searchbar']" position="replace"/>
        <xpath expr="//t[@t-if='rfqs']" position="replace">
            <t t-if="rfqs">
                <div class="o_portal_rfq_list">
                    <owl-component
                        name="ike_event_purchase.PurchaseRfqList"
                        t-att-props="json.dumps({'search': request.params.get('search', False)})"
                    />
                </div>
            </t>
        </xpath>
    </template>
    <template id="portal_pager_override" inherit_id="portal.pager">
        <xpath expr="//ul" position="attributes">
            <attribute name="t-if"/>
        </xpath>
    </template>
</odoo>