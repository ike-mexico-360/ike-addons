<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="purchase_order_kpis_tree_inherit_ike_event_purchase" model="ir.ui.view">
        <field name="name">purchase_order_kpis_tree.inherit.ike_event_purchase</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="x_action_consolidate" type="object" string="Consolidate"/>
            </xpath>
        </field>
    </record>

    <record id="purchase_order_form_inherit_ike_event_purchase" model="ir.ui.view">
        <field name="name">purchase_order_form.inherit.ike_event_purchase</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <!-- ToDo: Quitar este botón -->
            <!-- <xpath expr="//header" position="inside">
                <button name="x_action_button_test_tiket_details" type="object" string="Test Ticket Details"/>
            </xpath> -->
            <xpath expr="//field[@name='order_line']/list/field[@name='price_unit']" position="after">
                <field name="x_price_unit_dispute" optional="show"/>
                <field name="x_product_qty_dispute" optional="show"/>
                <field name="x_price_unit_approved" optional="show"/>
                <field name="x_product_qty_approved" optional="show"/>
            </xpath>
        </field>
    </record>

