<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="sh_product_product_view_form" model="ir.ui.view">
            <field name="name">product.template</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='options']//span" position="after">
                    <span class="d-inline-block" groups="sh_subscription.group_user_sh_subscription">
                        <field name="sh_product_subscribe" invisible="product_variant_count>1"  />
                        <label for="sh_product_subscribe" string="Is Subscription Type" invisible="product_variant_count>1"   />
                    </span>
                </xpath>
                <div name="list_price_uom" position="after">
                    <!-- <field name="sh_subscription_plan_id" invisible="product_variant_count>1 or not sh_product_subscribe"  required="sh_product_subscribe"     groups="sh_subscription.group_user_sh_subscription"/> -->
                    <field name="sh_subscription_plan_id" invisible="1"/>
                    <field name="sh_product_subscribe" invisible="1"/>
                </div>
                 <xpath expr="//field[@name='type']" position="attributes">
                    <attribute name="force_save">1</attribute>
                    <attribute name="readonly">sh_product_subscribe</attribute>
                </xpath>
                <xpath expr="//page[@name='sales']/group[2]" position="after" invisible="product_variant_count>1 or not sh_product_subscribe">
                    <field name="sh_product_subscribe" invisible="1"/>
                    <group string="Planes de afiliación" name="subscription_plan">
                        <field name="x_subscription_plan_ids" nolabel="1" mode="list" options="{'no_create': True,'edit': False,'no_edit': True,'no_open': True}">
                            <list string="Planes de afilicación" limit="200" edit="0" delete="0" create="0" no_open="1" no_edit="1" multi_edit="0">
                                <field name="name"/>
                            </list>
                        </field>
                    </group>
                </xpath>
            </field>
        </record>
        <record id="sh_product_variant_form_view" model="ir.ui.view">
            <field name="name">product.product</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_normal_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='sh_product_subscribe']/.." position="replace"/>
                <xpath expr="//field[@name='sh_subscription_plan_id']" position="replace"/>
                <xpath expr="//div[@name='options']//span" position="after">
                    <span class="d-inline-block" groups="sh_subscription.group_user_sh_subscription">
                        <field name="sh_product_subscribe" />
                        <label for="sh_product_subscribe"/>
                    </span>
                </xpath>
                <field name="lst_price" position="attributes">
                	<attribute name="force_save">1</attribute>
                </field>
                <div name="list_price_uom" position="after">
                    <!-- <field name="sh_subscription_plan_id" required="sh_product_subscribe" invisible="not sh_product_subscribe" groups="sh_subscription.group_user_sh_subscription"></field> -->
                    <field name="sh_subscription_plan_id" invisible="1"></field>
                </div>
                <xpath expr="//field[@name='type']" position="attributes">
                    <attribute name="readonly">sh_product_subscribe</attribute>
                </xpath>
            </field>
        </record>
        <record id="sh_product_variant_easy_edit_view" model="ir.ui.view">
            <field name="name">product.product</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_variant_easy_edit_view"/>
            <field name="arch" type="xml">
            	<field name="lst_price" position="attributes">
            		<attribute name="force_save">1</attribute>
            	</field>
                <xpath expr="//group[1]" position="after">
                    <group string="Subcription Details" groups="sh_subscription.group_user_sh_subscription">
                        <group>
                            <field name="sh_product_subscribe" />
                            <field name="sh_subscription_plan_id"  required="sh_product_subscribe" invisible="not sh_product_subscribe" ></field>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>